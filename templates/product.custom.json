{"sections":{"1763210298bcd17d87":{"type":"_blocks","settings":{}},"main":{"type":"main-product","blocks":{"vendor":{"type":"text","settings":{"text":"{{ product.vendor }}","text_style":"uppercase"}},"title":{"type":"title","settings":{}},"price":{"type":"price","settings":{}},"variant_picker":{"type":"variant_picker","settings":{"picker_type":"button","swatch_shape":"circle"}},"quantity_selector":{"type":"quantity_selector","settings":{}},"custom_liquid_WDQ3m7":{"type":"custom_liquid","settings":{"custom_liquid":"<div id=\"bbb-custom-wrap\" style=\"\n  margin-top: 16px;\n  padding: 14px;\n  border: 2px solid #c1121f;\n  background-color: rgba(193, 18, 31, 0.10);\n  border-radius: 8px;\n\">\n  <label for=\"bbb_custom_wording\" style=\"\n    display:block;\n    margin-bottom:8px;\n    font-weight:700;\n    color:#c1121f;\n    text-transform:uppercase;\n    letter-spacing:.03em;\n  \">\n    required · custom wording *\n  <\/label>\n\n  <input\n    id=\"bbb_custom_wording\"\n    name=\"properties[custom wording]\"\n    type=\"text\"\n    maxlength=\"100\"\n    placeholder=\"type it exactly here\"\n    style=\"\n      width:100%;\n      padding:12px;\n      border:2px solid #c1121f;\n      border-radius:6px;\n      background:#fff;\n      color:#000;\n      font-size:16px;\n      outline:none;\n    \"\n  >\n\n  <p id=\"bbb_custom_error\" style=\"display:none; margin-top:8px; font-size:13px; color:#c1121f;\">\n    please enter your custom wording before adding to cart.\n  <\/p>\n<\/div>\n\n<script>\n(function () {\n  function getVal() {\n    var input = document.getElementById('bbb_custom_wording');\n    return input ? (input.value || '').trim() : '';\n  }\n\n  function showError(show) {\n    var err = document.getElementById('bbb_custom_error');\n    if (err) err.style.display = show ? 'block' : 'none';\n  }\n\n  function findForm() {\n    \/\/ Works for Dawn + most themes\n    return (\n      document.querySelector('#bbb-custom-wrap')?.closest('form') ||\n      document.querySelector('product-form form') ||\n      document.querySelector('form[action^=\"\/cart\/add\"]') ||\n      document.querySelector('form[action*=\"cart\/add\"]')\n    );\n  }\n\n  function upsertProperty(form, value) {\n    var name = 'properties[custom wording]';\n    var hidden = form.querySelector('input[name=\"' + name.replace(\/\"\/g,'\\\\\"') + '\"]');\n    if (!hidden) {\n      hidden = document.createElement('input');\n      hidden.type = 'hidden';\n      hidden.name = name;\n      form.appendChild(hidden);\n    }\n    hidden.value = value;\n  }\n\n  function blockIfEmpty(e) {\n    var v = getVal();\n    if (!v) {\n      e.preventDefault();\n      e.stopPropagation();\n      showError(true);\n      var input = document.getElementById('bbb_custom_wording');\n      if (input) input.focus();\n      return true;\n    }\n    showError(false);\n    var form = findForm();\n    if (form) upsertProperty(form, v);\n    return false;\n  }\n\n  function wire() {\n    var form = findForm();\n    if (!form) return;\n\n    \/\/ Block submit (some themes still submit normally)\n    form.addEventListener('submit', function (e) {\n      blockIfEmpty(e);\n    }, true);\n\n    \/\/ Block button clicks (AJAX themes usually hook here)\n    var btns = form.querySelectorAll('button[name=\"add\"], button[type=\"submit\"], input[type=\"submit\"]');\n    btns.forEach(function (btn) {\n      btn.addEventListener('click', function (e) {\n        blockIfEmpty(e);\n      }, true);\n    });\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', wire);\n  } else {\n    wire();\n  }\n  \/\/ Extra passes for themes that render product form after load\n  setTimeout(wire, 300);\n  setTimeout(wire, 1200);\n})();\n<\/script>"}},"buy_buttons":{"type":"buy_buttons","settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"description":{"type":"description","settings":{}},"share":{"type":"share","settings":{"share_label":"Share"}}