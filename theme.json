{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1180px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "black",
          "name": "Black",
          "color": "#0b0b0b"
        },
        {
          "slug": "ink",
          "name": "Ink",
          "color": "#111111"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        },
        {
          "slug": "pink",
          "name": "Pink",
          "color": "#e85a9b"
        },
        {
          "slug": "pink-light",
          "name": "Pink Light",
          "color": "#ff8ac7"
        },
        {
          "slug": "pink-society",
          "name": "Pink Society",
          "color": "#EC80B8"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "rgba(246,246,246,0.6)"
        }
      ]
    },
    "typography": {
      "fluid": false,
      "fontFamilies": [
        {
          "slug": "serif",
          "name": "Libre Baskerville",
          "fontFamily": "'Libre Baskerville', Georgia, 'Times New Roman', serif"
        },
        {
          "slug": "display",
          "name": "Playfair Display",
          "fontFamily": "'Playfair Display', Georgia, serif"
        },
        {
          "slug": "script",
          "name": "Dancing Script",
          "fontFamily": "'Dancing Script', cursive"
        },
        {
          "slug": "sans",
          "name": "Inter",
          "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.75rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.125rem"
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "2.625rem"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--black)",
      "text": "var(--wp--preset--color--white)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.65"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--pink)",
          "text": "var(--wp--preset--color--white)"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1.375rem",
            "bottom": "0.75rem",
            "left": "1.375rem"
          }
        },
        "typography": {
          "fontWeight": "600",
          "letterSpacing": "0.08em"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "400",
          "lineHeight": "1.12",
          "textTransform": "lowercase"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--pink)"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "front-page",
      "title": "Front Page",
      "postTypes": ["page"]
    },
    {
      "name": "home",
      "title": "Blog Home",
      "postTypes": ["page"]
    },
    {
      "name": "page-home",
      "title": "Homepage",
      "postTypes": ["page"]
    }
  ]
}
