{
  "name": "sss read tracker calendar",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "your reading life"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "track your reads"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "click a day, choose the book you finished, and let the cover live there."
    }
  ],
  "presets": [
    {
      "name": "sss read tracker calendar"
    }
  ]
}
{% endschema %}
