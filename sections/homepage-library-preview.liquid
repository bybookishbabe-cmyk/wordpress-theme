bottom:0;
z-index:2;
transform:translate(8px, 8px) rotate(-2deg);
animation:bbbHomeRecSlide 3.6s ease-in-out infinite;
}

.bbb-homeRecDemo__book img{
width:86px;
aspect-ratio:3 / 4.2;
object-fit:cover;
border-radius:14px;
display:block;
}

.bbb-homeRecDemo__label{
grid-column:1 / -1;
font-size:10px;
letter-spacing:.14em;
text-transform:uppercase;
color:#ffb8e0;
}

.bbb-homeRecDemo__meta{
align-self:center;
}

.bbb-homeRecDemo__bookTitle{
font-family:'Cormorant', serif;
font-size:1.5rem;
line-height:1.02;
color:#f7f3ee;
}

.bbb-homeRecDemo__bookLine{
margin-top:8px;
font-size:12px;
line-height:1.45;
color:rgba(247,243,238,.7);
}

@keyframes bbbHomeRecSlide{
  0%, 18% { transform:translate(34px, 18px) rotate(-4deg); opacity:.22; }
  34%, 100% { transform:translate(8px, 8px) rotate(-2deg); opacity:1; }
}

/* center header */

.sss-lib--preview .sss-lib__archiveHead{
max-width:700px;
margin:0 auto 40px;
}

/* center shelf */

.sss-lib--preview .sss-lib__shelfRow{
display:flex;
justify-content:center;
align-items:flex-start;
flex-wrap:wrap;
gap:22px;
margin:auto;
max-width:900px;
}

/* ensure cards behave like library cards */

.sss-lib--preview .sss-lib__book{
flex:0 0 auto;
}

/* link below shelf */

.sss-lib__previewLink{
margin-top:40px;
text-align:center;
}

.sss-lib__previewLink a{
font-size:12px;
letter-spacing:.14em;
text-transform:uppercase;
text-decoration:none;
color:#ff8ac7;
border-bottom:1px solid rgba(255,138,199,.6);
padding-bottom:4px;
}

/* ===============================
PREVIEW HEADER FIX
================================ */

.sss-lib--preview .sss-lib__archiveHead{
text-align:center;
max-width:900px;
margin:0 auto 50px;
}

/* kicker */

.sss-lib--preview .sss-lib__archiveKicker{
font-size:13px;
letter-spacing:.25em;
text-transform:uppercase;
