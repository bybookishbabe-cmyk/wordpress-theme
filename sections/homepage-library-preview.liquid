{% assign books = shop.metaobjects.sss_library.values %}
{% assign demo_pick_title_key = section.settings.demo_pick_title | downcase | strip %}
{% assign demo_result_title_key = section.settings.demo_result_title | downcase | strip %}
{% assign demo_pick_handle_key = section.settings.demo_pick_title | handleize %}
{% assign demo_result_handle_key = section.settings.demo_result_title | handleize %}
{% assign demo_pick_cover_url = '' %}
{% assign demo_result_cover_url = '' %}
{% assign demo_pick_book = shop.metaobjects.sss_library[demo_pick_handle_key] %}
{% assign demo_result_book = shop.metaobjects.sss_library[demo_result_handle_key] %}

{% if demo_pick_book != blank %}
  {% assign demo_pick_cover_value = demo_pick_book.cover.value | default: demo_pick_book.cover %}
  {% assign demo_pick_cover_url = demo_pick_cover_value.url | default: demo_pick_cover_value %}
{% endif %}

{% if demo_result_book != blank %}
  {% assign demo_result_cover_value = demo_result_book.cover.value | default: demo_result_book.cover %}
  {% assign demo_result_cover_url = demo_result_cover_value.url | default: demo_result_cover_value %}
{% endif %}

{% for book in books %}
  {% assign book_title_value = book.title.value | default: book.title %}
  {% assign book_title_key = book_title_value | downcase | strip %}
  {% assign book_handle_key = book.system.handle | default: book.handle | handleize %}
  {% assign book_cover_value = book.cover.value | default: book.cover %}
  {% assign book_cover_url = book_cover_value.url | default: book_cover_value %}
  {% if demo_pick_cover_url == blank and book_title_key == demo_pick_title_key or demo_pick_cover_url == blank and book_handle_key == demo_pick_handle_key %}
    {% assign demo_pick_cover_url = book_cover_url %}
  {% endif %}
  {% if demo_result_cover_url == blank and book_title_key == demo_result_title_key or demo_result_cover_url == blank and book_handle_key == demo_result_handle_key %}
    {% assign demo_result_cover_url = book_cover_url %}
  {% endif %}
{% endfor %}

<section class="sss-lib sss-lib--preview" data-sss-lib="public">

<div class="sss-lib__wrap">

<a href="{{ section.settings.demo_link | default: 'https://bybookishbabe.com/pages/what-to-read-next' }}" class="bbb-homeRecDemo">
  <div class="bbb-homeRecDemo__copy">
    <div class="bbb-homeRecDemo__kicker">
      {{ section.settings.demo_kicker }}
    </div>

    <div class="bbb-homeRecDemo__title">
      {{ section.settings.demo_title }}
    </div>

    <div class="bbb-homeRecDemo__sub">
      {{ section.settings.demo_subtext }}
    </div>

    <div class="bbb-homeRecDemo__cta">
      {{ section.settings.demo_button }}
    </div>
  </div>

  <div class="bbb-homeRecDemo__stage" aria-hidden="true">
    <div class="bbb-homeRecDemo__book bbb-homeRecDemo__book--picked">
      <div class="bbb-homeRecDemo__label">you picked</div>
      {% if section.settings.demo_pick_cover != blank or demo_pick_cover_url != blank %}
        <img src="{% if section.settings.demo_pick_cover != blank %}{{ section.settings.demo_pick_cover | image_url: width: 320 }}{% else %}{{ demo_pick_cover_url }}{% endif %}" alt="{{ section.settings.demo_pick_title | escape }}" loading="lazy">
      {% endif %}
      <div class="bbb-homeRecDemo__meta">
        <div class="bbb-homeRecDemo__bookTitle">{{ section.settings.demo_pick_title }}</div>
        <div class="bbb-homeRecDemo__bookLine">{{ section.settings.demo_pick_meta }}</div>
      </div>
    </div>

    <div class="bbb-homeRecDemo__book bbb-homeRecDemo__book--result">
      <div class="bbb-homeRecDemo__label">closest match</div>
      {% if section.settings.demo_result_cover != blank or demo_result_cover_url != blank %}
        <img src="{% if section.settings.demo_result_cover != blank %}{{ section.settings.demo_result_cover | image_url: width: 320 }}{% else %}{{ demo_result_cover_url }}{% endif %}" alt="{{ section.settings.demo_result_title | escape }}" loading="lazy">
      {% endif %}
      <div class="bbb-homeRecDemo__meta">
        <div class="bbb-homeRecDemo__bookTitle">{{ section.settings.demo_result_title }}</div>
        <div class="bbb-homeRecDemo__bookLine">{{ section.settings.demo_result_meta }}</div>
      </div>
    </div>
  </div>
</a>

<div class="sss-lib__archiveHead">
<div class="sss-lib__archiveKicker">
society favorites
</div>

<h2 class="sss-lib__archiveTitle">
what the society is obsessed with
</h2>

<div class="sss-lib__archiveSub">
a few books the society can’t stop recommending.
</div>
</div>

<div class="sss-lib__shelf">
<div class="sss-lib__shelfRow" id="sssPreviewTrending" data-sss-lib="public">

{% paginate shop.metaobjects.sss_library.values by 250 %}
{% assign books = shop.metaobjects.sss_library.values %}
{% assign obsessed_books_count = 0 %}
{% capture obsessed_books_markup %}{% endcapture %}

{% for book in books %}
  {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
  {% assign is_visible_value = is_visible | strip %}
  {% unless is_visible_value == 'true' %}
    {% continue %}
  {% endunless %}
  {% capture is_private %}{% render 'sss-book-private', book: book %}{% endcapture %}
  {% assign is_private_value = is_private | strip %}
  {% if is_private_value == 'true' %}
    {% continue %}
  {% endif %}

  {% assign top_shelf_value = book.top_shelf.value | default: book.top_shelf %}

  {% if obsessed_books_count < 5 and top_shelf_value == true %}
    {% assign obsessed_books_count = obsessed_books_count | plus: 1 %}
    {% capture obsessed_books_markup %}
      {{ obsessed_books_markup }}
      {% render 'sss-book-card', book: book, mini: true %}
    {% endcapture %}
  {% endif %}
{% endfor %}

{{ obsessed_books_markup }}

{% endpaginate %}

</div>
</div>

<div class="sss-lib__previewLink">
<a href="/pages/library">
explore the full library →
</a>
</div>

</div>

</section>


<style>
  /* ===============================
SOCIAL FAVORITES PREVIEW
uses normal library styling
================================ */

.sss-lib--preview{
margin:60px auto;
text-align:center;
}

.bbb-homeRecDemo{
display:grid;
grid-template-columns:minmax(0, 1fr) minmax(320px, 420px);
gap:28px;
max-width:760px;
margin:0 auto 34px;
padding:26px 28px;
border:1px solid rgba(255,255,255,.12);
border-radius:24px;
background:linear-gradient(180deg, rgba(255,138,199,.08), rgba(255,255,255,.03));
box-shadow:0 18px 50px rgba(0,0,0,.22);
text-decoration:none;
align-items:center;
text-align:left;
}

.bbb-homeRecDemo__kicker{
font-size:12px;
letter-spacing:.18em;
text-transform:uppercase;
color:#ffb8e0;
margin-bottom:12px;
}

.bbb-homeRecDemo__title{
font-family:'Cormorant', serif;
font-size:clamp(2.1rem, 4vw, 3rem);
line-height:1.02;
color:#f7f3ee;
}

.bbb-homeRecDemo__sub{
max-width:40ch;
margin:12px 0 0;
font-size:1.02rem;
line-height:1.65;
color:rgba(247,243,238,.72);
}

.bbb-homeRecDemo__cta{
display:inline-flex;
align-items:center;
justify-content:center;
width:max-content;
margin-top:18px;
padding:13px 22px;
border-radius:999px;
background:#ff8ac7;
color:#1b1016;
text-decoration:none;
font-size:12px;
letter-spacing:.14em;
text-transform:uppercase;
font-weight:700;
}

.bbb-homeRecDemo__stage{
position:relative;
min-height:260px;
}

.bbb-homeRecDemo__book{
position:absolute;
display:grid;
grid-template-columns:86px minmax(0, 1fr);
gap:14px;
width:100%;
padding:14px;
border-radius:20px;
border:1px solid rgba(255,255,255,.12);
background:rgba(15,15,18,.86);
box-shadow:0 18px 38px rgba(0,0,0,.26);
}

.bbb-homeRecDemo__book--picked{
