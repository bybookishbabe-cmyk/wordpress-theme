{% assign tease_pick_title_key = section.settings.rec_pick_title | downcase | strip %}
{% assign tease_result_title_key = section.settings.rec_result_title | downcase | strip %}
{% assign tease_pick_handle_key = section.settings.rec_pick_title | handleize %}
{% assign tease_result_handle_key = section.settings.rec_result_title | handleize %}
{% assign tease_pick_cover_url = '' %}
{% assign tease_result_cover_url = '' %}
{% assign tease_pick_book = shop.metaobjects.sss_library[tease_pick_handle_key] %}
{% assign tease_result_book = shop.metaobjects.sss_library[tease_result_handle_key] %}

{% if tease_pick_book != blank %}
  {% assign tease_pick_cover_value = tease_pick_book.cover.value | default: tease_pick_book.cover %}
  {% assign tease_pick_cover_url = tease_pick_cover_value.url | default: tease_pick_cover_value %}
{% endif %}

{% if tease_result_book != blank %}
  {% assign tease_result_cover_value = tease_result_book.cover.value | default: tease_result_book.cover %}
  {% assign tease_result_cover_url = tease_result_cover_value.url | default: tease_result_cover_value %}
{% endif %}
{% assign tease_books = shop.metaobjects.sss_library.values %}
{% for book in tease_books %}
  {% assign book_title_value = book.title.value | default: book.title %}
  {% assign book_title_key = book_title_value | downcase | strip %}
  {% assign book_handle_key = book.system.handle | default: book.handle | handleize %}
  {% assign book_cover_value = book.cover.value | default: book.cover %}
  {% assign book_cover_url = book_cover_value.url | default: book_cover_value %}
  {% if tease_pick_cover_url == blank and book_title_key == tease_pick_title_key or tease_pick_cover_url == blank and book_handle_key == tease_pick_handle_key %}
    {% assign tease_pick_cover_url = book_cover_url %}
  {% endif %}
  {% if tease_result_cover_url == blank and book_title_key == tease_result_title_key or tease_result_cover_url == blank and book_handle_key == tease_result_handle_key %}
    {% assign tease_result_cover_url = book_cover_url %}
  {% endif %}
{% endfor %}

<a href="{{ section.settings.rec_link | default: 'https://bybookishbabe.com/pages/what-to-read-next' }}" class="bbb-homeRecDemo bbb-homeRecDemo--library">
