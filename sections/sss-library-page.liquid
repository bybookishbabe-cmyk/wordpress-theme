<div class="sss-lib__finder" id="sssReadFinder">
  <div class="sss-lib__finderHead">
    <div class="sss-lib__finderKicker">need help finding your next read?</div>
    <h2 class="sss-lib__finderTitle">let me play book matchmaker.</h2>
    <div class="sss-lib__finderSub">
      answer three quick questions and i’ll pull a romance obsession from the society shelves.
    </div>
  </div>

  <div class="sss-lib__finderGrid">
    <label class="sss-lib__finderField" for="sssFinderShelf" data-finder-step="1">
      <span>1. what kind of shelf are you craving?</span>
      <select id="sssFinderShelf">
        <option value="">choose a genre</option>
        {% assign finder_shelves = '|' %}
        {% for book in all_books %}
          {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
          {% assign is_visible_value = is_visible | strip %}
          {% unless is_visible_value == 'true' %}
            {% continue %}
          {% endunless %}
          {% assign shelf_name = book.shelf.value.name | strip %}
          {% assign shelf_token = '|' | append: shelf_name | append: '|' %}
          {% if shelf_name != blank %}
            {% unless finder_shelves contains shelf_token %}
              {% assign finder_shelves = finder_shelves | append: shelf_name | append: '|' %}
              <option value="{{ shelf_name | escape }}">{{ shelf_name }}</option>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </select>
    </label>

    <label class="sss-lib__finderField" for="sssFinderTropeOne" data-finder-step="2">
      <span>2. pick a trope you always fall for</span>
      <select id="sssFinderTropeOne">
        <option value="">choose a trope</option>
        {% assign finder_tropes = '|' %}
        {% for book in all_books %}
          {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
          {% assign is_visible_value = is_visible | strip %}
          {% unless is_visible_value == 'true' %}
            {% continue %}
          {% endunless %}
          {% for trope in book.tropes.value %}
            {% assign trope_name = trope.name | strip %}
            {% assign trope_token = '|' | append: trope_name | append: '|' %}
            {% if trope_name != blank %}
              {% unless finder_tropes contains trope_token %}
                {% assign finder_tropes = finder_tropes | append: trope_name | append: '|' %}
                <option value="{{ trope_name | escape }}">{{ trope_name }}</option>
              {% endunless %}
            {% endif %}
          {% endfor %}
        {% endfor %}
      </select>
    </label>

    <label class="sss-lib__finderField" for="sssFinderTropeTwo" data-finder-step="3">
      <span>3. get specific with one more vibe</span>
      <select id="sssFinderTropeTwo">
        <option value="">surprise me</option>
        {% assign finder_tropes_two = '|' %}
        {% for book in all_books %}
          {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
          {% assign is_visible_value = is_visible | strip %}
          {% unless is_visible_value == 'true' %}
            {% continue %}
          {% endunless %}
          {% for trope in book.tropes.value %}
            {% assign trope_name = trope.name | strip %}
            {% assign trope_token = '|' | append: trope_name | append: '|' %}
            {% if trope_name != blank %}
              {% unless finder_tropes_two contains trope_token %}
                {% assign finder_tropes_two = finder_tropes_two | append: trope_name | append: '|' %}
                <option value="{{ trope_name | escape }}">{{ trope_name }}</option>
              {% endunless %}
            {% endif %}
          {% endfor %}
        {% endfor %}
      </select>
    </label>
  </div>

  <div class="sss-lib__finderActions">
    <button type="button" class="sss-lib__finderBtn" id="sssFinderSubmit" disabled>
      find my next read
    </button>
  </div>

  <div class="sss-lib__finderResult" id="sssFinderResult" hidden>
    <div class="sss-lib__finderResultCard">
      <button type="button" class="sss-lib__finderCoverBtn" id="sssFinderOpen" aria-label="Open book details">
        <img class="sss-lib__finderCover" id="sssFinderCover" alt="" loading="lazy">
      </button>

      <div class="sss-lib__finderResultBody">
        <div class="sss-lib__finderResultLabel">your next obsession might be</div>
        <div class="sss-lib__finderResultTitle" id="sssFinderResultTitle"></div>
        <div class="sss-lib__finderResultAuthor" id="sssFinderResultAuthor"></div>
        <div class="sss-lib__finderResultMeta" id="sssFinderResultMeta"></div>
        <div class="sss-lib__finderResultWhy" id="sssFinderResultWhy"></div>

        <div class="sss-lib__finderResultActions">
          <button type="button" class="sss-lib__finderBtn sss-lib__finderBtn--ghost" id="sssFinderRead">
            i've read it
          </button>
          <button type="button" class="sss-lib__finderBtn sss-lib__finderBtn--ghost" id="sssFinderRetry">
            give me another
          </button>
        </div>

        <div class="sss-lib__finderResultNote" id="sssFinderResultNote"></div>
      </div>
    </div>
  </div>

  <script type="application/json" id="sssFinderData">
    [
      {% assign finder_first = true %}
      {% for book in all_books %}
        {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
        {% assign is_visible_value = is_visible | strip %}
        {% unless is_visible_value == 'true' %}
          {% continue %}
        {% endunless %}
        {% unless finder_first %},{% endunless %}
        {% assign finder_first = false %}
        {
          "handle": {{ book.system.handle | json }},
          "title": {{ book.title.value | json }},
          "author": {{ book.author.value | json }},
          "cover": {{ book.cover.value.url | default: book.cover.value | json }},
          "why": {{ book.why_i_loved_it.value | strip_html | json }},
          "mini": {{ book.mini_note.value | strip_html | json }},
          "shelf": {{ book.shelf.value.name | strip | json }},
          "tropes": [
            {% for trope in book.tropes.value %}
              {{ trope.name | strip | json }}{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }
      {% endfor %}
    ]
  </script>
</div>

