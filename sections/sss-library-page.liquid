{% comment %}
===============================================================
SMUT & SENTIMENT SOCIETY — LIBRARY PAGE

===============================================================
{% endcomment %}

<section class="sss-lib" id="sss-lib-{{ section.id }}" data-sss-lib="society">

  <div class="sss-lib__wrap">

	    <header class="sss-lib__head">
	      <p class="sss-lib__kicker">{{ section.settings.kicker }}</p>
	      <h1 class="sss-lib__title">{{ section.settings.title }}</h1>
	      {% if section.settings.subtext != blank %}
	        <p class="sss-lib__sub">{{ section.settings.subtext }}</p>
	      {% endif %}
        <a class="sss-lib__kuLink" href="https://amzn.to/4uZ8Y3a" target="_blank" rel="noopener sponsored">
          on a kindle kick? try kindle unlimited →
        </a>
	    </header>

{% paginate shop.metaobjects.sss_library.values by 250 %}
{% assign jump_books = shop.metaobjects.sss_library.values | sort: "title" %}
{% endpaginate %}

{% assign jump_starter_count = 0 %}
{% assign jump_private_count = 0 %}
{% assign jump_mood_shelf_list = '' %}
{% assign jump_has_mood_shelves = false %}

{% for book in jump_books %}
  {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
  {% assign is_visible_value = is_visible | strip %}
  {% unless is_visible_value == 'true' %}
    {% continue %}
  {% endunless %}
  {% capture is_private %}{% render 'sss-book-private', book: book %}{% endcapture %}
  {% assign is_private_value = is_private | strip %}

  {% if book.starter_pack.value %}
    {% assign jump_starter_count = jump_starter_count | plus: 1 %}
  {% endif %}

  {% assign jump_shelf_name = book.shelf.value.name | strip %}

  {% if is_private_value == 'true' %}
    {% assign jump_private_count = jump_private_count | plus: 1 %}
  {% endif %}

  {% if jump_shelf_name != blank and jump_shelf_name != 'society classics' %}
    {% assign jump_shelf_token = '|' | append: jump_shelf_name | append: '|' %}
    {% unless jump_mood_shelf_list contains jump_shelf_token %}
      {% assign jump_mood_shelf_list = jump_mood_shelf_list | append: jump_shelf_name | append: '|' %}
    {% endunless %}
  {% endif %}
{% endfor %}

{% assign jump_mood_shelves = jump_mood_shelf_list | split: '|' %}
{% for shelf in jump_mood_shelves %}
  {% if shelf == blank or jump_has_mood_shelves %}
    {% continue %}
  {% endif %}

  {% assign jump_shelf_count = 0 %}
  {% for book in jump_books %}
    {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
    {% assign is_visible_value = is_visible | strip %}
    {% unless is_visible_value == 'true' %}
      {% continue %}
    {% endunless %}
    {% assign book_shelf = book.shelf.value.name | strip %}
    {% if book_shelf == shelf %}
      {% assign jump_shelf_count = jump_shelf_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if jump_shelf_count > 5 %}
    {% assign jump_has_mood_shelves = true %}
  {% endif %}
{% endfor %}


