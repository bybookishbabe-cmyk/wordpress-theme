===============================================================
{% endcomment %}
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script>
const { createClient } = supabase;

const client = createClient(
   "https://efmrfxsmgbeikfgtrxjv.supabase.co",
  "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVmbXJmeHNtZ2JlaWtmZ3RyeGp2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE5ODgzNzEsImV4cCI6MjA4NzU2NDM3MX0.icXIZi_2Cm_s82ogkdKaXperJHeEIrbKsF3MFEPjCJI"
);

const input = document.getElementById("bomName");
const button = document.getElementById("bomSubmit");
const results = document.getElementById("bomResults");
const bomBookMapEl = document.getElementById("sssBomBookMap");
let bomBookMap = [];

try{
  bomBookMap = bomBookMapEl ? JSON.parse(bomBookMapEl.textContent) : [];
}catch(error){
  console.error("BOM map failed to parse", error);
}

function normalizeBom(value){
  return String(value || "").trim().toLowerCase();
}

function findBomMatch(name){
  const target = normalizeBom(name);
  if(!target || !Array.isArray(bomBookMap)) return null;

  return bomBookMap.find(function(entry){
    return normalizeBom(entry.boyfriend_name) === target;
  }) || null;
}

async function submitVote(){
  const name = input.value.trim();
  if(!name) return;

  await client.from("boyfriend_votes").insert([
    { name: name }
  ]);

  input.value = "";
  loadResults();
}

async function loadResults(){
  const { data, error } = await client
    .from("boyfriend_votes_current_month")
    .select("name,vote_count")
    .order("vote_count", { ascending: false })
    .order("name", { ascending: true });

  if(error){
    console.error(error);
    return;
  }

  if(!data || data.length === 0){
    results.innerHTML = "no one has been crowned yet.";
    return;
  }

  const sorted = data.map(function(v){
    return [v.name, Number(v.vote_count || 0)];
  });

  const totalVotes = sorted.reduce(function(sum, entry){
    return sum + entry[1];
  }, 0);

  const topThree = sorted.slice(0,3);

  const winner = topThree[0];
  const winnerPercent = Math.round((winner[1] / totalVotes) * 100);
  const winnerMatch = findBomMatch(winner[0]);
  const winnerTrope = winnerMatch && Array.isArray(winnerMatch.tropes) && winnerMatch.tropes.length
    ? winnerMatch.tropes[0]
    : "";
  const winnerType = winnerMatch && winnerMatch.boyfriend_type
    ? winnerMatch.boyfriend_type
    : "";

  // Build HTML
  results.innerHTML = `
    <div class="sss-bom__winnerReveal">
      <div class="sss-bom__eyebrow">this month’s private-shelf problem</div>
      <div class="sss-bom__winner crown-hidden">
        👑 ${winner[0]}
      </div>

      <div class="sss-bom__tagline">
        ${winnerPercent >= 50 ? "the society is down bad." : "the society has spoken."}
      </div>

      <div class="sss-bom__barWrap">
        <div class="sss-bom__bar" style="width:0%"></div>
      </div>

      <div class="sss-bom__stats">
        ${winnerPercent}% obsession rate · ${totalVotes} votes cast
      </div>

      ${
        winnerTrope
          ? `<div class="sss-bom__trait">looks like we like <span>${winnerTrope}</span>${winnerType ? ` and a little ${winnerType.toLowerCase()}` : ""}.</div>`
          : winnerType
            ? `<div class="sss-bom__trait">looks like we like <span>${winnerType.toLowerCase()}</span> energy.</div>`
            : `<div class="sss-bom__trait">looks like we like fictional men who ruin our peace.</div>`
      }

      ${
        winnerMatch && winnerMatch.title
          ? `<div class="sss-bom__bookHint">currently haunting us in <em>${winnerMatch.title}</em></div>`
          : ""
      }
    </div>

    <div class="sss-bom__topThree">
      ${topThree.map((entry, index) => {
        const percent = Math.round((entry[1] / totalVotes) * 100);
        return `
          <div class="sss-bom__rank">
            <span class="sss-bom__rankNum">#${index+1}</span>
            <span class="sss-bom__rankName">${entry[0]}</span>
            <span class="sss-bom__rankPercent">${percent}% of votes</span>
          </div>
        `;
      }).join('')}
    </div>
  `;

  // Animate reveal
  setTimeout(() => {
    const crown = document.querySelector('.sss-bom__winner');
    const bar = document.querySelector('.sss-bom__bar');

    if(crown) crown.classList.remove('crown-hidden');
    if(bar) bar.style.width = winnerPercent + "%";

  }, 300);
}

button.addEventListener("click", submitVote);
loadResults();
</script>

<div id="sssBackToTop">
  <button class="sss-lib__backTopBtn" aria-label="Back to top">↑</button>
</div>

