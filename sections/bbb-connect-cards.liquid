{%- liquid
  assign sid = section.id
-%}

<!-- bybookishbabe · connect cards -->
<section id="bbb-connect-{{ sid }}" class="bbb-connect-cards" data-bbb-connect>
  <div class="bbb-connect-cards__inner">

    <header class="bbb-connect-cards__header">
      <h2 class="bbb-connect-cards__title">
        <span class="bbb-lets">{{ section.settings.script_word }}</span>
        <span class="bbb-word">{{ section.settings.main_word }}</span>
      </h2>

      <p class="bbb-connect-cards__sub">
        {{ section.settings.subtext }}
      </p>
    </header>

    <div class="bbb-card-wrap">

      <!-- THIS ROW behaves like your "favorites-row" -->
      <div class="bbb-card-row" data-swipe-row>
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'tiktok' -%}
              <a class="libcard" href="{{ block.settings.link | default: 'https://www.tiktok.com/@bybookishbabe' }}" target="_blank" rel="noopener" style="--bbb-card-delay: .45s;" {{ block.shopify_attributes }}>
                <div class="libcard__paper">
                  <div class="libcard__hole"></div>
                  <div class="libcard__head">
                    <span class="libcard__platform">
                      <svg viewBox="0 0 24 24" class="libcard__ico" aria-hidden="true">
                        <path fill="currentColor" d="M21 8.25a6.75 6.75 0 0 1-4.5-1.694v6.706A6.264 6.264 0 1 1 9.75 7.05v2.496a3.768 3.768 0 1 0 2.25 3.451V3h2.25a4.5 4.5 0 0 0 4.5 4.5z"/>
                      </svg>
                      {{ block.settings.platform_label }}
                    </span>
                    <span class="libcard__handle">{{ block.settings.handle }}</span>
                  </div>
                  <div class="libcard__body">
                    <div class="libcard__row"><span>feed</span><span>{{ block.settings.account }}</span></div>
                    <div class="libcard__row"><span>posts</span><span>{{ block.settings.category }}</span></div>
                    <div class="libcard__row"><span>good for</span><span>{{ block.settings.status }}</span></div>
                  </div>
                </div>
              </a>

            {%- when 'substack' -%}
              <a class="libcard is-substack" href="{{ block.settings.link | default: 'https://thesmutandsentimentsociety.substack.com/subscribe' }}" target="_blank" rel="noopener" style="--bbb-card-delay: .82s;" {{ block.shopify_attributes }}>
                <div class="libcard__paper">
                  <div class="libcard__hole"></div>
                  <div class="libcard__head">
                    <span class="libcard__platform">
                      <svg viewBox="0 0 24 24" class="libcard__ico" aria-hidden="true">
                        <path fill="currentColor" d="M4 4h16v3H4V4zm0 4h16v3H4V8zm0 4h16v8L12 16 4 20v-8z"/>
                      </svg>
                      {{ block.settings.platform_label }}
                    </span>
                    <span class="libcard__handle">{{ block.settings.handle }}</span>
                  </div>
                  <div class="libcard__body">
                    <div class="libcard__row"><span>tier</span><span>{{ block.settings.tier }}</span></div>
                    <div class="libcard__row"><span>inside</span><span>{{ block.settings.sundays }}</span></div>
                    <div class="libcard__row"><span>extras</span><span>{{ block.settings.perks }}</span></div>
                  </div>
                </div>
              </a>

            {%- when 'instagram' -%}
              <a class="libcard" href="{{ block.settings.link | default: 'https://www.instagram.com/bybookishbabe/' }}" target="_blank" rel="noopener" style="--bbb-card-delay: 1.19s;" {{ block.shopify_attributes }}>
                <div class="libcard__paper">
                  <div class="libcard__hole"></div>
                  <div class="libcard__head">
                    <span class="libcard__platform">
                      <svg viewBox="0 0 24 24" class="libcard__ico" aria-hidden="true">
                        <path fill="currentColor" d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7zm5 3.5a5.5 5.5 0 1 1 0 11.001A5.5 5.5 0 0 1 12 7.5zm0 2a3.5 3.5 0 1 0 .001 7.001A3.5 3.5 0 0 0 12 9.5zm5.75-.75a.75.75 0 1 1 0 1.5.75.75 0 0 1 0-1.5z"/>
                      </svg>
                      {{ block.settings.platform_label }}
                    </span>
                    <span class="libcard__handle">{{ block.settings.handle }}</span>
                  </div>
                  <div class="libcard__body">
                    <div class="libcard__row"><span>grid</span><span>{{ block.settings.style }}</span></div>
                    <div class="libcard__row"><span>focus</span><span>{{ block.settings.vibe }}</span></div>
                    <div class="libcard__row"><span>good for</span><span>{{ block.settings.status }}</span></div>
                  </div>
                </div>
              </a>

          {%- endcase -%}
        {%- endfor -%}
      </div>

      <!-- swipe hint like your favorites -->
      <div class="bbb-swipe-hint" aria-hidden="true">
        <span class="bbb-dot"></span>
        <span class="bbb-dot"></span>
        <span class="bbb-dot"></span>
        <span class="bbb-hint-text">swipe me</span>
      </div>

    </div>
  </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant:wght@500;600&display=swap');

#bbb-connect-{{ sid }}.bbb-connect-cards{
  --ink:#111111;
  background:#000;
  color:#fff;
  position:relative;
  isolation:isolate;
  overflow:hidden;
  padding:clamp(1.8rem,4vw,3.2rem) 1rem clamp(3rem,6vw,4.8rem);
  font-family:'Cormorant',serif;
  margin-top:-1.4rem;
}

#bbb-connect-{{ sid }} .bbb-connect-cards__inner{
  max-width:1150px;
  margin:0 auto;
  opacity:0;
  transform:translateX(-4.2rem);
  animation:bbbConnectSlideIn .9s cubic-bezier(.22,1,.36,1) forwards;
}

/* header side-by-side (desktop) */
#bbb-connect-{{ sid }} .bbb-connect-cards__header{
  display:flex;
  align-items:flex-end;
  justify-content:space-between;
  gap:clamp(16px,3vw,28px);
  margin-bottom:clamp(1.4rem,2.4vw,2.2rem);
}

#bbb-connect-{{ sid }} .bbb-connect-cards__title{
  margin:0;
  line-height:1;
  display:flex;
  align-items:baseline;
  gap:.18em;
  white-space:nowrap;
}

#bbb-connect-{{ sid }} .bbb-lets{
  font-family:'Great Vibes',cursive;
  font-size:clamp(4.6rem,8vw,7.2rem);
  transform:translateY(.12em);
  color:#fff;
}

#bbb-connect-{{ sid }} .bbb-word{
  font-size:clamp(3rem,5.5vw,4.2rem);
  text-transform:lowercase;
  font-weight:600;
}

#bbb-connect-{{ sid }} .bbb-connect-cards__sub{
  margin:0;
  max-width:520px;
  font-size:clamp(1.4rem,2.2vw,1.8rem);
  opacity:.9;
  text-align:left;
}

/* ORIGINAL desktop layout: 3-up grid */
#bbb-connect-{{ sid }} .bbb-card-row{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:clamp(18px,2.5vw,26px);
}

/* card styling (your original sizing) */
#bbb-connect-{{ sid }} .libcard{
  text-decoration:none;
  color:var(--ink);
  transition:transform .25s ease;
  opacity:0;
  transform:translateY(26px);
  animation:bbbConnectCardIn 1.1s cubic-bezier(.22,1,.36,1) forwards;
  animation-delay:var(--bbb-card-delay, 0s);
  will-change:transform, opacity;
  height:100%;
}

#bbb-connect-{{ sid }} .libcard:hover{ transform:translateY(-4px); }

#bbb-connect-{{ sid }} .libcard__paper{
  background:#fff;
  background-image:
    repeating-linear-gradient(
      to bottom,
      rgba(0,0,0,0.08) 0,
      rgba(0,0,0,0.08) 1px,
      transparent 1px,
      transparent 28px
    );
  border:2px solid #111;
  border-radius:12px;
  box-shadow:0 18px 38px rgba(0,0,0,.35);
  padding:28px;         /* original */
  min-height:320px;     /* original */
  height:100%;
  position:relative;
  display:flex;
  flex-direction:column;
  transition:background .25s ease, border-color .25s ease, color .25s ease, box-shadow .25s ease;
}

#bbb-connect-{{ sid }} .libcard__hole{
  width:18px; height:18px;
  border:2px solid #111;
  border-radius:50%;
  position:absolute;
  top:18px; right:18px;
  background:rgba(255,255,255,.85);
}

#bbb-connect-{{ sid }} .libcard__platform{
  font-size:2.2rem;
  font-weight:600;
  display:flex;
  gap:12px;
  align-items:center;
}

#bbb-connect-{{ sid }} .libcard__ico{ width:34px; height:34px; color:#111; }
#bbb-connect-{{ sid }} .libcard__handle{ font-size:1.8rem; opacity:.85; display:block; margin-top:6px; }

#bbb-connect-{{ sid }} .libcard__body{
  margin-top:18px;
  display:flex;
  flex-direction:column;
  gap:10px;
  flex:1 1 auto;
}
#bbb-connect-{{ sid }} .libcard__row{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  font-size:1.7rem;
  gap:12px;
}
#bbb-connect-{{ sid }} .libcard__row span:first-child{
  flex:0 0 auto;
}
#bbb-connect-{{ sid }} .libcard__row span:last-child{ text-align:right; opacity:.9; }

#bbb-connect-{{ sid }} .libcard:hover .libcard__paper{
  background:#ff8ac7 !important;
  border-color:#ff8ac7 !important;
  background-image:none !important;
  color:#111 !important;
  box-shadow:0 22px 42px rgba(0,0,0,.38) !important;
}

#bbb-connect-{{ sid }} .libcard:hover .libcard__ico,
#bbb-connect-{{ sid }} .libcard:hover .libcard__platform,
#bbb-connect-{{ sid }} .libcard:hover .libcard__handle,
#bbb-connect-{{ sid }} .libcard:hover .libcard__row{
  color:#111 !important;
}

#bbb-connect-{{ sid }} .libcard:hover .libcard__hole{
  border-color:#111 !important;
  background:rgba(255,255,255,.65) !important;
}

/* swipe hint default hidden (desktop/tablet) */
#bbb-connect-{{ sid }} .bbb-swipe-hint{ display:none; }

/* tablet: header stacks, keep grid */
@media (max-width: 980px){
  #bbb-connect-{{ sid }} .bbb-connect-cards__header{
    flex-direction:column;
    align-items:flex-start;
  }
  #bbb-connect-{{ sid }} .bbb-connect-cards__sub{ max-width:820px; }
}

/* MOBILE: swipe exactly like favorites-row */
@media (max-width: 749px){
  #bbb-connect-{{ sid }}.bbb-connect-cards{
    margin-top:-1rem;
    padding-top:1.4rem;
  }

  #bbb-connect-{{ sid }} .bbb-card-row{
    display:flex !important;
    flex-wrap:nowrap !important;
    overflow-x:auto !important;
    -webkit-overflow-scrolling:touch;
    gap:16px !important;
    padding:0 10px !important;
    scroll-snap-type:x mandatory;
  }

  /* same idea as favorite-card: fixed width so you swipe */
  #bbb-connect-{{ sid }} .libcard{
    flex:0 0 72% !important;
    scroll-snap-align:center;
  }

  #bbb-connect-{{ sid }} .libcard__paper{
    min-height:220px;
    height:220px;
    padding:18px 16px;
    border-radius:14px;
  }

  #bbb-connect-{{ sid }} .libcard__platform{
    font-size:1.7rem;
    gap:8px;
  }

  #bbb-connect-{{ sid }} .libcard__ico{
    width:24px;
    height:24px;
  }

  #bbb-connect-{{ sid }} .libcard__handle{
    font-size:1.4rem;
    margin-top:4px;
  }

  #bbb-connect-{{ sid }} .libcard__body{
    margin-top:12px;
  }

  #bbb-connect-{{ sid }} .libcard__row{
    font-size:1.35rem;
    line-height:1.45;
  }

  #bbb-connect-{{ sid }} .bbb-card-row::-webkit-scrollbar{ display:none; }
  #bbb-connect-{{ sid }} .bbb-card-row{ scrollbar-width:none; }

  /* swipe hint like your favorites */
  #bbb-connect-{{ sid }} .bbb-swipe-hint{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    margin-top:16px;
    opacity:.9;
  }

  #bbb-connect-{{ sid }} .bbb-dot{
    width:7px; height:7px;
    border-radius:50%;
    background:rgba(255,255,255,.45);
  }

  #bbb-connect-{{ sid }} .bbb-hint-text{
    font-size:1.4rem;
    letter-spacing:.02em;
  }
}

@keyframes bbbConnectSlideIn{
  to{
    opacity:1;
    transform:translateX(0);
  }
}

@keyframes bbbConnectCardIn{
  to{
    opacity:1;
    transform:translateY(0);
  }
}
</style>

{% schema %}
{
  "name": "Connect Cards",
  "settings": [
    { "type": "text", "id": "script_word", "label": "Script word", "default": "come" },
    { "type": "text", "id": "main_word", "label": "Main word", "default": "closer" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "book recs, newsletter notes, and all the reader-life chaos in the places i actually post." }
  ],
  "blocks": [
    {
      "type": "tiktok",
      "name": "TikTok card",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "platform_label", "label": "Platform label", "default": "tiktok" },
        { "type": "text", "id": "handle", "label": "Handle", "default": "@bybookishbabe" },
        { "type": "text", "id": "account", "label": "Account", "default": "daily" },
        { "type": "text", "id": "category", "label": "Category", "default": "book recs · reading vlogs · library chaos" },
        { "type": "text", "id": "status", "label": "Status", "default": "fast takes and reader spirals" },
        { "type": "text", "id": "cta", "label": "CTA", "default": "open tiktok →" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    },
    {
      "type": "substack",
      "name": "Substack card",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "platform_label", "label": "Platform label", "default": "substack" },
        { "type": "text", "id": "handle", "label": "Title/Handle", "default": "the smut & sentiment society" },
        { "type": "text", "id": "tier", "label": "Tier", "default": "free or society" },
        { "type": "text", "id": "sundays", "label": "Sundays", "default": "one curated romance recommendation" },
        { "type": "text", "id": "perks", "label": "Perks", "default": "private notes · polls · extra reader bits" },
        { "type": "text", "id": "cta", "label": "CTA", "default": "subscribe on substack →" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    },
    {
      "type": "instagram",
      "name": "Instagram card",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "platform_label", "label": "Platform label", "default": "instagram" },
        { "type": "text", "id": "handle", "label": "Handle", "default": "@bybookishbabe" },
        { "type": "text", "id": "style", "label": "Style", "default": "shelf styling · current reads · pretty proof" },
        { "type": "text", "id": "vibe", "label": "Vibe", "default": "books, mood, and newsletter-adjacent things" },
        { "type": "text", "id": "status", "label": "Status", "default": "slower reader life updates" },
        { "type": "text", "id": "cta", "label": "CTA", "default": "open instagram →" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Connect Cards",
      "blocks": [
        { "type": "tiktok" },
        { "type": "substack" },
        { "type": "instagram" }
      ]
    }
  ]
}
{% endschema %}
