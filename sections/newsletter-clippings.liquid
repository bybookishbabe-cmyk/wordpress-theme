{% comment %}
  Newsletter Clippings — Clean Newspaper Tiles
  Metaobject: newsletter_issue
  Fields:
  title, subtitle, publish_date, tropes, excerpt, url (link), label, issue_no, preview
{% endcomment %}

<section class="bbb-clippings" id="bbb-clippings-{{ section.id }}">
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="bbb-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="bbb-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% assign editions = shop.metaobjects.newsletter_issue.values %}
    {% assign now_ts = 'now' | date: '%s' | plus: 0 %}

    {% if editions != blank and editions.size > 0 %}
      {% assign editions_sorted = editions | sort: "publish_date.value" | reverse %}

      <div class="bbb-row" role="list">
        {% assign shown_count = 0 %}
        {% for ed in editions_sorted %}
          {% if shown_count >= 4 %}{% break %}{% endif %}
          {% if ed.publish_date.value == blank %}{% continue %}{% endif %}
          {% assign issue_ts = ed.publish_date.value | date: "%s" | plus: 0 %}
          {% assign live_ts = issue_ts | plus: 36000 %}
          {% if live_ts > now_ts %}{% continue %}{% endif %}
          {% assign shown_count = shown_count | plus: 1 %}

          {%- comment -%} Link field is an object; use .url if present {%- endcomment -%}
          {% assign link_url = blank %}
          {% if ed.url.value != blank %}
            {% if ed.url.value.url != blank %}
              {% assign link_url = ed.url.value.url %}
            {% else %}
              {% assign link_url = ed.url.value %}
            {% endif %}
          {% endif %}

          <article class="bbb-card bbb-card--{{ forloop.index }}" role="listitem">
            {% if link_url != blank %}
              <a href="{{ link_url | escape }}" class="bbb-link" aria-label="Read {{ ed.title.value | escape }}">
            {% endif %}

              <div class="bbb-paper">

                <div class="bbb-top">
                  <div class="bbb-mast">
                    <span class="bbb-paper-name">{{ section.settings.paper_name }}</span>
                    <span class="bbb-meta">
                      {% if ed.publish_date.value != blank %}
                        {{ ed.publish_date.value | date: "%b %e, %Y" }}
                      {% endif %}
                      {% if ed.issue_no.value != blank %}
                        · issue {{ ed.issue_no.value }}
                      {% endif %}
                    </span>
                  </div>

                  {% if ed.label.value != blank %}
                    <div class="bbb-kicker">{{ ed.label.value }}</div>
                  {% endif %}
                </div>

                <div class="bbb-rule"></div>

                <h3 class="bbb-title">{{ ed.title.value }}</h3>

                {% if ed.subtitle.value != blank %}
                  <p class="bbb-subtitle">{{ ed.subtitle.value }}</p>
                {% endif %}

                <!-- IMAGE LEFT + TROPES RIGHT -->
                <div class="bbb-split">
                  <div class="bbb-left">
                    {% if ed.preview.value != blank %}
                      <div class="bbb-imgwrap">
                        <img
                          src="{{ ed.preview.value | image_url: width: 700 }}"
                          alt="{{ ed.title.value | escape }}"
                          loading="lazy"
                          class="bbb-image"
                        >
                      </div>
                    {% else %}
                      <div class="bbb-imgwrap bbb-imgwrap--empty" aria-hidden="true"></div>
                    {% endif %}
                  </div>

                  <div class="bbb-right">
                    {% if ed.tropes.value != blank %}
                      <div class="bbb-tropes">
                        <div class="bbb-tropes-label">tropes</div>
                        <div class="bbb-tropes-text">{{ ed.tropes.value }}</div>
                      </div>
                    {% endif %}

                    <div class="bbb-footer">
                      <span class="bbb-cta">{{ section.settings.cta_text }}</span>
                      <span aria-hidden="true">→</span>
                    </div>
                  </div>
                </div>

                {% if ed.excerpt.value != blank %}
                  <p class="bbb-excerpt">{{ ed.excerpt.value }}</p>
                {% endif %}

              </div>

            {% if link_url != blank %}
              </a>
            {% endif %}
          </article>

        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

<style>
/* headings */
#bbb-clippings-{{ section.id }} .bbb-heading { margin: 0 0 4px; }
#bbb-clippings-{{ section.id }} .bbb-subheading { margin: 0 0 14px; opacity: .75; }

/* horizontal strip */
#bbb-clippings-{{ section.id }} .bbb-row{
  display:flex;
  gap: 14px;
  overflow-x:auto;
  padding: 10px 2px 18px;
  scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling: touch;
}
#bbb-clippings-{{ section.id }} .bbb-card{
  flex: 0 0 auto;
  width: 230px;              /* small but rectangular */
  scroll-snap-align:start;
}

/* subtle stagger (no rotation) */
#bbb-clippings-{{ section.id }} .bbb-card--1{ transform: translateY(6px); }
#bbb-clippings-{{ section.id }} .bbb-card--2{ transform: translateY(0px); }
#bbb-clippings-{{ section.id }} .bbb-card--3{ transform: translateY(10px); }
#bbb-clippings-{{ section.id }} .bbb-card--4{ transform: translateY(2px); }

#bbb-clippings-{{ section.id }} .bbb-link{
  text-decoration:none !important;
  color: inherit !important;
  display:block;
}

/* tile */
#bbb-clippings-{{ section.id }} .bbb-paper{
  background: #fff;
  border: 1px solid #000;
  padding: 12px;
  color:#000;
}
#bbb-clippings-{{ section.id }} .bbb-paper,
#bbb-clippings-{{ section.id }} .bbb-paper *{
  color:#000 !important;
}

/* masthead */
#bbb-clippings-{{ section.id }} .bbb-mast{
  display:flex;
  justify-content:space-between;
  gap: 10px;
  align-items:flex-end;
}
#bbb-clippings-{{ section.id }} .bbb-paper-name{
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  font-weight: 700;
}
#bbb-clippings-{{ section.id }} .bbb-meta{
  font-size: 10px;
  opacity: .8;
  white-space: nowrap;
}
#bbb-clippings-{{ section.id }} .bbb-kicker{
  margin-top: 8px;
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  opacity: .85;
}
#bbb-clippings-{{ section.id }} .bbb-rule{
  height: 1px;
  background: #000;
  margin: 10px 0;
}

/* title + copy */
#bbb-clippings-{{ section.id }} .bbb-title{
  font-size: 16px;
  line-height: 1.15;
  margin: 0 0 6px;
  font-weight: 700;
}
#bbb-clippings-{{ section.id }} .bbb-subtitle{
  margin: 0 0 10px;
  font-size: 12px;
  line-height: 1.3;
  opacity: .9;
}

/* split row */
#bbb-clippings-{{ section.id }} .bbb-split{
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  align-items:start;
}

/* image left */
#bbb-clippings-{{ section.id }} .bbb-imgwrap{
  border: 1px solid #000;
  width: 100%;
  aspect-ratio: 4 / 5;   /* keeps it rectangular */
  overflow:hidden;
  background:#fff;
}
#bbb-clippings-{{ section.id }} .bbb-image{
  width:100%;
  height:100%;
  object-fit: cover;
  display:block;
  filter: grayscale(100%);
}
#bbb-clippings-{{ section.id }} .bbb-imgwrap--empty{
  background: #fff;
}

/* tropes right */
#bbb-clippings-{{ section.id }} .bbb-tropes-label{
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  margin-bottom: 6px;
  opacity: .9;
}
#bbb-clippings-{{ section.id }} .bbb-tropes-text{
  font-size: 11px;
  line-height: 1.35;
}

/* footer (kept in right column) */
#bbb-clippings-{{ section.id }} .bbb-footer{
  display:flex;
  justify-content:flex-end;
  align-items:center;
  gap: 8px;
  margin-top: 12px;
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
}

/* excerpt under split */
#bbb-clippings-{{ section.id }} .bbb-excerpt{
  margin: 12px 0 0;
  font-size: 12px;
  line-height: 1.35;
}
</style>

{% schema %}
{
  "name": "Newsletter clippings",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "latest editions" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "from the society library" },
    { "type": "text", "id": "paper_name", "label": "Paper name", "default": "the smut & sentiment society" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "read edition" }
  ],
  "presets": [{ "name": "Newsletter clippings" }]
}
{% endschema %}
