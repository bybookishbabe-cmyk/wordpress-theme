{% assign shelf = page.metafields.custom.shelf.value %}
{% paginate shop.metaobjects.sss_library.values by 250 %}
  {% assign all_books = shop.metaobjects.sss_library.values %}
{% assign shelf_handle = shelf.system.handle | default: '' | strip %}
{% assign shelf_name = shelf.name | default: '' | strip | downcase %}

<section class="sss-lib" data-sss-lib="public">

<div class="sss-lib__wrap">

<!-- HEADER + SOCIETY CTA -->

<div class="sss-tropeTop">

<div class="sss-tropeTop__left">

<div class="sss-trope__header">

<div class="sss-trope__eyebrow">
the society shelves
</div>

<h1 class="sss-trope__title">
{{ shelf.name }} books {% if shelf.emoji %}{{ shelf.emoji }}{% endif %}
</h1>

{% if shelf.description %}
<p class="sss-trope__desc">
{{ shelf.description }}
</p>
{% endif %}

</div>

</div>


<div class="sss-tropeTop__right">

<div class="sss-tropeInvite">

<div class="sss-tropeInvite__kicker">
the private layer
</div>

<div class="sss-tropeInvite__title">
one romance recommendation.
every sunday.
</div>

<div class="sss-tropeInvite__sub">
morally gray men delivered straight to you
</div>

<a 
href="https://thesmutandsentimentsociety.substack.com/subscribe"
class="sss-tropeInvite__btn"
target="_blank"
rel="noopener"
>
join the society →
</a>

</div>

</div>

</div>

<div class="sss-trope__divider"></div>

<!-- BOOK COUNT -->

{% assign book_count = 0 %}

{% for book in all_books %}
{% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
{% assign is_visible_value = is_visible | strip %}
{% unless is_visible_value == 'true' %}
  {% continue %}
{% endunless %}

{% assign book_shelf_handle = book.shelf.value.system.handle | default: '' | strip %}
{% assign book_shelf_name = book.shelf.value.name | default: '' | strip | downcase %}

{% if book_shelf_handle == shelf_handle or book_shelf_name == shelf_name %}

{% assign book_count = book_count | plus: 1 %}

{% endif %}

{% endfor %}

<div class="sss-trope__count">
{{ book_count }} {{ shelf.name | downcase }} books in the society library
</div>

<div class="sss-lib__seriesDisclaimer">
  <span class="sss-lib__seriesBadge sss-lib__seriesBadge--demo">1</span>
  <span class="sss-lib__seriesText">
    the pink # badge means the book is part of a connected series.
  </span>
  <span class="sss-lib__seriesBadge sss-lib__seriesBadge--demo sss-lib__seriesBadge--standalone">1</span>
  <span class="sss-lib__seriesText">
    the white # badge means the book is part of a series but can be read as a standalone.
  </span>
</div>

<!-- GRID -->

<div class="sss-lib__grid sss-lib__grid--browsePage">

{% for book in all_books %}
{% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
{% assign is_visible_value = is_visible | strip %}
{% unless is_visible_value == 'true' %}
  {% continue %}
{% endunless %}

{% assign book_shelf_handle = book.shelf.value.system.handle | default: '' | strip %}
{% assign book_shelf_name = book.shelf.value.name | default: '' | strip | downcase %}

{% if book_shelf_handle == shelf_handle or book_shelf_name == shelf_name %}

{% render 'sss-book-card', book: book %}

{% endif %}

{% endfor %}

</div>


<!-- CTA -->

<div class="sss-trope__actions">

<a href="/pages/library" class="sss-trope__actionLink">
see the full romance library →
</a>

<a href="/pages/reader-quizes" class="sss-trope__actionLink">
find your fictional boyfriend →
</a>

</div>

<div class="sss-you-might-like--mobile">
{% render 'sss-you-might-like', current_shelf: shelf %}
</div>

<div class="sss-you-might-like--desktop">
{% render 'sss-you-might-like', current_shelf: shelf %}
</div>

<!-- MODAL -->

{% render 'sss-library-modal' %}
<div id="sssTropePopup" class="sss-tropePopup" hidden>

<div class="sss-tropePopup__title">
i want books by trope
</div>

<div class="sss-tropePopup__list" id="sssTropePopupList"></div>

<button class="sss-tropePopup__close" id="sssTropePopupClose">
×
</button>

</div>
</section>
{% endpaginate %}


<!-- FLOATING SHARE BUTTON -->

<div id="sssFloatingShare">

<button id="sssShareLibrary" class="sss-lib__floatingShareBtn">
📲
</button>

</div>


{{ 'sss-library.css' | asset_url | stylesheet_tag }}
{{ 'sss-you-might-like.css' | asset_url | stylesheet_tag }}

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="{{ 'sss-library.js' | asset_url }}" defer></script>

<div id="sssSaveToast" class="sss-saveToast">

<span>added to your society shelf 🖤</span>

<a 
  href="#"
  id="sssToastShelfLink"
  target="_blank"
  rel="noopener"
  class="sss-saveToast__link"
>
view your shelf →
</a>

</div>
