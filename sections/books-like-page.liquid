    }

    #books-like-{{ section.id }} .bbb-like__quizNudge span[aria-hidden]{
      color:#ff8ac7;
      font-size:24px;
      transition:transform .2s ease;
    }

    #books-like-{{ section.id }} .bbb-like__quizNudge:hover span[aria-hidden]{
      transform:translateX(4px);
    }

    @keyframes bbbLikeQuizFloat{
      0%, 100%{ transform:translateY(0); }
      50%{ transform:translateY(-4px); }
    }

    #books-like-{{ section.id }} .bbb-like__newsletter{
      margin-top:38px;
      padding:28px;
      border-radius:8px;
      border:1px solid rgba(255,255,255,.12);
