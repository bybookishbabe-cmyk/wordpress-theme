    #books-like-{{ section.id }} .bbb-like__quizCover::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(135deg, rgba(255,255,255,.22), transparent 42%, rgba(232,90,155,.2));
      pointer-events:none;
    }

    #books-like-{{ section.id }} .bbb-like__quizCover img{
      width:100%;
