      }

      #books-like-{{ section.id }} .bbb-like__share span:first-child{
        font-size:18px;
      }

      #books-like-{{ section.id }} .bbb-like__rec{
        grid-template-columns:22px 104px minmax(0, 1fr);
        gap:13px;
        padding:14px;
        align-items:start;
      }

      #books-like-{{ section.id }} .bbb-like__cover{
        width:104px;
      }

      #books-like-{{ section.id }} .bbb-like__sourceCover{
        flex-basis:86px;
        width:86px;
      }

      #books-like-{{ section.id }} .bbb-like__rank{
        font-size:12px;
      }

      #books-like-{{ section.id }} .bbb-like__rec h3{
        font-size:18px;
      }

      #books-like-{{ section.id }} .bbb-like__author,
      #books-like-{{ section.id }} .bbb-like__why{
        font-size:13px;
      }

      #books-like-{{ section.id }} .bbb-like__actions a{
        min-height:40px;
        padding:0 14px;
        font-size:12px;
      }

      #books-like-{{ section.id }} .bbb-like__newsletter form,
      #books-like-{{ section.id }} .bbb-like__moreGrid{
        grid-template-columns:1fr;
      }

      #books-like-{{ section.id }} .bbb-like__source{
        padding:18px;
      }

      #books-like-{{ section.id }} .bbb-like__unlock{
        align-items:flex-start;
        flex-direction:column;
        gap:14px;
      }

      #books-like-{{ section.id }} .bbb-like__unlock a{
        min-height:40px;
        width:100%;
      }

      #books-like-{{ section.id }} .bbb-like__quizNudge{
        grid-template-columns:60px minmax(0, 1fr) auto;
        gap:12px;
        padding:12px;
      }

      #books-like-{{ section.id }} .bbb-like__quizCover{
        width:60px;
      }

      #books-like-{{ section.id }} .bbb-like__quizNudge strong{
        font-size:16px;
      }
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", function(){
      var root = document.getElementById("books-like-{{ section.id }}");
      if(!root) return;

      var source = JSON.parse(document.getElementById("books-like-source-{{ section.id }}").textContent || "{}");
      var books = JSON.parse(document.getElementById("books-like-library-{{ section.id }}").textContent || "[]");
      var list = root.querySelector("[data-like-list]");
      var lock = root.querySelector("[data-like-lock]");
      var heading = root.querySelector("[data-match-heading]");
      var shareBtn = root.querySelector("[data-books-like-share]");
      var shareLabel = root.querySelector("[data-books-like-share-label]");
      var leadForm = root.querySelector("[data-books-like-lead-form]");

      function normalize(value){
        return String(value || "").toLowerCase().trim();
      }

      function diffScore(a, b, weight){
        a = parseInt(a, 10) || 0;
        b = parseInt(b, 10) || 0;
        if(!a || !b) return 0;
        return Math.max(0, weight - Math.abs(a - b) * 3);
      }

      function isWithinSpiceLane(book){
        var sourceSpice = parseInt(source.spice, 10) || 0;
        var bookSpice = parseInt(book && book.spice, 10) || 0;
        if(!sourceSpice || !bookSpice) return true;
        return Math.abs(sourceSpice - bookSpice) <= 1;
      }

      function tropeKeys(book){
        return (book.tropes || []).map(function(trope){
          return normalize(trope.handle || trope.name);
        }).filter(Boolean);
      }

      function sharedTropes(book){
        var sourceKeys = tropeKeys(source);
        return (book.tropes || []).filter(function(trope){
          return sourceKeys.indexOf(normalize(trope.handle || trope.name)) !== -1;
        });
      }

      function scoreBook(book, index){
        var score = 0;
        var shared = sharedTropes(book).length;
        if(normalize(book.shelf) && normalize(book.shelf) === normalize(source.shelf)) score += 36;
        if(normalize(book.boyfriend) && normalize(book.boyfriend) === normalize(source.boyfriend)) score += 24;
        score += shared * 14;
        score += diffScore(book.spice, source.spice, 18);
        score += diffScore(book.darkness, source.darkness, 12);
        score += diffScore(book.tension, source.tension, 12);
        score += diffScore(book.damage, source.damage, 12);
        if(normalize(book.yearning) && normalize(book.yearning) === normalize(source.yearning)) score += 8;
        if(book.ku && source.ku) score += 3;
        return score + Math.max(0, 2 - index / 1000);
      }

      function escapeHtml(value){
        return String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function dataAttr(name, value){
        return ' data-' + name + '="' + escapeHtml(value) + '"';
      }

      function getBooksLikeSupabaseClient(){
        if(window.bbbBooksLikeSupabaseClient) return window.bbbBooksLikeSupabaseClient;
        if(!window.supabase || !window.supabase.createClient) return null;
        window.bbbBooksLikeSupabaseClient = window.supabase.createClient(
          "https://efmrfxsmgbeikfgtrxjv.supabase.co",
          "sb_publishable_iwjASe3QwixdDvHovaXZBQ_gbXU0Utk"
        );
        return window.bbbBooksLikeSupabaseClient;
      }

      function getLeadSessionId(){
        try {
          return localStorage.getItem("sssAnalyticsSessionId") || "";
        } catch(err) {
          return "";
        }
      }

      async function captureNewsletterLead(form){
        var emailInput = form.querySelector('input[name="contact[email]"]');
        var email = emailInput ? emailInput.value.trim() : "";
        if(!email) return;

        var client = getBooksLikeSupabaseClient();
        if(!client) return;

        var normalized = email.toLowerCase();
        await client
          .from("newsletter_leads")
          .upsert([
            {
              email: email,
              email_normalized: normalized,
              source: "books_like_page",
              page_path: window.location.pathname,
              page_title: document.title,
              source_book_handle: source.handle || "",
              source_book_title: source.title || "",
              session_id: getLeadSessionId(),
              substack_sync_status: "pending",
              metadata: {
                capture_location: "books_like_newsletter",
                referrer: document.referrer || "",
                url: window.location.href
              }
            }
          ], {
            onConflict: "email_normalized,source"
          });
      }

      function hasSocietyAccess(){
        try {
          if(localStorage.getItem("bbbSocietyUnlocked") === "true") return true;
          if(localStorage.getItem("sssSocietyUnlocked") === "true") return true;
          if(localStorage.getItem("societyUnlocked") === "true") return true;
          for(var i = 0; i < localStorage.length; i++){
            var key = localStorage.key(i);
            if(key && key.indexOf("sss-access-") === 0 && localStorage.getItem(key) === "true") return true;
          }
        } catch(err){}
        return false;
      }

      if(shareBtn){
        shareBtn.addEventListener("click", function(){
          var originalLabel = shareLabel ? shareLabel.textContent : "share";
          var shareUrl = window.location.href.split("#")[0];
          var shareTitle = document.title || ("books like " + (source.title || ""));
          var shareText = source.title
            ? "books with the same energy as " + source.title
            : "a romance reading guide you need";

          if(navigator.share){
            navigator.share({
              title: shareTitle,
              text: shareText,
              url: shareUrl
            }).catch(function(){});
            return;
          }

          if(navigator.clipboard && navigator.clipboard.writeText){
            navigator.clipboard.writeText(shareUrl).then(function(){
              if(shareLabel) shareLabel.textContent = "copied";
              shareBtn.setAttribute("aria-label", "link copied");
              window.setTimeout(function(){
                if(shareLabel) shareLabel.textContent = originalLabel;
                shareBtn.setAttribute("aria-label", "share this reading guide");
              }, 1600);
            }).catch(function(){});
          }
        });
      }

      if(leadForm){
        leadForm.addEventListener("submit", function(event){
          if(leadForm.dataset.nativeSubmit === "true") return;
          event.preventDefault();

          var submitBtn = leadForm.querySelector('button[type="submit"]');
          var originalText = submitBtn ? submitBtn.textContent : "";
          if(submitBtn){
            submitBtn.disabled = true;
            submitBtn.textContent = "joining...";
          }

          captureNewsletterLead(leadForm).catch(function(err){
            console.log("Newsletter lead capture failed", err);
          }).finally(function(){
            leadForm.dataset.nativeSubmit = "true";
            if(submitBtn){
              submitBtn.disabled = false;
              submitBtn.textContent = originalText || "join";
            }
            leadForm.submit();
          });
        });
      }

      function recWhy(book){
        if(book.mini) return book.mini;
        if(book.why) return book.why;
        var shared = sharedTropes(book).map(function(trope){ return trope.name; }).slice(0, 2).join(" and ");
        if(shared) return "same " + shared + " nerve, with enough familiar damage to feel dangerous.";
        if(normalize(book.shelf) === normalize(source.shelf)) return "same shelf, same emotional weather, different spiral.";
        return "a nearby obsession with enough overlap to keep the mood going.";
      }

      function tagHtml(book){
        var tags = sharedTropes(book).slice(0, 3);
        if(tags.length < 3 && book.shelf) tags.unshift({ name: book.shelf });
        return tags.slice(0, 3).map(function(tag, index){
          return '<span class="bbb-like__tag' + (index >= 2 ? " is-tag-locked" : "") + '">' + escapeHtml(tag.name || tag) + '</span>';
        }).join("");
      }

      function spiceHtml(book){
        var spice = parseInt(book.spice, 10) || 0;
        if(!spice) return "";
        return '<div class="sss-lib__floatSpice bbb-like__floatSpice" aria-label="' + spice + ' spice">' + "🌶".repeat(spice) + '</div>';
      }

      function darknessHtml(book){
        var darkness = parseInt(book.darkness, 10) || 0;
        if(!darkness) return "";
        return [
          '<div class="bbb-like__darkness" aria-label="' + darkness + ' darkness level">',
            '<span>darkness</span>',
            '<i aria-hidden="true">' + "💀".repeat(darkness) + '</i>',
            '<em>' + darkness + '/5</em>',
          '</div>'
        ].join("");
      }

      function cardHtml(book, index){
        var locked = index >= 2;
        var rank = String(index + 1).padStart(2, "0");
        var tropesText = (book.tropes || []).map(function(trope){ return trope.name; }).filter(Boolean).join(", ");
        var tropesDisplay = (book.tropes || []).map(function(trope){
          return (trope.emoji ? trope.emoji + " " : "") + trope.name;
        }).filter(Boolean).join(", ");
        var attrs = [
          dataAttr("handle", book.handle),
          dataAttr("title", book.title),
          dataAttr("author", book.author),
          dataAttr("cover", book.cover),
          dataAttr("amazon", book.amazon),
          dataAttr("bookshop", book.bookshop),
          dataAttr("newsletter", book.newsletter),
          dataAttr("shelf", book.shelf),
          dataAttr("private-shelf", book.privateShelf || "false"),
          dataAttr("spice", book.spice),
          dataAttr("tropes", tropesText),
          dataAttr("tropes-display", tropesDisplay),
          dataAttr("why", book.why),
          dataAttr("mini", book.mini),
          dataAttr("tension", book.tension),
          dataAttr("damage", book.damage),
          dataAttr("yearning", book.yearning),
          dataAttr("boyfriend", book.boyfriend),
          dataAttr("reread", book.reread),
          dataAttr("ku", book.ku),
          dataAttr("series", book.series),
          dataAttr("series-name", book.seriesName),
          dataAttr("series-number", book.seriesNumber),
          dataAttr("standalone", book.standalone ? "true" : "false")
        ].join("");
        var amazon = book.amazon ? '<a href="' + escapeHtml(book.amazon) + '" target="_blank" rel="noopener sponsored" onclick="event.stopPropagation()">get on amazon</a>' : "";
        var ku = book.ku ? '<a href="' + escapeHtml(book.amazon || book.bookshop || "#") + '" target="_blank" rel="noopener sponsored" onclick="event.stopPropagation()">on kindle unlimited</a>' : "";
        var shop = !ku && book.bookshop ? '<a href="' + escapeHtml(book.bookshop) + '" target="_blank" rel="noopener sponsored" onclick="event.stopPropagation()">support local bookshop</a>' : "";
        return [
          '<article class="bbb-like__rec sss-lib__book' + (locked ? " is-locked" : "") + '" role="button" tabindex="0"' + attrs + '>',
            '<div class="bbb-like__rank">' + rank + '</div>',
            '<div class="bbb-like__cover sss-lib__coverWrap">',
              '<span class="sss-lib__heart bbb-like__heart" data-heart role="button" aria-label="save to your bookshelf" onclick="event.stopPropagation()">',
                '<span class="sss-lib__heartIcon" data-heart-icon aria-hidden="true">♡</span>',
                '<span class="sss-lib__heartLabel" data-heart-label>save</span>',
              '</span>',
              spiceHtml(book),
              (book.cover ? '<img class="sss-lib__cover" src="' + escapeHtml(book.cover) + '" alt="' + escapeHtml(book.title) + '" loading="lazy">' : ""),
            '</div>',
            '<div>',
              '<h3>' + escapeHtml(book.title) + '</h3>',
              '<p class="bbb-like__author">' + escapeHtml(book.author) + '</p>',
              '<div class="bbb-like__tags">' + tagHtml(book) + '</div>',
              darknessHtml(book),
              '<p class="bbb-like__whyKicker">why you’ll love it</p>',
              '<p class="bbb-like__why">' + escapeHtml(recWhy(book)) + '</p>',
              '<div class="bbb-like__actions">' + amazon + ku + shop + '</div>',
            '</div>',
          '</article>'
        ].join("");
      }

      var ranked = books.filter(function(book){
        return book &&
          book.title &&
          normalize(book.handle) !== normalize(source.handle) &&
          normalize(book.title) !== normalize(source.title) &&
          isWithinSpiceLane(book);
      }).map(function(book, index){
        return { book: book, score: scoreBook(book, index), index: index };
      }).sort(function(a, b){
        if(b.score !== a.score) return b.score - a.score;
        return a.index - b.index;
      }).slice(0, 7).map(function(item){ return item.book; });

      if(heading) heading.textContent = ranked.length + " books that hit the same nerve";
      if(list) list.innerHTML = ranked.map(cardHtml).join("");

      root.addEventListener("keydown", function(event){
        var card = event.target.closest(".bbb-like__rec[data-title], .bbb-like__source[data-title]");
        if(!card) return;
        if(event.target.closest("[data-heart]")) return;
        if(event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        card.click();
      });

      if(hasSocietyAccess()){
        root.classList.add("is-unlocked");
        if(lock) lock.hidden = true;
      }

    });
  </script>
{% endif %}

{% schema %}
{
