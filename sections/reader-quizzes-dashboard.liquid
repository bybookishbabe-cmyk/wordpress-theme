{% assign quiz_dash_books = shop.metaobjects.sss_library.values %}

<section class="bbb-quizdash" id="reader-quizzes">
  <div class="bbb-quizdash__wrap">
    <header class="bbb-quizdash__hero">
      <p class="bbb-quizdash__kicker">{{ section.settings.kicker }}</p>
      <h1 class="bbb-quizdash__title">{{ section.settings.title }}</h1>
      {% if section.settings.subtext != blank %}
        <p class="bbb-quizdash__sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </header>

    <div class="bbb-quizdash__grid" aria-label="reader quiz selection">
      <a class="bbb-quizdash__card bbb-quizdash__card--feature" href="/pages/fictional-boyfriend-quiz">
        <span class="bbb-quizdash__emojiRain" aria-hidden="true">
          <span>🖤</span><span>🖤</span><span>🖤</span><span>🖤</span><span>🖤</span>
        </span>
        <span class="bbb-quizdash__badge">most popular</span>
        <span class="bbb-quizdash__covers" aria-hidden="true">
          {% assign quiz_cover_count = 0 %}
          {% for book in quiz_dash_books %}
            {% if quiz_cover_count >= 3 %}
              {% break %}
            {% endif %}
            {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
            {% assign is_visible_value = is_visible | strip %}
            {% unless is_visible_value == 'true' %}
              {% continue %}
            {% endunless %}
            {% capture is_private %}{% render 'sss-book-private', book: book %}{% endcapture %}
            {% assign is_private_value = is_private | strip %}
            {% if is_private_value == 'true' or book.cover.value == blank %}
              {% continue %}
            {% endif %}
            {% if book.cover.value.url != blank %}
              {% assign quiz_cover_url = book.cover.value.url %}
            {% else %}
              {% assign quiz_cover_url = book.cover.value %}
            {% endif %}
            <img src="{{ quiz_cover_url | escape }}" alt="" loading="lazy">
            {% assign quiz_cover_count = quiz_cover_count | plus: 1 %}
          {% endfor %}
        </span>
        <span class="bbb-quizdash__issue">quiz 01</span>
        <h2>who is your fictional boyfriend?</h2>
        <p>for the reader who has a type and deserves to be lovingly exposed by it.</p>
        <span class="bbb-quizdash__cta">meet him →</span>
      </a>

      <a class="bbb-quizdash__card bbb-quizdash__card--pink" href="/pages/reader-mood-quiz">
        <span class="bbb-quizdash__emojiRain" aria-hidden="true">
          <span>💌</span><span>🌶</span><span>🖤</span><span>✨</span><span>🔥</span>
        </span>
        <span class="bbb-quizdash__badge">new</span>
        <span class="bbb-quizdash__covers bbb-quizdash__covers--right" aria-hidden="true">
          {% assign quiz_cover_count = 0 %}
          {% for book in quiz_dash_books offset: 3 %}
            {% if quiz_cover_count >= 3 %}
              {% break %}
            {% endif %}
            {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
            {% assign is_visible_value = is_visible | strip %}
            {% unless is_visible_value == 'true' %}
              {% continue %}
            {% endunless %}
            {% capture is_private %}{% render 'sss-book-private', book: book %}{% endcapture %}
            {% assign is_private_value = is_private | strip %}
            {% if is_private_value == 'true' or book.cover.value == blank %}
              {% continue %}
            {% endif %}
            {% if book.cover.value.url != blank %}
              {% assign quiz_cover_url = book.cover.value.url %}
            {% else %}
              {% assign quiz_cover_url = book.cover.value %}
            {% endif %}
            <img src="{{ quiz_cover_url | escape }}" alt="" loading="lazy">
            {% assign quiz_cover_count = quiz_cover_count | plus: 1 %}
          {% endfor %}
        </span>
        <span class="bbb-quizdash__issue">quiz 02</span>
        <h2>what should you read based on your mood?</h2>
        <p>tell me what emotional state dragged you in here and i’ll hand you a romance era.</p>
        <span class="bbb-quizdash__cta">take the mood quiz →</span>
      </a>

      <article class="bbb-quizdash__card bbb-quizdash__card--locked">
        <span class="bbb-quizdash__emojiRain" aria-hidden="true">
          <span>💘</span><span>📖</span><span>🎭</span><span>💌</span><span>✨</span>
        </span>
        <span class="bbb-quizdash__issue">coming next</span>
        <h2>what romance trope are you secretly living?</h2>
        <p>for when your life starts acting a little too much like a third-act conflict.</p>
        <span class="bbb-quizdash__cta">coming soon</span>
      </article>

      <article class="bbb-quizdash__card bbb-quizdash__card--locked">
        <span class="bbb-quizdash__emojiRain" aria-hidden="true">
          <span>🌶</span><span>🔥</span><span>💋</span><span>🌶</span><span>🔥</span>
        </span>
        <span class="bbb-quizdash__issue">coming next</span>
        <h2>what spice level is your current era?</h2>
        <p>a deeply unserious diagnosis for the state of your kindle, your standards, and your sleep schedule.</p>
        <span class="bbb-quizdash__cta">coming soon</span>
      </article>
    </div>
  </div>
</section>

<style>
  #reader-quizzes.bbb-quizdash{
    padding:72px 18px 38px;
    background:#0b0b0b;
    color:#f6f6f6;
    overflow:hidden;
  }

  .bbb-quizdash__wrap{
    max-width:1120px;
    margin:0 auto;
  }

  .bbb-quizdash__hero{
    max-width:760px;
    margin:0 0 28px;
  }

  .bbb-quizdash__kicker,
  .bbb-quizdash__issue{
    position:relative;
    z-index:2;
    margin:0;
    color:#ff8ac7;
    font-size:.72rem;
    letter-spacing:.18em;
    text-transform:uppercase;
  }

  .bbb-quizdash__title{
    margin:10px 0 0;
    font-size:clamp(2.8rem, 7vw, 6.2rem);
    line-height:.9;
    font-weight:400;
    text-transform:lowercase;
  }

  .bbb-quizdash__sub{
    max-width:44rem;
    margin:18px 0 0;
    color:rgba(246,246,246,.72);
    font-size:1.05rem;
    line-height:1.7;
  }

  .bbb-quizdash__grid{
    display:grid;
    grid-template-columns:repeat(4, minmax(0, 1fr));
    gap:16px;
    align-items:stretch;
  }

  .bbb-quizdash__card{
    position:relative;
    display:flex;
    min-height:390px;
    flex-direction:column;
    justify-content:flex-end;
    padding:18px;
    border-radius:8px;
    border:1px solid rgba(255,255,255,.12);
    background:
      radial-gradient(circle at 18% 12%, rgba(255,138,199,.14), transparent 36%),
      linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.018));
    color:inherit;
    text-decoration:none;
    overflow:hidden;
    transition:transform .18s ease, border-color .18s ease, background .18s ease;
  }

  .bbb-quizdash__card--feature{
    min-height:390px;
  }

  .bbb-quizdash__card--pink{
    background:
      radial-gradient(circle at 82% 18%, rgba(255,138,199,.28), transparent 38%),
      linear-gradient(135deg, rgba(255,138,199,.14), rgba(255,255,255,.025));
  }

  .bbb-quizdash__card--locked{
    opacity:.74;
  }

  .bbb-quizdash__card:hover{
    transform:translateY(-3px);
    border-color:rgba(255,138,199,.42);
  }

  .bbb-quizdash__badge{
    position:absolute;
    top:18px;
    right:18px;
    z-index:3;
    padding:8px 12px;
    border-radius:999px;
    background:#ff8ac7;
    color:#0b0b0b;
    font-size:.68rem;
    font-weight:800;
    letter-spacing:.12em;
    text-transform:uppercase;
  }

  .bbb-quizdash__emojiRain{
    position:absolute;
    inset:0;
    z-index:0;
    pointer-events:none;
    overflow:hidden;
    opacity:.88;
  }

  .bbb-quizdash__emojiRain span{
    position:absolute;
    top:-22px;
    left:var(--x, 50%);
    font-size:var(--size, 18px);
    filter:drop-shadow(0 8px 14px rgba(0,0,0,.45));
    animation:bbbQuizDashEmojiDrop var(--dur, 7600ms) linear infinite;
    animation-delay:var(--delay, 0ms);
  }

  .bbb-quizdash__emojiRain span:nth-child(1){ --x:14%; --size:20px; --dur:7200ms; --delay:-800ms; }
  .bbb-quizdash__emojiRain span:nth-child(2){ --x:34%; --size:15px; --dur:8600ms; --delay:-3300ms; }
  .bbb-quizdash__emojiRain span:nth-child(3){ --x:58%; --size:18px; --dur:7900ms; --delay:-1900ms; }
  .bbb-quizdash__emojiRain span:nth-child(4){ --x:76%; --size:16px; --dur:9300ms; --delay:-5200ms; }
  .bbb-quizdash__emojiRain span:nth-child(5){ --x:88%; --size:21px; --dur:8200ms; --delay:-4300ms; }

  @keyframes bbbQuizDashEmojiDrop{
    0%{ transform:translate3d(0,-20px,0) rotate(0deg); opacity:0; }
    12%{ opacity:.9; }
    80%{ opacity:.9; }
    to{ transform:translate3d(14px,430px,0) rotate(220deg); opacity:0; }
  }

  .bbb-quizdash__covers{
    position:absolute;
    top:28px;
    left:18px;
    display:flex;
    align-items:flex-end;
    min-height:142px;
    opacity:.86;
    pointer-events:none;
    z-index:1;
  }

  .bbb-quizdash__covers--right{
    top:28px;
    left:auto;
    right:18px;
    transform:scale(1);
    transform-origin:top right;
  }

  .bbb-quizdash__covers img{
    width:58px;
    aspect-ratio:2/3;
    object-fit:cover;
    border-radius:8px;
    border:1px solid rgba(255,255,255,.18);
    box-shadow:0 18px 34px rgba(0,0,0,.36);
    transform:rotate(-7deg);
  }

  .bbb-quizdash__covers img + img{
    margin-left:-22px;
  }

  .bbb-quizdash__covers img:nth-child(2){
    transform:translateY(-10px) rotate(3deg);
  }

  .bbb-quizdash__covers img:nth-child(3){
    transform:rotate(9deg);
  }

  .bbb-quizdash__card h2{
    position:relative;
    z-index:2;
    max-width:14ch;
    margin:12px 0 0;
    font-size:clamp(1.55rem, 2.7vw, 2.35rem);
    line-height:.96;
    font-weight:400;
    text-transform:lowercase;
  }

  .bbb-quizdash__card p{
    position:relative;
    z-index:2;
    max-width:34rem;
    margin:14px 0 0;
    color:rgba(246,246,246,.73);
    line-height:1.55;
    font-size:.96rem;
  }

  .bbb-quizdash__cta{
    position:relative;
    z-index:2;
    width:max-content;
    margin-top:22px;
    padding:10px 14px;
    border-radius:999px;
    border:1px solid rgba(255,138,199,.45);
    color:#ff8ac7;
    font-size:.78rem;
    font-weight:800;
    letter-spacing:.12em;
    text-transform:uppercase;
  }

  @media(max-width:840px){
    #reader-quizzes.bbb-quizdash{
      padding-top:44px;
    }

    .bbb-quizdash__grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:12px;
    }

    .bbb-quizdash__card,
    .bbb-quizdash__card--feature{
      min-height:300px;
      padding:14px;
    }

    .bbb-quizdash__covers{
      top:18px;
      left:14px;
      min-height:96px;
      transform:scale(.86);
      transform-origin:top left;
    }

    .bbb-quizdash__covers--right{
      right:12px;
      transform:scale(.78);
      transform-origin:top right;
    }

    .bbb-quizdash__covers img{
      width:46px;
    }

    .bbb-quizdash__covers img + img{
      margin-left:-20px;
    }

    .bbb-quizdash__badge{
      top:12px;
      right:12px;
      padding:6px 8px;
      font-size:.58rem;
    }

    .bbb-quizdash__card h2{
      font-size:clamp(1.25rem, 5vw, 1.8rem);
      line-height:1;
    }

    .bbb-quizdash__card p{
      font-size:.82rem;
      line-height:1.45;
    }

    .bbb-quizdash__cta{
      padding:8px 10px;
      font-size:.62rem;
      letter-spacing:.08em;
    }
  }

  @media(max-width:420px){
    .bbb-quizdash__grid{
      gap:10px;
    }

    .bbb-quizdash__card,
    .bbb-quizdash__card--feature{
      min-height:280px;
      padding:12px;
    }

    .bbb-quizdash__covers{
      transform:scale(.76);
    }

    .bbb-quizdash__covers--right{
      transform:scale(.7);
    }
  }
</style>

{% schema %}
{
  "name": "Reader quizzes dashboard",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "reader quizzes"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "choose your next little diagnosis"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "romance quizzes for your mood, your type, and the fictional problem currently ruining your standards."
    }
  ],
  "presets": [
    {
      "name": "Reader quizzes dashboard"
    }
  ]
}
{% endschema %}
