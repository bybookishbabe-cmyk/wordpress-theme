<section class="bbb-review-banner color-{{ section.settings.color_scheme }} gradient">
  <div class="bbb-review-banner__inner page-width">
    <a
      href="{{ section.settings.link }}"
      class="bbb-review-banner__link"
      target="_blank"
      rel="noopener"
      aria-label="{{ section.settings.aria_label | escape }}"
    >
      <span class="bbb-review-banner__text">{{ section.settings.text }}</span>
    </a>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .bbb-review-banner {
    background: #000;
    border-top: 1px solid rgba(247, 243, 238, 0.15);
    border-bottom: 1px solid rgba(247, 243, 238, 0.15);
  }

  #shopify-section-{{ section.id }} .bbb-review-banner__inner {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .bbb-review-banner__link {
    display: inline-block;
    color: #f7f3ee;
    text-decoration: none;
    font-family: 'Cormorant', serif;
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    font-weight: 600;
    letter-spacing: 0.04rem;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  #shopify-section-{{ section.id }} .bbb-review-banner__link:hover {
    color: #fff;
    transform: translateY(-0.2rem);
  }

  #shopify-section-{{ section.id }} .bbb-review-banner__text {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bbb-review-banner__inner {
      padding-top: 28px;
      padding-bottom: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "bbb review banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "★★★★★ loved by readers — see what they’re saying →"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Aria label",
      "default": "Read reviews of By Bookish Babe"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "bbb review banner"
    }
  ]
}
{% endschema %}
