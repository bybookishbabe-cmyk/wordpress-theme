{% comment %}
  sss-for-readers.liquid
  Pinterest-coded reader hub
{% endcomment %}

<section class="sss-readers" id="sss-readers-{{ section.id }}">
  <div class="sss-emoji-rain" aria-hidden="true"></div>
  <div class="sss-readers__wrap">

    <!-- Header -->
    <header class="sss-readers__head">
      <p class="sss-readers__kicker">{{ section.settings.kicker }}</p>
      <h1 class="sss-readers__title">{{ section.settings.title }}</h1>
      {% if section.settings.subtext != blank %}
        <p class="sss-readers__sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </header>

    <!-- Cards -->
    <div class="sss-readers__grid">

      <!-- Reading List -->
      <a href="{{ section.settings.reading_list_url }}" class="sss-readers__card">
        <div class="sss-readers__card-inner">
          <p class="sss-readers__card-kicker">for your tbr</p>
          <h3 class="sss-readers__card-title">the reading list</h3>
          <p class="sss-readers__card-text">
            books i’ve been thinking about lately — sentimental favorites, dark recs, and stories that stayed with me.
          </p>
          <span class="sss-readers__card-link">browse the list →</span>
        </div>
      </a>

      <!-- Quiz -->
      <a href="{{ section.settings.quiz_url }}" class="sss-readers__card sss-readers__card--pink">
        <div class="sss-readers__card-inner">
          <p class="sss-readers__card-kicker">reader behavior</p>
          <h3 class="sss-readers__card-title">fictional boyfriend test</h3>
          <p class="sss-readers__card-text">
            answer five questions. i’ll tell you which fictional man is your downfall — and what you should read next.
          </p>
          <span class="sss-readers__card-link">take the quiz →</span>
        </div>
      </a>

    </div>

  </div>
</section>

<style>
.sss-readers{
  background:#0b0b0b;
  color:#f6f6f6;
  padding:96px 16px;
  font-family:"Libre Baskerville", Georgia, serif;
}
.sss-readers__wrap{
  max-width:960px;
  margin:0 auto;
}

/* header */
.sss-readers__kicker{
  font-size:11px;
  letter-spacing:.14em;
  text-transform:uppercase;
  opacity:.6;
}
.sss-readers__title{
  margin-top:10px;
  font-size:34px;
  font-weight:400;
  text-transform:lowercase;
}
.sss-readers__sub{
  margin-top:12px;
  font-size:14px;
  color:rgba(246,246,246,.7);
  max-width:56ch;
}

/* grid */
.sss-readers__grid{
  margin-top:48px;
  display:grid;
  grid-template-columns:repeat(2, 1fr);
  gap:28px;
}

/* cards */
.sss-readers__card{
  text-decoration:none;
  color:inherit;
  border:1px solid rgba(255,255,255,.12);
  border-radius:22px;
  background:rgba(255,255,255,.03);
  transition:transform .25s ease, border-color .25s ease;
}
.sss-readers__card:hover{
  transform:translateY(-4px);
  border-color:rgba(255,255,255,.22);
}
.sss-readers__card--pink{
  background:linear-gradient(
    160deg,
    rgba(255,138,199,.18),
    rgba(255,138,199,.04)
  );
  border-color:rgba(255,138,199,.45);
}

.sss-readers__card-inner{
  padding:34px;
}

.sss-readers__card-kicker{
  font-size:10px;
  letter-spacing:.14em;
  text-transform:uppercase;
  opacity:.6;
}
.sss-readers__card-title{
  margin:10px 0 0;
  font-size:22px;
  font-weight:400;
  text-transform:lowercase;
}
.sss-readers__card-text{
  margin-top:10px;
  font-size:14px;
  line-height:1.6;
  color:rgba(246,246,246,.75);
}
.sss-readers__card-link{
  display:inline-block;
  margin-top:18px;
  font-size:12px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:#ff8ac7;
}
.sss-emoji-rain{
  position:absolute;
  inset:0;
  pointer-events:none;
  overflow:hidden;
  z-index:0;
}

.sss-emoji{
  position:absolute;
  top:-40px;
  font-size:var(--size, 20px);
  opacity:.75;
  animation: sss-fall var(--dur, 12s) linear forwards;
  filter: drop-shadow(0 6px 14px rgba(0,0,0,.25));
}

@keyframes sss-fall{
  to{
    transform:
      translateY(var(--drop, 120vh))
      translateX(var(--drift, 0px))
      rotate(var(--rot, 0deg));
    opacity:0;
  }
}


/* mobile */
@media(max-width:720px){
  .sss-readers__grid{
    grid-template-columns:1fr;
  }
}
</style>

{% schema %}
{
  "name": "sss for readers",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "for readers"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "if you’re here, you probably love fictional men a little too much"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "book recs, quizzes, and soft chaos for the romantically inclined."
    },
    {
  "type": "text",
  "id": "reading_list_url",
  "label": "Reading list page URL",
  "default": "/pages/reading-list"
},
{
  "type": "text",
  "id": "quiz_url",
  "label": "Fictional boyfriend quiz URL",
  "default": "/pages/reader-quizes"
}
  ],
  "presets": [
    { "name": "sss for readers" }
  ]
}
{% endschema %}
