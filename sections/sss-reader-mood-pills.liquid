{% comment %}
  sss-reader-mood-pills.liquid
  - Clickable pills
  - Reveals a line on click
  - Emoji "fall" animation for 2 seconds
{% endcomment %}

<section class="sss-mood" id="sss-mood-{{ section.id }}">
  <div class="sss-mood__wrap">
    {% if section.settings.title != blank %}
      <h2 class="sss-mood__title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.sub != blank %}
      <p class="sss-mood__sub">{{ section.settings.sub }}</p>
    {% endif %}

    <div class="sss-mood__pills" role="group" aria-label="choose your reader mood">
      {% for block in section.blocks %}
        {% if block.type == "mood" %}
          <button
            class="sss-pill"
            type="button"
            data-line="{{ block.settings.line | escape }}"
            data-emoji="{{ block.settings.emoji }}"
            data-label="{{ block.settings.label | escape }}"
            {{ block.shopify_attributes }}
          >
            <span class="sss-pill__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
            <span class="sss-pill__label">{{ block.settings.label }}</span>
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="sss-mood__reveal" aria-live="polite" aria-atomic="true" hidden>
      <div class="sss-mood__revealInner">
        <span class="sss-mood__revealPill" data-reveal-pill></span>
        <p class="sss-mood__revealLine" data-reveal-line></p>
      </div>
    </div>
  </div>

  <!-- emoji rain layer -->
  <div class="sss-emoji-layer" data-emoji-layer aria-hidden="true"></div>
</section>

<style>
  #sss-mood-{{ section.id }}{
    --ink: rgb(var(--color-foreground));
    --bg: rgb(var(--color-background));
    --muted: rgba(var(--color-foreground), .78);
    --border: rgba(var(--color-foreground), .22);

    /* tweakable */
    --pill-bg: {{ section.settings.pill_bg }};
    --pill-ink: {{ section.settings.pill_ink }};
  }

  .sss-mood{
    position: relative;
    overflow: hidden;
    background: var(--bg);
    padding: 18px 12px;
  }

  .sss-mood__wrap{
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    padding: 0 10px;
    text-align: center;
  }

  .sss-mood__title{
    margin: 0;
    font-family: var(--font-heading-family);
    font-weight: 800;
    text-transform: lowercase;
    font-size: 18px;
    color: var(--ink);
  }

  .sss-mood__sub{
    margin: 8px auto 0;
    max-width: 780px;
    font-family: var(--font-body-family);
    text-transform: lowercase;
    font-size: 13px;
    line-height: 1.6;
    color: var(--muted);
  }

  .sss-mood__pills{
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .sss-pill{
    border: 1px solid var(--border);
    background: rgba(var(--color-foreground), .06);
    color: var(--ink);
    border-radius: 999px;
    padding: 10px 14px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body-family);
    text-transform: lowercase;
    font-size: 13px;
    line-height: 1;
    transition: transform .12s ease, background .12s ease, border-color .12s ease;
  }

  .sss-pill:hover{
    transform: translateY(-1px);
    background: rgba(var(--color-foreground), .09);
    border-color: rgba(var(--color-foreground), .32);
  }

  .sss-pill:focus-visible{
    outline: 2px solid rgba(var(--color-foreground), .35);
    outline-offset: 3px;
  }

  .sss-pill.is-active{
    background: var(--pill-bg);
    color: var(--pill-ink);
    border-color: var(--pill-bg);
  }

  .sss-pill.is-active .sss-pill__label,
  .sss-pill.is-active .sss-pill__emoji{
    color: var(--pill-ink);
  }

  .sss-pill__emoji{
    font-size: 14px;
  }

  .sss-pill__label{
    font-weight: 700;
  }

  /* reveal line */
  .sss-mood__reveal{
    margin: 12px auto 0;
    max-width: 860px;
  }
  .sss-mood__revealInner{
    display: inline-flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    justify-content: center;
    padding: 10px 12px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: rgba(var(--color-foreground), .05);
  }
  .sss-mood__revealPill{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--pill-bg);
    color: var(--pill-ink);
    border: 1px solid var(--pill-bg);
    font-family: var(--font-body-family);
    text-transform: lowercase;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
  }
  .sss-mood__revealLine{
    margin: 0;
    font-family: var(--font-body-family);
    text-transform: lowercase;
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink);
  }

  /* emoji rain layer */
  .sss-emoji-layer{
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .sss-emoji{
    position: absolute;
    top: -40px;
    font-size: var(--size, 20px);
    opacity: 0;
    transform: translateY(-10px);
    animation: sss-fall var(--dur, 1400ms) ease-in forwards;
    filter: drop-shadow(0 8px 14px rgba(0,0,0,.15));
    will-change: transform, opacity;
  }

  @keyframes sss-fall{
    0%   { opacity: 0; transform: translateY(-30px) rotate(0deg); }
    10%  { opacity: 1; }
    100% { opacity: 0; transform: translateY(var(--drop, 420px)) rotate(var(--rot, 220deg)); }
  }
</style>

<script>
(function(){
  var root = document.getElementById('sss-mood-{{ section.id }}');
  if (!root) return;

  var pills = Array.prototype.slice.call(root.querySelectorAll('.sss-pill'));
  var revealWrap = root.querySelector('.sss-mood__reveal');
  var revealPill = root.querySelector('[data-reveal-pill]');
  var revealLine = root.querySelector('[data-reveal-line]');
  var layer = root.querySelector('[data-emoji-layer]');

  var RUN_MS = 7000; // emojis fall for 7 seconds
  var MAX_EMOJIS = 50; // total spawned per click (keeps it light)
  var intervalId = null;
  var timeoutId = null;

  function clearRain(){
    if (intervalId) clearInterval(intervalId);
    if (timeoutId) clearTimeout(timeoutId);
    intervalId = null;
    timeoutId = null;
    if (layer) layer.innerHTML = '';
  }

  function spawnEmoji(char){
    if (!layer) return;
    var el = document.createElement('span');
    el.className = 'sss-emoji';
    el.textContent = char;

    var left = Math.random() * 100; // %
    var size = 16 + Math.random() * 16; // px
    var dur = 1600 + Math.random() * 1600; // ms
    var drop = 280 + Math.random() * 360; // px
    var rot = (Math.random() * 380) - 190; // deg

    el.style.left = left + '%';
    el.style.setProperty('--size', size + 'px');
    el.style.setProperty('--dur', dur + 'ms');
    el.style.setProperty('--drop', drop + 'px');
    el.style.setProperty('--rot', rot + 'deg');

    layer.appendChild(el);

    // cleanup after animation finishes
    window.setTimeout(function(){
      if (el && el.parentNode) el.parentNode.removeChild(el);
    }, dur + 60);
  }

  function startRain(char){
    clearRain();

    // spawn a quick burst, then a short stream
    var spawned = 0;

    function burst(n){
      for (var i=0; i<n; i++){
        spawnEmoji(char);
        spawned++;
        if (spawned >= MAX_EMOJIS) return;
      }
    }

    burst(10);

    intervalId = window.setInterval(function(){
      burst(3);
      if (spawned >= MAX_EMOJIS) clearInterval(intervalId);
    }, 140);

    timeoutId = window.setTimeout(function(){
      clearRain();
    }, RUN_MS);
  }

  function setActive(btn){
    pills.forEach(function(p){ p.classList.remove('is-active'); });
    btn.classList.add('is-active');
  }

  pills.forEach(function(btn){
    btn.addEventListener('click', function(){
      var line = btn.getAttribute('data-line') || '';
      var emoji = btn.getAttribute('data-emoji') || '✨';
      var label = btn.getAttribute('data-label') || '';

      setActive(btn);

      if (revealWrap) revealWrap.hidden = false;
      if (revealPill) revealPill.textContent = label;
      if (revealLine) revealLine.textContent = line;

      startRain(emoji);
    });
  });
})();
</script>

{% schema %}
{
  "name": "reader mood pills",
  "settings": [
    { "type": "text", "id": "title", "label": "heading", "default": "what kind of reader are you today?" },
    { "type": "textarea", "id": "sub", "label": "subtext", "default": "pick a mood. we’ll set the tone." },
    { "type": "color", "id": "pill_bg", "label": "active pill background", "default": "#000000" },
    { "type": "color", "id": "pill_ink", "label": "active pill text", "default": "#F7F3EE" }
  ],
  "blocks": [
    {
      "type": "mood",
      "name": "mood pill",
      "settings": [
        { "type": "text", "id": "label", "label": "pill label", "default": "obsessive reader" },
        { "type": "text", "id": "emoji", "label": "emoji to rain", "default": "🖤" },
        { "type": "textarea", "id": "line", "label": "reveal line", "default": "today you’re here for tension, tabbed pages, and a little emotional damage." }
      ]
    }
  ],
  "presets": [
    {
      "name": "reader mood pills",
      "blocks": [
        { "type": "mood", "settings": { "label": "comfort reader", "emoji": "🤍", "line": "soft pages. warm drinks. zero emotional jump-scares. you’re safe here." } },
        { "type": "mood", "settings": { "label": "obsessive reader", "emoji": "🖤", "line": "today you’re here for tension, tabbed pages, and a little emotional damage." } },
        { "type": "mood", "settings": { "label": "chaos reader", "emoji": "🔥", "line": "plot twists, morally gray men, and choices you’ll defend in court. understood." } },
        { "type": "mood", "settings": { "label": "sentimental reader", "emoji": "🥀", "line": "give me devotion, aching confessions, and a slow burn that hurts in the best way." } }
      ]
    }
  ]
}
{% endschema %}
