  }
  /* collapse header once quiz is in progress */
  #bbb-quiz-{{ section.id }}.is-started .bbb-quiz__head{
    max-height:0;
    margin:0;
    padding-top:0;
    padding-bottom:0;
    opacity:0;
    transform:translateY(-10px);
    pointer-events:none;
    overflow:hidden;
  }

  /* base quiz */
  #bbb-quiz-{{ section.id }}.bbb-quiz{
    position:relative;
    max-width:760px;
    margin:120px auto;
    color:#f6f6f6;
    overflow:hidden;
    font-family:"Libre Baskerville", Georgia, serif;
  }

  #bbb-quiz-{{ section.id }} .bbb-quiz__topbar{
    position:relative;
    z-index:4;
    display:none;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    padding:0 24px;
    margin:0 0 28px;
  }

  #bbb-quiz-{{ section.id }} .bbb-quiz__back,
