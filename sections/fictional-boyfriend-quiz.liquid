<div id="fictional-boyfriend-quiz"></div>

{% comment %}
Fictional Boyfriend Quiz (bybookishbabe)
- 5 questions + dramatic reveal
- "what you should read next" uses library tile markup
- visible retailer links (amazon pink) + optional modal on tile click
{% endcomment %}

<section class="bbb-quiz" id="bbb-quiz-{{ section.id }}" data-bbb-quiz>
  <div class="bbb-quiz__topbar" aria-label="quiz navigation">
    <a class="bbb-quiz__back" href="/pages/reader-quizes">back to all quizzes</a>
    <button class="bbb-quiz__again" type="button" data-quiz-again>retake quiz</button>
  </div>

  {% if section.settings.title != blank %}
    <header class="bbb-quiz__head">
      <p class="bbb-quiz__kicker">{{ section.settings.kicker }}</p>
      <h2 class="bbb-quiz__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="bbb-quiz__sub">{{ section.settings.subtext }}</p>
      {% endif %}
      <button class="bbb-quiz__cta" type="button" data-quiz-begin>{{ section.settings.cta_label | default: 'meet him' }}</button>
      {% if section.settings.tagline != blank %}
        <p class="bbb-quiz__tagline">{{ section.settings.tagline }}</p>
      {% endif %}
    </header>
  {% endif %}

  <div class="quiz-track" id="quizTrack-{{ section.id }}" data-quiz-track>

  <!-- Q1 -->
<div class="quiz-slide">
  <h2>pick the line that would absolutely ruin you.</h2>
  <div class="quiz-answers">

    <button class="quiz-answer"
      data-type="morally gray villain"
      data-trope="power, control">
      you don’t belong to the world. you belong to me.
    </button>

    <button class="quiz-answer"
      data-type="obsessive protector"
      data-trope="devotion, angst">
      i would burn for you. happily.
    </button>

    <button class="quiz-answer"
      data-type="academic rival"
      data-trope="tension, rivalry">
      try to beat me. i dare you.
    </button>

  </div>
</div>

  <!-- Q2 -->
<div class="quiz-slide">
  <h2>your weakness is…</h2>
  <div class="quiz-answers">

    <button class="quiz-answer"
      data-type="athlete with heart"
      data-trope="sports, soft devotion">
      protective, competitive, secretly soft.
    </button>

    <button class="quiz-answer"
      data-type="mafia boss"
      data-trope="crime, dominance">
      calm power. everyone else is afraid of him.
    </button>

    <button class="quiz-answer"
      data-type="tortured prince"
      data-trope="royalty, angst">
      duty-bound, emotionally repressed, tragic.
    </button>

  </div>
</div>

  <!-- Q3 -->
<div class="quiz-slide">
  <h2>you always fall for…</h2>
  <div class="quiz-answers">

    <button class="quiz-answer"
      data-type="obsessed stalker"
      data-trope="dark, obsession">
      the one who watches from the shadows.
    </button>

    <button class="quiz-answer"
      data-type="morally gray villain"
      data-trope="enemies, tension">
      the villain who chooses her.
    </button>

    <button class="quiz-answer"
      data-type="academic rival"
      data-trope="enemies to lovers">
      the one who argues with you in public and ruins you in private.
    </button>

  </div>
</div>

  <!-- Q4 -->
<div class="quiz-slide">
  <h2>your ideal dynamic is…</h2>
  <div class="quiz-answers">

    <button class="quiz-answer"
      data-type="athlete with heart"
      data-trope="loyalty, softness">
      touch her and you die energy.
    </button>

    <button class="quiz-answer"
      data-type="mafia boss"
      data-trope="danger, control">
      public indifference. private obsession.
    </button>

    <button class="quiz-answer"
      data-type="tortured prince"
      data-trope="slow burn, royalty">
      longing that almost destroys him.
    </button>

  </div>
</div>

  <!-- Q5 -->
<div class="quiz-slide">
  <h2>your perfect scene is…</h2>
  <div class="quiz-answers">

    <button class="quiz-answer"
      data-type="obsessive protector"
      data-trope="intensity, devotion">
      he looks at you like you’re oxygen.
    </button>

    <button class="quiz-answer"
      data-type="mafia boss"
      data-trope="power, dominance">
      he speaks softly. everyone listens.
    </button>

    <button class="quiz-answer"
      data-type="tortured prince"
      data-trope="yearning, fate">
      he wants you. he just won’t admit it.
    </button>

  </div>
</div>

    <!-- RESULT -->
    <div class="quiz-slide quiz-result">
      <div id="quizResult-{{ section.id }}"></div>
      <div class="sss-emoji-layer" data-emoji-layer aria-hidden="true"></div>

  



    </div>

  </div>
</section>

{%- comment -%} Hidden pool of real library cards {%- endcomment -%}

{% render 'sss-library-modal' %}

{%- comment -%} -------- BUILD BOOK POOLS FROM METAOBJECTS -------- {%- endcomment -%}
<script type="application/json" id="quiz-books-{{ section.id }}">
{
  {% assign all = shop.metaobjects.sss_library.values %}

  {% assign types = all | map: "boyfriend_type" | uniq %}

  {% for type in types %}
    {% assign type_string = type.value | downcase | strip %}

    "{{ type_string }}": [
      {% assign first = true %}
      {% for book in all %}
        {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
        {% assign is_visible_value = is_visible | strip %}
        {% unless is_visible_value == 'true' %}
          {% continue %}
        {% endunless %}
        {% if book.boyfriend_type.value == type.value %}
          {% unless first %},{% endunless %}
          {
            "title": {{ book.title.value | json }},
            "handle": {{ book.system.handle | json }},
            "author": {{ book.author.value | json }},
            "cover": {{ book.cover.value.url | default: book.cover.value | json }},
            "spice": {{ book.spice_level.value | json }},
            "tropes": {{ book.tropes.value | json }},
            "tropes_display": {{ book.tropes.value | map: 'name' | join: ', ' | json }},
            "mini": {{ book.mini_note.value | json }},
            "amazon": {{ book.amazon_link.value.url | json }},
            "bookshop": {{ book.bookshop_link.value.url | json }},
            "boyfriend_name": {{ book.boyfriend_name.value | json }},
            "boyfriend_type": {{ book.boyfriend_type.value | json }}
          }
          {% assign first = false %}
        {% endif %}
      {% endfor %}
    ]{% unless forloop.last %},{% endunless %}
  {% endfor %}
}
</script>

<style>
  /* header */
  #bbb-quiz-{{ section.id }} .bbb-quiz__head{
    padding: 0 24px 22px;
    margin: 0 auto 18px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: opacity .28s ease, transform .28s ease, max-height .28s ease, margin .28s ease, padding .28s ease;
  }

  #bbb-quiz-{{ section.id }}.is-showing-result .bbb-quiz__head{
    max-height:0;
    margin:0;
    padding-top:0;
    padding-bottom:0;
    opacity:0;
    transform:translateY(-10px);
    pointer-events:none;
    overflow:hidden;
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__kicker{
    margin:0;
    font-size:11px;
    letter-spacing:.14em;
    text-transform:uppercase;
    opacity:.62;
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__title{
    margin:10px 0 0;
    font-size:30px;
    font-weight:400;
    text-transform:lowercase;
    letter-spacing:-.02em;
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__sub{
    margin:10px 0 0;
    font-size:13px;
    color:rgba(246,246,246,.72);
    line-height:1.6;
    max-width:70ch;
  }

  /* intro CTA + tagline */
  #bbb-quiz-{{ section.id }} .bbb-quiz__cta{
    position:relative;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:100%;
    max-width:440px;
    min-height:60px;
    margin-top:32px;
    border-radius:18px;
    border:1px solid #ff8ac7;
    background:#ff8ac7;
    color:#0b0b0b;
    font-size:17px;
    font-family:"Libre Baskerville",Georgia,serif;
    cursor:pointer;
    transition:transform .18s ease, filter .18s ease, box-shadow .18s ease;
    letter-spacing:.01em;
    box-shadow:0 14px 30px rgba(255,138,199,.18);
    overflow:hidden;
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__cta:before{
    content:"";
    position:absolute;
    top:-45%;
    bottom:-45%;
    left:-42%;
    width:36%;
    background:linear-gradient(90deg, transparent, rgba(255,255,255,.5), transparent);
    transform:skewX(-18deg) translateX(-120%);
    transition:transform .68s ease;
    pointer-events:none;
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__cta:after{
    content:"";
    position:absolute;
    inset:0;
    border-radius:inherit;
    box-shadow:inset 0 0 0 0 rgba(255,255,255,.26);
    transition:box-shadow .18s ease;
    pointer-events:none;
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__cta:hover{
    transform:translateY(-2px);
    filter:brightness(1.04);
    box-shadow:0 18px 36px rgba(255,138,199,.26);
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__cta:hover:before{
    transform:skewX(-18deg) translateX(520%);
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__cta:hover:after{
    box-shadow:inset 0 0 0 2px rgba(255,255,255,.22);
  }
  #bbb-quiz-{{ section.id }} .bbb-quiz__tagline{
    margin:14px 0 0;
    font-size:12px;
    opacity:.45;
    letter-spacing:.05em;
  }

  /* hide quiz until 'meet him' clicked */
  #bbb-quiz-{{ section.id }} [data-quiz-track]{
    display:none;
  }
  #bbb-quiz-{{ section.id }}.is-started [data-quiz-track]{
