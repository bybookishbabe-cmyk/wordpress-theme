<script>
document.addEventListener("DOMContentLoaded", function(){

const root = document.getElementById("bbb-quiz-{{ section.id }}");
if(!root) return;

let slide = 0;

const track = document.getElementById("quizTrack-{{ section.id }}");
const slides = root.querySelectorAll(".quiz-slide");
const answers = root.querySelectorAll(".quiz-answer");

let scores = {};
let tropeScores = {};

/* -------------------------
SLIDE CONTROL
------------------------- */

function goTo(i){
  slide = i;
  track.style.transform = `translateX(-${slide * 100}%)`;
}

function resetQuiz(){
  scores = {};
  tropeScores = {};
  answers.forEach(function(answer){
    answer.classList.remove("selected");
  });
  root.classList.remove("is-showing-result");
  root.classList.remove("is-started");
  goTo(0);
}

const againBtn = root.querySelector("[data-quiz-again]");
if(againBtn){
  againBtn.addEventListener("click", resetQuiz);
}

const beginBtn = root.querySelector("[data-quiz-begin]");
if(beginBtn){
  beginBtn.addEventListener("click", function(){
    root.classList.add("is-started");
  });
}

/* -------------------------
QUIZ ANSWERS
------------------------- */

answers.forEach(btn=>{
  btn.addEventListener("click",()=>{

    if(btn.classList.contains("selected")) return;

    slides[slide]
      .querySelectorAll(".quiz-answer")
      .forEach(b=> b.disabled = true);

    btn.classList.add("selected");

const type = btn.dataset.type;
const trope = btn.dataset.trope;

/* boyfriend scoring */

if(!scores[type]) scores[type] = 0;
scores[type]++;

/* trope scoring */

if(trope){
  trope.split(",").forEach(t=>{
    const key = t.trim();
    if(!tropeScores[key]) tropeScores[key] = 0;
    tropeScores[key]++;
  });
}

    if(!scores[type]) scores[type] = 0;
    scores[type]++;

    setTimeout(()=>{
      const next = slide + 1;
      goTo(next);

      if(next === slides.length - 1){
        showResult();
      }

    },320);

  });
});

/* -------------------------
LOAD BOOK POOLS
------------------------- */

function getPools(){

  const el = document.getElementById("quiz-books-{{ section.id }}");
  if(!el) return {};

  try{
    return JSON.parse(el.textContent);
  }catch(e){
    return {};
  }

}

/* -------------------------
BUILD LIBRARY CARD
------------------------- */


const boyfriendData = {
  "morally gray villain": {
    tags: ["possessive", "obsessive", "emotionally unavailable", "would actually ruin your life"],
    desc: "he doesn't do soft. he does intense, consuming, and slightly terrifying. he's chosen you and that's the most dangerous thing that's ever happened to you. you love it."
  },
  "obsessive protector": {
    tags: ["devoted", "territorial", "will not share you", "dangerously intense"],
    desc: "he'd burn down cities before he let anything hurt you. the devotion is overwhelming. the protection is suffocating in the best way possible. you are his entire reason."
  },
  "academic rival": {
    tags: ["competitive", "sharp-tongued", "secretly soft", "infuriatingly attractive"],
    desc: "he argues with you in public and can't stop thinking about you in private. the banter is foreplay. the rivalry is a love language. he'll never admit he's losing."
  },
  "athlete with heart": {
    tags: ["protective", "competitive", "quietly devoted", "dangerously loyal"],
    desc: "strong enough to wreck you, soft enough to make you cry about it. he shows up every single time without being asked. you are his favorite thing about being alive."
  },
  "mafia boss": {
    tags: ["controlled", "quietly terrifying", "dominant", "yours and only yours"],
    desc: "everyone in the room is afraid of him. he lets you be the only one who isn't. that's the most dangerous position you've ever been in. you don't want out."
  },
  "tortured prince": {
    tags: ["brooding", "duty-bound", "tragically devoted", "emotionally repressed"],
    desc: "he wants you so badly it's destroying him. he's carrying a hundred obligations and you're the one thing he can't let himself have. yet. the yearning is excruciating."
  },
  "obsessed stalker": {
    tags: ["darkly devoted", "haunting", "obsessive", "terrifyingly attentive"],
    desc: "he was watching before you knew he existed. he knows you better than you know yourself. it should terrify you. it really doesn't. that's the problem."
  }
};

const bookPools = getPools();

/* -------------------------
SHOW RESULT
------------------------- */

function showResult(){

root.classList.add("is-showing-result");

const keys = Object.keys(scores);
if(!keys.length) return;

const winner = keys
  .reduce((a,b)=> scores[a] >= scores[b] ? a : b)
  .toLowerCase()
  .trim();

const pool = (bookPools[winner] || []).slice();

const books =
[...pool]
.sort(()=>0.5-Math.random())
.slice(0,3);

const main = books[0] || null;
const resultBoyfriend = main?.boyfriend_name || winner;
const resultCover = main?.cover || "";
const resultTitle = main?.title || "";
const libraryPreviewCovers = books
  .map(function(entry){
    return {
      cover: entry?.cover || "",
      title: entry?.title || ""
    };
  })
  .filter(function(item){
    return item.cover;
  })
  .slice(0,3);

const result =
document.getElementById("quizResult-{{ section.id }}");

const data = boyfriendData[winner] || { tags: [], desc: "" };
const traitItems = (data.tags || []).map(function(tag, i){
  return `<li class="bbb-result__trait" style="animation-delay:${0.08 + i * 0.18}s">${escape(tag)}</li>`;
}).join("");
const coverRain = coverHeartRainHtml();

result.innerHTML = `

<div class="bbb-result__header">
  ${resultCover ? `<div class="bbb-result__matchCover"><img src="${escape(resultCover)}" alt="${escape(resultTitle || resultBoyfriend)}" loading="lazy"><div class="bbb-result__coverRain" aria-hidden="true">${coverRain}</div></div>` : ""}
  <p class="bbb-result__kicker">your fictional boyfriend is</p>
  <h3 class="bbb-result__type">${escape(resultBoyfriend)}</h3>
  <ul class="bbb-result__traits">${traitItems}</ul>
  <p class="bbb-result__desc">${escape(data.desc || "")}</p>
</div>

<hr class="bbb-result__divider">

<div class="bbb-result__books">
  <p class="bbb-result__booksKicker">books with his exact energy</p>
  <div class="bbb-result__bookList" id="bbb-bookList-{{ section.id }}"></div>
</div>

<div class="bbb-result__newsletter">
  <p class="bbb-result__newsletterTitle">get a new fictional man every sunday</p>
  <p class="bbb-result__newsletterSub">the smut &amp; sentiment society — one perfectly curated rec, delivered weekly. morally gray men a specialty.</p>
  <form class="bbb-result__newsletterForm" action="/contact#contact_form" method="post" accept-charset="UTF-8">
    <input type="hidden" name="form_type" value="customer">
    <input type="hidden" name="utf8" value="✓">
    <input type="hidden" name="contact[tags]" value="newsletter">
    <input class="bbb-result__emailInput" type="email" name="contact[email]" placeholder="your email" required>
    <button class="bbb-result__joinBtn" type="submit">join the society</button>
  </form>
  <p class="bbb-result__newsletterFine">free to join. unsubscribe any time.</p>
</div>

<div class="bbb-result__actions">
  <button class="bbb-result__shareBtn" type="button" data-quiz-bestie-share data-quiz-result-name="${escape(resultBoyfriend)}">share your result</button>
</div>

`;

/* build a single book row */
function makeBookItem(book, isMatch){
  if(!book) return null;
  const cover    = book.cover || "";
  const title    = book.title || "";
  const author   = book.author || "";
  const mini     = book.mini || "";
  const amazon   = book.amazon || "";
  const bookshop = book.bookshop || "";
  const handle   = book.handle || "";
  const spice    = parseInt(book.spice) || 0;
  const tropes   = Array.isArray(book.tropes) ? book.tropes.join(", ") : (book.tropes || "");
  const tropesDisplay = book.tropes_display || tropes;
  const spiceHtml = spice > 0
    ? `<div class="sss-lib__floatSpice">${"🌶".repeat(Math.min(spice,5))}</div>`
    : "";
  const item = document.createElement("div");
  item.className = "bbb-book-item" + (isMatch ? " bbb-book-item--match" : "");
  item.dataset.bkTitle    = title;
  item.dataset.bkAuthor   = author;
  item.dataset.bkCover    = cover;
  item.dataset.bkAmazon   = amazon;
  item.dataset.bkBookshop = bookshop;
  item.dataset.bkMini     = mini;
  item.dataset.bkTropes   = tropes;
  item.dataset.bkTropesDisplay = tropesDisplay;
  item.dataset.bkHandle   = handle;
  item.innerHTML = `
    <div class="bbb-book-item__inner" data-open-book>
      <div class="bbb-bi__coverWrap">
        ${cover
          ? `<img class="bbb-bi__cover" src="${escape(cover)}" alt="${escape(title)}" loading="lazy">`
          : `<div class="bbb-bi__cover bbb-bi__cover--empty"></div>`}
        ${spiceHtml}
        <button class="sss-lib__heart bbb-bi__heart" type="button" data-book-save data-book-handle="${escape(handle)}" aria-label="save to shelf">
          <span class="sss-lib__heartIcon" data-heart-icon aria-hidden="true">♡</span>
          <span class="sss-lib__heartLabel" data-heart-label>save</span>
        </button>
      </div>
      <div class="bbb-book-item__content">
        <p class="bbb-book-item__title">${escape(title)}</p>
        <p class="bbb-book-item__author">${escape(author)}</p>
        ${mini ? `<p class="bbb-book-item__desc">${escape(mini)}</p>` : ""}
        ${tropesDisplay ? `<p class="bbb-book-item__desc">tropes: ${escape(tropesDisplay)}</p>` : ""}
        <div class="bbb-book-item__buttons">
          ${amazon ? `<a class="bbb-book-item__btn bbb-book-item__btn--a" href="${escape(amazon)}" target="_blank" rel="noopener sponsored">amazon</a>` : ""}
          ${bookshop ? `<a class="bbb-book-item__btn bbb-book-item__btn--shop" href="${escape(bookshop)}" target="_blank" rel="noopener sponsored">bookshop</a>` : ""}
          <button class="bbb-book-item__btn bbb-book-item__btn--b" type="button" data-book-save data-book-handle="${escape(handle)}">save to shelf</button>
        </div>
      </div>
    </div>
  `;
  return item;
}

const bookList = result.querySelector("#bbb-bookList-{{ section.id }}");
const mainBook    = books[0];
const suggestBooks = books.slice(1);

if(mainBook){
  const el = makeBookItem(mainBook, true);
  if(el) bookList.appendChild(el);
}

if(suggestBooks.length){
  const sep = document.createElement("div");
  sep.innerHTML = `
    <hr class="bbb-result__divider bbb-result__divider--slim">
    <p class="bbb-result__booksKicker" style="margin-top:24px">he would also suggest</p>
  `;
  bookList.appendChild(sep);
  suggestBooks.forEach(function(book){
    const el = makeBookItem(book, false);
    if(el) bookList.appendChild(el);
  });
}

books.forEach(function(book){
  if(!book) return;
  updateQuizSaveButtons(book.handle || "", quizBookIsSaved(quizBookData(book)));
});

startRain(winner);

}

/* save-to-shelf */
function getQuizShelf(){
  try {
    return JSON.parse(localStorage.getItem("sssMyShelf")) || [];
  } catch(err){
    return [];
  }
}

function setQuizShelf(nextShelf){
  localStorage.setItem("sssMyShelf", JSON.stringify(nextShelf));
  document.dispatchEvent(new CustomEvent("sss:bookshelf-updated", {
    detail: { count: Array.isArray(nextShelf) ? nextShelf.length : 0 }
  }));
}

function quizBookData(card){
  if(!card) return null;
  return {
    handle: card.handle || card.dataset && (card.dataset.handle || card.dataset.bkHandle) || "",
    title: card.title || card.dataset && (card.dataset.title || card.dataset.bkTitle) || "",
    author: card.author || card.dataset && (card.dataset.author || card.dataset.bkAuthor) || "",
    cover: card.cover || card.dataset && (card.dataset.cover || card.dataset.bkCover) || "",
    amazon: card.amazon || card.dataset && (card.dataset.amazon || card.dataset.bkAmazon) || "",
    bookshop: card.bookshop || card.dataset && (card.dataset.bookshop || card.dataset.bkBookshop) || ""
  };
}

function quizBookIsSaved(bookData){
  if(!bookData || !bookData.title) return false;
  return getQuizShelf().some(function(book){
    return book.title === bookData.title || (bookData.handle && book.handle === bookData.handle);
  });
}

function updateQuizHeart(heart, isSaved){
  if(!heart) return;
  heart.classList.toggle("is-saved", !!isSaved);

  const icon = heart.querySelector("[data-heart-icon]");
  const label = heart.querySelector("[data-heart-label]");

  if(icon) icon.textContent = isSaved ? "♥" : "♡";
  if(label) label.textContent = isSaved ? "saved" : "save";
  heart.setAttribute("aria-label", isSaved ? "remove from your bookshelf" : "save to your bookshelf");
}

function syncQuizSourceHeart(handle, isSaved){
  if(!handle) return;
  updateQuizSaveButtons(handle, isSaved);
}

function toggleQuizShelfBook(bookData){
  if(!bookData || !bookData.title) return false;
  let shelf = getQuizShelf();
  const exists = shelf.some(function(book){
    return book.title === bookData.title || (bookData.handle && book.handle === bookData.handle);
  });

  if(exists){
    shelf = shelf.filter(function(book){
      return book.title !== bookData.title && (!bookData.handle || book.handle !== bookData.handle);
    });
  } else {
    shelf.push(bookData);
  }

  setQuizShelf(shelf);
  document.dispatchEvent(new CustomEvent(exists ? "bbb:shelf-unsaved" : "bbb:shelf-saved", {
    detail: {
      count: shelf.length,
      bookTitle: bookData.title,
      bookHandle: bookData.handle,
      book: bookData,
      source: "fictional_boyfriend_quiz"
    }
  }));

  return !exists;
}

function updateQuizSaveButtons(handle, isSaved){
  root.querySelectorAll("[data-book-save]").forEach(function(btn){
    if(btn.dataset.bookHandle !== handle) return;
    btn.classList.toggle("is-saved", !!isSaved);

    const icon = btn.querySelector("[data-heart-icon]");
    const label = btn.querySelector("[data-heart-label]");

    if(icon) icon.textContent = isSaved ? "♥" : "♡";
    if(label) label.textContent = isSaved ? "saved" : "save";
    if(!icon && !label) btn.textContent = isSaved ? "saved" : "save to shelf";
  });
}

root.addEventListener("click", function(e){
  const saveBtn = e.target.closest("[data-book-save]");
  if(!saveBtn) return;
  e.stopPropagation();
  const handle = saveBtn.dataset.bookHandle;
  if(!handle) return;
  const resultCard = saveBtn.closest(".bbb-book-item");
  let sourceBook = null;
  Object.keys(bookPools).some(function(key){
    const match = (bookPools[key] || []).find(function(book){ return book.handle === handle; });
    if(match){
      sourceBook = match;
      return true;
    }
    return false;
  });
  const isSaved = toggleQuizShelfBook(quizBookData(sourceBook || resultCard));
  updateQuizSaveButtons(handle, isSaved);
  syncQuizSourceHeart(handle, isSaved);
});

/* open modal when clicking a book item */
root.addEventListener("click", function(e){
  if(e.target.closest("[data-book-save]")) return;
  if(e.target.closest("a")) return;
  const inner = e.target.closest("[data-open-book]");
  if(!inner) return;
  const item = inner.closest(".bbb-book-item");
  if(!item) return;
  const modal = document.querySelector(".sss-lib__modal:not([data-quiz-modal])");
  if(!modal) return;
  const titleEl  = modal.querySelector("[data-mtitle]");
  const authorEl = modal.querySelector("[data-mauthor]");
  const coverEl  = modal.querySelector("[data-mcover]");
  const amazonEl = modal.querySelector("[data-amazon-btn]");
  const shopEl   = modal.querySelector("[data-bookshop-btn]");
  const miniEl   = modal.querySelector("[data-mmini]");
  const tropesEl = modal.querySelector("[data-mtropes]");
  const bfEl     = modal.querySelector("[data-mboyfriend]");
  const spiceEl  = modal.querySelector("[data-mspice]");
  const modalHeart = modal.querySelector("[data-modal-heart]");
  if(titleEl)  titleEl.textContent  = item.dataset.bkTitle || "";
  if(authorEl) authorEl.textContent = "by " + (item.dataset.bkAuthor || "");
  if(coverEl)  coverEl.src          = item.dataset.bkCover || "";
  if(amazonEl) amazonEl.href        = item.dataset.bkAmazon || "#";
  if(shopEl)   shopEl.href          = item.dataset.bkBookshop || "#";
  if(miniEl)   miniEl.textContent   = item.dataset.bkMini || "";
  if(tropesEl){
    const modalTropes = item.dataset.bkTropesDisplay || item.dataset.bkTropes || "";
    tropesEl.textContent = modalTropes ? "tropes: " + modalTropes : "";
  }
  if(bfEl)     bfEl.textContent     = "";
  if(spiceEl)  spiceEl.textContent  = "";
  modal.dataset.quizBookHandle = item.dataset.bkHandle || "";
  modal.dataset.quizBookTitle = item.dataset.bkTitle || "";
  modal.dataset.quizBookAuthor = item.dataset.bkAuthor || "";
  modal.dataset.quizBookCover = item.dataset.bkCover || "";
  modal.dataset.quizBookAmazon = item.dataset.bkAmazon || "";
  modal.dataset.quizBookBookshop = item.dataset.bkBookshop || "";
  updateQuizHeart(modalHeart, quizBookIsSaved(quizBookData(item)));
  modal.hidden = false;
});

document.addEventListener("click", function(e){
  const modalHeart = e.target.closest("[data-modal-heart]");
  if(!modalHeart) return;
  const modal = modalHeart.closest(".sss-lib__modal");
  if(!modal || !modal.dataset.quizBookTitle) return;
  e.preventDefault();
  e.stopPropagation();

  const bookData = {
    handle: modal.dataset.quizBookHandle || "",
    title: modal.dataset.quizBookTitle || "",
    author: modal.dataset.quizBookAuthor || "",
    cover: modal.dataset.quizBookCover || "",
    amazon: modal.dataset.quizBookAmazon || "",
    bookshop: modal.dataset.quizBookBookshop || ""
  };
  const isSaved = toggleQuizShelfBook(bookData);
  updateQuizHeart(modalHeart, isSaved);
  updateQuizSaveButtons(bookData.handle, isSaved);
  syncQuizSourceHeart(bookData.handle, isSaved);
});

root.addEventListener("click", function(e){
if(e.target.closest("[data-quiz-again]")){
  resetQuiz();
  return;
}

const shareBtn = e.target.closest("[data-quiz-bestie-share]");
if(!shareBtn) return;

const quizUrl = window.location.origin + window.location.pathname;
const resultName = shareBtn.dataset.quizResultName || "a fictional man";
const shareText = "i got " + resultName + " and you have to take this";
const shareTitle = "fictional boyfriend test";
const shareMessage = shareText + "\n" + quizUrl;

if(navigator.share){
  navigator.share({
    title: shareTitle,
    text: shareText,
    url: quizUrl
  }).catch(function(){});
  return;
}

if(navigator.clipboard && navigator.clipboard.writeText){
  navigator.clipboard.writeText(shareMessage).then(function(){
    shareBtn.textContent = "link copied";
    setTimeout(function(){
      shareBtn.textContent = "share your result";
    }, 1800);
  });
}
});

/* -------------------------
MODAL
------------------------- */

root.addEventListener("click", function(e){

const book = e.target.closest(".sss-lib__book");
if(!book) return;

const modal = document.querySelector(".sss-lib__modal:not([data-quiz-modal])");
if(!modal) return;

/* populate modal fields */

modal.querySelector("[data-mtitle]").textContent = book.dataset.title || "";
modal.querySelector("[data-mauthor]").textContent = "by " + (book.dataset.author || "");

modal.querySelector("[data-mcover]").src = book.dataset.cover || "";

modal.querySelector("[data-amazon-btn]").href = book.dataset.amazon || "#";
modal.querySelector("[data-bookshop-btn]").href = book.dataset.bookshop || "#";

modal.querySelector("[data-mmini]").textContent = book.dataset.mini || "";
const modalBoyfriend = modal.querySelector("[data-mboyfriend]");
if(modalBoyfriend){
modalBoyfriend.textContent = "";
}

const modalTropes = book.dataset.tropesDisplay || book.dataset.tropes || "";
modal.querySelector("[data-mtropes]").textContent = modalTropes ? "tropes: " + modalTropes : "";

const modalSpice = modal.querySelector("[data-mspice]");
if(modalSpice){
modalSpice.textContent = "";
}

modal.hidden = false;

});

document.querySelectorAll("[data-close]").forEach(btn=>{
  btn.addEventListener("click",()=>{
    const modal = document.querySelector(".sss-lib__modal");
    if(modal) modal.hidden = true;
  });
});

/* -------------------------
UTILS
------------------------- */

function resolveUrl(v){
if(!v) return "";
if(typeof v === "string") return v;
if(v.url) return v.url;
return "";
}

function escape(str){
return String(str || "")
.replaceAll("&","&amp;")
.replaceAll("<","&lt;")
.replaceAll(">","&gt;");
}

/* -------------------------
EMOJI RAIN
------------------------- */

function startRain(type){

const existingLayer = document.querySelector(".sss-quiz-confetti-layer");
if(existingLayer) existingLayer.remove();

const layer = document.createElement("div");
layer.className = "sss-quiz-confetti-layer";
layer.setAttribute("aria-hidden", "true");
document.body.appendChild(layer);

const emoji = "🖤";

for(let i=0;i<62;i++){

const el = document.createElement("span");

el.className = "sss-quiz-confetti";
el.textContent = emoji;

el.style.left = Math.random()*100 + "vw";
el.style.setProperty("--size", (14 + Math.random()*18) + "px");
el.style.setProperty("--dur", (7600 + Math.random()*5200) + "ms");
el.style.setProperty("--drift", ((Math.random() * 180) - 90) + "px");
el.style.setProperty("--rot", ((Math.random() * 720) - 360) + "deg");
el.style.animationDelay = (Math.random()*2600) + "ms";

layer.appendChild(el);

}

window.setTimeout(function(){
  if(layer && layer.parentNode) layer.remove();
}, 14200);

}

function coverHeartRainHtml(){
  let html = "";
  for(let i = 0; i < 14; i++){
    html += '<span class="bbb-result__coverHeart" style="--x:' + (8 + Math.random() * 84) + '%; --size:' + (11 + Math.random() * 9) + 'px; --dur:' + (3200 + Math.random() * 2400) + 'ms; --delay:-' + (Math.random() * 4200) + 'ms; --drift:' + ((Math.random() * 30) - 15) + 'px; --rot:' + ((Math.random() * 260) - 130) + 'deg;">🖤</span>';
  }
  return html;
}

});
