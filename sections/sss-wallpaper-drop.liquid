{% comment %}
  sss-wallpaper-drop.liquid
  Cute iPhone wallpaper drop section
  - Preview card + “tap to unlock” moment
  - Optional lockscreen + homescreen download links
  - Pink hearts confetti on unlock
  - Mobile-first, on-brand (dark editorial)
{% endcomment %}

<section class="sss-wp" data-sss-wallpaper>
  <div class="sss-wp__wrap">

    <div class="sss-wp__top">
      <p class="sss-wp__kicker">{{ section.settings.kicker }}</p>
      <h2 class="sss-wp__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="sss-wp__sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="sss-wp__grid">

      <!-- LEFT: preview / story -->
      <article class="sss-wp__card">
        <div class="sss-wp__cardHead">
          <p class="sss-wp__label">{{ section.settings.card_label }}</p>
          <h3 class="sss-wp__cardTitle">{{ section.settings.card_title }}</h3>
          {% if section.settings.card_sub != blank %}
            <p class="sss-wp__cardSub">{{ section.settings.card_sub }}</p>
          {% endif %}
        </div>

        <div class="sss-wp__media">
          {% if section.settings.preview_image != blank %}
            {{ section.settings.preview_image | image_url: width: 1400 | image_tag: class: 'sss-wp__img', loading: 'lazy', alt: 'Wallpaper preview' }}
          {% else %}
            <div class="sss-wp__placeholder">
              <div class="sss-wp__phTop">iphone wallpaper</div>
              <div class="sss-wp__phMain">add a preview image</div>
              <div class="sss-wp__phSub">so they can obsess first 🤍</div>
            </div>
          {% endif %}
        </div>

        {% if section.settings.caption != blank %}
          <p class="sss-wp__caption">{{ section.settings.caption }}</p>
        {% endif %}

      </article>

      <!-- RIGHT: unlock + downloads -->
      <aside class="sss-wp__panel">
        <div class="sss-wp__panelHead">
          <p class="sss-wp__panelKicker">{{ section.settings.panel_kicker }}</p>
          <h3 class="sss-wp__panelTitle">{{ section.settings.panel_title }}</h3>
          {% if section.settings.panel_sub != blank %}
            <p class="sss-wp__panelSub">{{ section.settings.panel_sub }}</p>
          {% endif %}
        </div>

        <div class="sss-wp__panelBody">
          <button class="sss-wp__unlockBtn" type="button" id="wpUnlock">
            <span class="sss-wp__unlockText">{{ section.settings.unlock_btn }}</span>
            <span class="sss-wp__unlockSub">tap to reveal</span>
          </button>

          <div class="sss-wp__reveal" id="wpReveal" hidden>
            <div class="sss-wp__revealTop">
              <span class="sss-wp__badge">unlocked</span>
              <p class="sss-wp__revealLine">{{ section.settings.reveal_line }}</p>
            </div>

            <div class="sss-wp__dlGrid">
              {% assign lock_url = section.settings.lockscreen_url %}
              {% assign home_url = section.settings.homescreen_url %}

              {% if lock_url != blank %}
                <a class="sss-wp__dlBtn" href="{{ lock_url }}" target="_blank" rel="noopener">
                  <span class="big">download</span>
                  <span class="small">lockscreen</span>
                </a>
              {% endif %}

              {% if home_url != blank %}
                <a class="sss-wp__dlBtn" href="{{ home_url }}" target="_blank" rel="noopener">
                  <span class="big">download</span>
                  <span class="small">homescreen</span>
                </a>
              {% endif %}

              {% if lock_url == blank and home_url == blank %}
                <div class="sss-wp__empty">
                  add your wallpaper links in the section settings
                </div>
              {% endif %}
            </div>

            {% if section.settings.extra_note != blank %}
              <p class="sss-wp__note">{{ section.settings.extra_note }}</p>
            {% endif %}
          </div>
        </div>

        <div class="sss-wp__tiny">
          <span class="sss-wp__tinyIcon">💗</span>
          <span>{{ section.settings.tiny_line }}</span>
        </div>
      </aside>

    </div>

    <div class="sss-wp__hearts" id="wpHearts" aria-hidden="true"></div>

  </div>
</section>

<style>
/* ===== outer ===== */
.sss-wp{
  background:#0b0b0b;
  color:#f6f6f6;
  padding:22px 12px;
  font-family:"Libre Baskerville", Georgia, serif;
  position:relative;
  overflow:hidden;
}
.sss-wp::before{
  content:"";
  position:absolute; inset:-60px;
  pointer-events:none;
  background:
    radial-gradient(1000px 560px at 50% 120px, rgba(255,255,255,.08), transparent 70%),
    repeating-linear-gradient(
      to bottom,
      rgba(255,255,255,.035),
      rgba(255,255,255,.035) 1px,
      transparent 1px,
      transparent 26px
    );
  opacity:.55;
}
.sss-wp__wrap{
  max-width:1200px;
  margin:0 auto;
  position:relative;
  z-index:2;
  padding:0 8px;
}
.sss-wp__top{ max-width:920px; margin:0 auto 14px; }
.sss-wp__kicker{
  margin:0 0 8px;
  font-size:12px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:#c8c8c8;
}
.sss-wp__title{
  margin:0;
  font-size:20px;
  font-weight:400;
  text-transform:lowercase;
}
.sss-wp__sub{
  margin:8px 0 0;
  font-size:13px;
  line-height:1.6;
  color:rgba(246,246,246,.78);
}

/* ===== layout ===== */
.sss-wp__grid{
  display:grid;
  grid-template-columns:1fr;
  gap:14px;
  align-items:start;
}
@media(min-width:990px){
  .sss-wp__grid{ grid-template-columns: 1.1fr .9fr; gap:16px; }
}

/* ===== left card ===== */
.sss-wp__card{
  background:rgba(21,21,21,.92);
  border:1px solid #2a2a2a;
  border-radius:18px;
  box-shadow:0 12px 28px rgba(0,0,0,.45);
  overflow:hidden;
}
.sss-wp__cardHead{
  padding:12px;
  border-bottom:1px solid #2a2a2a;
  background:rgba(255,255,255,.03);
}
.sss-wp__label{
  margin:0 0 8px;
  font-size:12px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:#c8c8c8;
}
.sss-wp__cardTitle{
  margin:0;
  font-size:17px;
  font-weight:400;
  text-transform:lowercase;
}
.sss-wp__cardSub{
  margin:6px 0 0;
  font-size:12px;
  line-height:1.55;
  color:rgba(246,246,246,.76);
}
.sss-wp__media{ padding:12px; }
.sss-wp__img{
  width:100%;
  height:auto;
  max-height:520px;
  object-fit:contain;
  display:block;
  border-radius:16px;
  border:1px solid rgba(255,255,255,.12);
  background:#0f0f0f;
  padding:10px;
  box-sizing:border-box;
}
.sss-wp__placeholder{
  border-radius:16px;
  border:1px dashed rgba(255,255,255,.18);
  background:rgba(255,255,255,.04);
  padding:18px;
  text-align:center;
}
.sss-wp__phTop{
  font-size:11px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:#c8c8c8;
}
.sss-wp__phMain{
  margin-top:10px;
  font-size:16px;
  text-transform:lowercase;
}
.sss-wp__phSub{
  margin-top:6px;
  font-size:12px;
  color:rgba(246,246,246,.72);
}

.sss-wp__caption{
  margin:0;
  padding:0 12px 12px;
  font-size:12.5px;
  line-height:1.55;
  color:rgba(246,246,246,.78);
}
.sss-wp__how{
  padding:0 12px 14px;
  display:grid;
  gap:8px;
}
.sss-wp__howItem{
  display:flex;
  align-items:center;
  gap:10px;
  font-size:12px;
  color:rgba(246,246,246,.78);
  text-transform:lowercase;
}
.sss-wp__howItem .dot{
  width:6px; height:6px; border-radius:999px;
  background:rgba(255,105,180,.95);
  flex:0 0 auto;
}

/* ===== right panel ===== */
.sss-wp__panel{
  background:rgba(21,21,21,.92);
  border:1px solid #2a2a2a;
  border-radius:18px;
  box-shadow:0 12px 28px rgba(0,0,0,.45);
  overflow:hidden;
}
.sss-wp__panelHead{
  padding:12px;
  border-bottom:1px solid #2a2a2a;
  background:rgba(255,255,255,.03);
}
.sss-wp__panelKicker{
  margin:0 0 8px;
  font-size:12px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:#c8c8c8;
}
.sss-wp__panelTitle{
  margin:0;
  font-size:17px;
  font-weight:400;
  text-transform:lowercase;
}
.sss-wp__panelSub{
  margin:6px 0 0;
  font-size:12px;
  line-height:1.55;
  color:rgba(246,246,246,.76);
}
.sss-wp__panelBody{ padding:12px; }

.sss-wp__unlockBtn{
  width:100%;
  height:56px;
  border-radius:16px;
  border:1px solid rgba(255,105,180,.55);
  background:rgba(255,105,180,.16);
  color:#fff;
  cursor:pointer;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:4px;
  transition:transform .14s ease, background .14s ease, border-color .14s ease;
}
.sss-wp__unlockBtn:hover{
  transform:translateY(-1px);
  background:rgba(255,105,180,.22);
  border-color:rgba(255,105,180,.75);
}
.sss-wp__unlockText{
  font-size:13px;
  text-transform:lowercase;
}
.sss-wp__unlockSub{
  font-size:12px;
  opacity:.85;
}
.sss-wp__reveal{
  margin-top:12px;
  border-radius:16px;
  border:1px solid rgba(255,255,255,.12);
  background:rgba(255,255,255,.04);
  padding:12px;
}
.sss-wp__revealTop{
  display:flex;
  flex-direction:column;
  gap:8px;
  margin-bottom:10px;
}
.sss-wp__badge{
  display:inline-flex;
  width:max-content;
  padding:5px 10px;
  border-radius:999px;
  background:#000;
  border:1px solid rgba(255,105,180,.55);
  color:rgba(255,180,220,.98);
  font-size:11px;
  text-transform:lowercase;
}
.sss-wp__revealLine{
  margin:0;
  font-size:12.5px;
  line-height:1.55;
  color:rgba(246,246,246,.82);
  text-transform:lowercase;
}
.sss-wp__dlGrid{
  display:grid;
  gap:10px;
}
@media(min-width:700px){
  .sss-wp__dlGrid{ grid-template-columns:1fr 1fr; }
}
.sss-wp__dlBtn{
  height:54px;
  border-radius:16px;
  border:1px solid rgba(255,255,255,.14);
  background:rgba(0,0,0,.22);
  color:#fff;
  text-decoration:none;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:2px;
  transition:transform .14s ease, background .14s ease, border-color .14s ease;
}
.sss-wp__dlBtn:hover{
  transform:translateY(-1px);
  background:rgba(255,105,180,.12);
  border-color:rgba(255,105,180,.45);
}
.sss-wp__dlBtn .big{
  font-size:13px;
  text-transform:lowercase;
}
.sss-wp__dlBtn .small{
  font-size:12px;
  opacity:.86;
  text-transform:lowercase;
}
.sss-wp__empty{
  padding:10px 12px;
  border-radius:14px;
  border:1px dashed rgba(255,255,255,.18);
  color:rgba(246,246,246,.70);
  font-size:12px;
  text-transform:lowercase;
  text-align:center;
}
.sss-wp__note{
  margin:10px 0 0;
  font-size:12px;
  color:rgba(246,246,246,.75);
  line-height:1.55;
}
.sss-wp__tiny{
  display:flex;
  align-items:center;
  gap:10px;
  padding:12px;
  border-top:1px solid #2a2a2a;
  color:rgba(246,246,246,.72);
  font-size:12px;
  text-transform:lowercase;
}
.sss-wp__tinyIcon{
  width:28px; height:28px;
  border-radius:12px;
  display:grid; place-items:center;
  background:rgba(255,105,180,.14);
  border:1px solid rgba(255,105,180,.35);
}

/* ===== heart confetti ===== */
.sss-wp__hearts{
  position:absolute;
  inset:0;
  pointer-events:none;
  z-index:6;
  overflow:hidden;
}
.sss-wp__heart{
  position:absolute;
  top:-26px;
  font-size:16px;
  opacity:.9;
  animation: wpFall linear forwards;
  filter: drop-shadow(0 10px 18px rgba(0,0,0,.45));
}
@keyframes wpFall{
  0%   { transform:translateY(-50px) rotate(0deg); opacity:0; }
  12%  { opacity:.95; }
  100% { transform:translateY(calc(120vh + 140px)) rotate(240deg); opacity:0; }
}
</style>

<script>
(function(){
  const root = document.querySelector('[data-sss-wallpaper]');
  if (!root || root.__wpBound) return;
  root.__wpBound = true;

  const unlockBtn = root.querySelector('#wpUnlock');
  const reveal    = root.querySelector('#wpReveal');
  const heartsEl  = root.querySelector('#wpHearts');

  function burstHearts(count){
    if (!heartsEl) return;
    for (let i=0;i<count;i++){
      const h = document.createElement('div');
      h.className = 'sss-wp__heart';
      h.textContent = (Math.random() < 0.94) ? '💗' : '✨';
      h.style.left = Math.floor(Math.random()*100) + '%';
      h.style.fontSize = (14 + Math.random()*18) + 'px';
      const dur = (8.5 + Math.random()*6.5); // slower + longer
      h.style.animationDuration = dur + 's';
      h.style.animationDelay = (Math.random()*0.35) + 's';
      h.style.opacity = (0.55 + Math.random()*0.35).toFixed(2);
      heartsEl.appendChild(h);
      setTimeout(()=> h.remove(), (dur*1000) + 1200);
    }
  }

  unlockBtn.addEventListener('click', function(){
    if (!reveal.hidden) return;
    reveal.hidden = false;
    unlockBtn.disabled = true;
    unlockBtn.style.opacity = '.75';
    unlockBtn.querySelector('.sss-wp__unlockSub').textContent = 'unlocked 💗';
    burstHearts(28);
  });
})();
</script>

{% schema %}
{
  "name": "sss wallpaper drop",
  "settings": [
    { "type": "text", "id": "kicker", "label": "kicker", "default": "society extra" },
    { "type": "text", "id": "title", "label": "title", "default": "this month’s iphone wallpaper" },
    { "type": "textarea", "id": "subtext", "label": "subtext", "default": "a tiny obsession for your lockscreen. tap to unlock the download." },

    { "type": "text", "id": "card_label", "label": "card label", "default": "wallpaper drop" },
    { "type": "text", "id": "card_title", "label": "card title", "default": "romantically unwell (but make it aesthetic)" },
    { "type": "textarea", "id": "card_sub", "label": "card subtext", "default": "a little reminder every time you open your phone." },
    { "type": "image_picker", "id": "preview_image", "label": "preview image" },
    { "type": "textarea", "id": "caption", "label": "caption", "default": "a little collage of romantic moments" },

    { "type": "text", "id": "panel_kicker", "label": "panel kicker", "default": "download" },
    { "type": "text", "id": "panel_title", "label": "panel title", "default": "tap to unlock" },
    { "type": "textarea", "id": "panel_sub", "label": "panel subtext", "default": "save it, set it, and let it emotionally damage you daily." },

    { "type": "text", "id": "unlock_btn", "label": "unlock button text", "default": "unlock wallpaper" },
    { "type": "textarea", "id": "reveal_line", "label": "reveal line", "default": "okay… here you go. try not to fall in love with your own lockscreen." },

    { "type": "url", "id": "lockscreen_url", "label": "lockscreen wallpaper url" },
    { "type": "url", "id": "homescreen_url", "label": "homescreen wallpaper url (optional)" },

    { "type": "textarea", "id": "extra_note", "label": "extra note", "default": "tip: if it downloads as a webp, screenshot it and set from photos." },
    { "type": "text", "id": "tiny_line", "label": "tiny line", "default": "just for society members 🤍" }
  ],
  "presets": [
    { "name": "sss wallpaper drop" }
  ]
}
{% endschema %}
