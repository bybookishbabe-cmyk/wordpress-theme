    align-items:center;
    justify-content:center;
    width:34px;
    height:34px;
    border-radius:999px;
    border:1px solid rgba(255,138,199,.28);
    color:#ff8ac7;
    font-size:16px;
    flex-shrink:0;
    animation:sssRecTeaseArrow 2.8s ease-in-out infinite;
  }

  #sss-lib-{{ section.id }} .sss-lib__recTeaseBook--result{
    transform:translateX(-8px);
