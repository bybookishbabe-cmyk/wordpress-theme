{% comment %}
  sss-library-page.liquid
  Society Library — grid + hover overlay + click-to-choose retailer modal
  Metaobject: sss_library
  Fields expected (based on your setup):
    - title (text)
    - author (text)
    - cover (link OR text URL)
    - why_i_loved_it (text)
    - tropes (text)
    - spice_level (integer)
    - amazon_link (link OR text URL)
    - bookshop_link (link OR text URL)
{% endcomment %}

<section class="sss-lib sss-lib--public" id="sss-lib-{{ section.id }}" data-sss-lib="public">
  {% assign society = false %}
  <div class="sss-lib__wrap">

    <div class="sss-lib__headWrap">

  <header class="sss-lib__head">
    <p class="sss-lib__kicker">{{ section.settings.kicker }}</p>
<h1 class="sss-lib__title">{{ section.settings.title }}</h1>

<p class="sss-lib__seoLine">
  made for romance readers by a romance reader.
</p>

{% if section.settings.subtext != blank %}
  <p class="sss-lib__sub">{{ section.settings.subtext }}</p>
{% endif %}
  <a class="sss-lib__kuLink" href="https://amzn.to/4uZ8Y3a" target="_blank" rel="noopener sponsored">
    on a kindle kick? try kindle unlimited →
  </a>
  </header>

  <div class="sss-lib__societyInviteCard">
    <div class="sss-lib__societyInviteKicker">
      the private layer
    </div>

    <div class="sss-lib__societyInviteTitle">
      join the society for the weekly recommendation
    </div>

    <div class="sss-lib__societyInviteSub">
      one curated romance. delivered every sunday.  
      full breakdown, tension index, emotional damage rating, and private annotations.
    </div>

	    <a href="https://thesmutandsentimentsociety.substack.com/subscribe" class="sss-lib__societyInviteBtn">
	      enter the society
	    </a>
	  </div>

	</div>
{% paginate shop.metaobjects.sss_library.values by 250 %}
{% assign jump_books = shop.metaobjects.sss_library.values | sort: "title" %}
{% endpaginate %}

{% assign jump_starter_count = 0 %}
{% assign jump_mood_shelf_list = '' %}
{% assign jump_has_mood_shelves = false %}

{% for book in jump_books %}
  {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
  {% assign is_visible_value = is_visible | strip %}
  {% unless is_visible_value == 'true' %}
    {% continue %}
  {% endunless %}
  {% capture is_private %}{% render 'sss-book-private', book: book %}{% endcapture %}
  {% assign is_private_value = is_private | strip %}
  {% if is_private_value == 'true' %}
    {% continue %}
  {% endif %}

  {% if book.starter_pack.value %}
    {% assign jump_starter_count = jump_starter_count | plus: 1 %}
  {% endif %}

  {% assign jump_shelf_name = book.shelf.value.name | strip %}
  {% if jump_shelf_name != blank and jump_shelf_name != 'society classics' %}
    {% assign jump_shelf_token = '|' | append: jump_shelf_name | append: '|' %}
    {% unless jump_mood_shelf_list contains jump_shelf_token %}
      {% assign jump_mood_shelf_list = jump_mood_shelf_list | append: jump_shelf_name | append: '|' %}
    {% endunless %}
  {% endif %}
{% endfor %}

{% assign jump_mood_shelves = jump_mood_shelf_list | split: '|' %}
{% for shelf in jump_mood_shelves %}
  {% if shelf == blank or jump_has_mood_shelves %}
    {% continue %}
  {% endif %}

  {% assign jump_shelf_count = 0 %}
  {% for book in jump_books %}
    {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
    {% assign is_visible_value = is_visible | strip %}
    {% unless is_visible_value == 'true' %}
      {% continue %}
    {% endunless %}
    {% capture is_private %}{% render 'sss-book-private', book: book %}{% endcapture %}
    {% assign is_private_value = is_private | strip %}
    {% if is_private_value == 'true' %}
      {% continue %}
    {% endif %}
    {% assign book_shelf = book.shelf.value.name | strip %}
    {% if book_shelf == shelf %}
      {% assign jump_shelf_count = jump_shelf_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if jump_shelf_count > 5 %}
    {% assign jump_has_mood_shelves = true %}
  {% endif %}
{% endfor %}
{% render 'sss-trending-shelf', books: jump_books, include_private_books: false %}

<nav class="sss-lib__jumpNav">
<div class="sss-lib__jumpTitle">
choose where to begin
</div>
<div class="sss-lib__jumpLinks">
<a href="#sssMyShelfSection">📚 your bookshelf</a>
<a href="#society-classics">👑 classics</a>
<a href="/pages/series-reading-orders">🔗 series</a>
{% if jump_starter_count > 0 %}<a href="#starter-pack">✨ start here</a>{% endif %}
<a href="#monthly">📅 books of the month</a>
{% if jump_has_mood_shelves %}<a href="#moods">🖤 trope shelves</a>{% endif %}
<a href="#archive">🗂️ full library</a>
</div>
</nav>

<a class="sss-lib__spiceTease" href="/pages/romance-books-by-spice-level">
  <span class="sss-lib__spiceTeaseRain" aria-hidden="true">
    <span>🌶</span><span>🌶</span><span>🌶</span><span>🌶</span><span>🌶</span>
  </span>
  <span class="sss-lib__spiceTeaseKicker">need a faster way in?</span>
  <span class="sss-lib__spiceTeaseText">browse the library by spice level and go straight to your preferred spice →</span>
</a>

{% assign tease_pick_title_key = section.settings.rec_pick_title | downcase | strip %}
{% assign tease_result_title_key = section.settings.rec_result_title | downcase | strip %}
{% assign tease_pick_handle_key = section.settings.rec_pick_title | handleize %}
{% assign tease_result_handle_key = section.settings.rec_result_title | handleize %}
{% assign tease_pick_cover_url = '' %}
{% assign tease_result_cover_url = '' %}
{% assign tease_pick_book = shop.metaobjects.sss_library[tease_pick_handle_key] %}
{% assign tease_result_book = shop.metaobjects.sss_library[tease_result_handle_key] %}

{% if tease_pick_book != blank %}
  {% assign tease_pick_cover_value = tease_pick_book.cover.value | default: tease_pick_book.cover %}
  {% assign tease_pick_cover_url = tease_pick_cover_value.url | default: tease_pick_cover_value %}
{% endif %}

{% if tease_result_book != blank %}
  {% assign tease_result_cover_value = tease_result_book.cover.value | default: tease_result_book.cover %}
  {% assign tease_result_cover_url = tease_result_cover_value.url | default: tease_result_cover_value %}
{% endif %}
{% assign tease_books = shop.metaobjects.sss_library.values %}
{% for book in tease_books %}
  {% assign book_title_value = book.title.value | default: book.title %}
  {% assign book_title_key = book_title_value | downcase | strip %}
  {% assign book_handle_key = book.system.handle | default: book.handle | handleize %}
  {% assign book_cover_value = book.cover.value | default: book.cover %}
  {% assign book_cover_url = book_cover_value.url | default: book_cover_value %}
  {% if tease_pick_cover_url == blank and book_title_key == tease_pick_title_key or tease_pick_cover_url == blank and book_handle_key == tease_pick_handle_key %}
    {% assign tease_pick_cover_url = book_cover_url %}
  {% endif %}
  {% if tease_result_cover_url == blank and book_title_key == tease_result_title_key or tease_result_cover_url == blank and book_handle_key == tease_result_handle_key %}
    {% assign tease_result_cover_url = book_cover_url %}
  {% endif %}
{% endfor %}

<a href="{{ section.settings.rec_link | default: 'https://bybookishbabe.com/pages/what-to-read-next' }}" class="bbb-homeRecDemo bbb-homeRecDemo--library">
  <div class="bbb-homeRecDemo__copy">
    <div class="bbb-homeRecDemo__kicker">{{ section.settings.rec_kicker }}</div>
    <div class="bbb-homeRecDemo__title"><span>if you liked...</span> {{ section.settings.rec_pick_title }}</div>
    <div class="bbb-homeRecDemo__sub">read this next</div>
    <div class="bbb-homeRecDemo__cta">{{ section.settings.rec_title }}</div>
  </div>

  <div class="bbb-homeRecDemo__stage" aria-hidden="true">
    <div class="bbb-homeRecDemo__book bbb-homeRecDemo__book--picked">
      <div class="bbb-homeRecDemo__label">you picked</div>
      {% if tease_pick_cover_url != blank %}
        <img src="{{ tease_pick_cover_url }}" alt="{{ section.settings.rec_pick_title | escape }}" loading="lazy">
      {% endif %}
      <div class="bbb-homeRecDemo__meta">
        <div class="bbb-homeRecDemo__bookTitle">{{ section.settings.rec_pick_title }}</div>
      </div>
    </div>

    <div class="bbb-homeRecDemo__book bbb-homeRecDemo__book--result">
      <div class="bbb-homeRecDemo__label">read this next</div>
      {% if tease_result_cover_url != blank %}
        <img src="{{ tease_result_cover_url }}" alt="{{ section.settings.rec_result_title | escape }}" loading="lazy">
      {% endif %}
      <div class="bbb-homeRecDemo__meta">
        <div class="bbb-homeRecDemo__bookTitle">{{ section.settings.rec_result_title }}</div>
      </div>
    </div>
  </div>
</a>

<div class="sss-lib__myshelf" id="sssMyShelfSection">

  <div class="sss-lib__archiveHead">

    <div class="sss-lib__archiveKicker">
