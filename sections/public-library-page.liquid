    padding:8px;
    min-height:84px;
    background:transparent;
    border-color:rgba(255,255,255,.05);
  }

  #sss-lib-{{ section.id }} .sss-lib__recTeaseBook img{
    width:64px;
    aspect-ratio:3 / 4.2;
    object-fit:cover;
    border-radius:10px;
    display:block;
  }

  #sss-lib-{{ section.id }} .sss-lib__recTeaseBook:first-child img{
    width:56px;
    opacity:.96;
  }

  #sss-lib-{{ section.id }} .sss-lib__recTeaseLabel{
    font-size:9px;
    letter-spacing:.14em;
    text-transform:uppercase;
