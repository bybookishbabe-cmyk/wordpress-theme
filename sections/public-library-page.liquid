  }

  #sss-lib-{{ section.id }} .bbb-homeRecDemo__cta{
    margin-top:14px;
    color:#ffb8e0;
    font-size:12px;
    letter-spacing:.14em;
    text-transform:uppercase;
    font-weight:700;
  }

  #sss-lib-{{ section.id }} .bbb-homeRecDemo__stage{
    position:relative;
    min-height:235px;
  }

  #sss-lib-{{ section.id }} .bbb-homeRecDemo__book{
