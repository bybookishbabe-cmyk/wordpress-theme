    <nav class="blog-bigspecific-links" aria-label="specific related links">
      {% assign bigspecific_item_count = 0 %}
      {% if specific_guide_handles != blank %}
        {% assign preferred_guide_handles = specific_guide_handles | split: '|' %}
        {% for preferred_handle in preferred_guide_handles %}
          {% if preferred_handle != blank and guide_blog and bigspecific_item_count < 3 %}
            {% for post in guide_blog.articles %}
              {% if post.handle == preferred_handle %}
                <a href="{{ post.url }}">
                  <span class="blog-bigspecific-links__itemIcon" aria-hidden="true">📖</span>
                  <span>{{ post.title }}</span>
                </a>
                {% assign bigspecific_item_count = bigspecific_item_count | plus: 1 %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endfor %}
      {% endif %}
      {% if specific_page_handles != blank and bigspecific_item_count < 3 %}
        {% assign preferred_page_handles = specific_page_handles | split: '|' %}
        {% for preferred_page_handle in preferred_page_handles %}
          {% if preferred_page_handle != blank and bigspecific_item_count < 3 %}
            {% assign matched_page = pages[preferred_page_handle] %}
            {% if matched_page != blank %}
              {% assign matched_page_emoji = matched_page.metafields.custom.trope.value.emoji | default: matched_page.metafields.custom.shelf.value.emoji | default: matched_page.metafields.custom.genre.value.emoji | default: '📚' %}
              <a href="{{ matched_page.url }}">
                <span class="blog-bigspecific-links__itemIcon" aria-hidden="true">{{ matched_page_emoji }}</span>
                <span>{{ matched_page.title }}</span>
              </a>
              {% assign bigspecific_item_count = bigspecific_item_count | plus: 1 %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </nav>
  {% endcapture %}
{% endif %}

