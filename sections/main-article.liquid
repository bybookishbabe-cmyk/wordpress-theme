<script>
  (function() {
    function buildGuideBookList(cardWrap) {
      if (!cardWrap) return '';

      var guideTitle = cardWrap.dataset.guideTitle || document.title || 'romance guide';
      var books = Array.from(cardWrap.querySelectorAll('[data-book-preview]'));
      if (!books.length) return '';

      var text = 'books from ' + guideTitle + '\n\n';

      books.forEach(function(book, index) {
        var bookTitle = book.dataset.title || '';
        var author = book.dataset.author || '';
        var amazon = book.dataset.amazon || '';
        var bookshop = book.dataset.bookshop || '';

        text += (index + 1) + '. ' + bookTitle + '\n';

        if (author) {
          text += '   by ' + author + '\n';
        }

        if (amazon) {
          text += '   amazon: ' + amazon + '\n';
        }

        if (bookshop) {
          text += '   bookshop: ' + bookshop + '\n';
        }

        text += '\n';
      });

      return text;
    }

    function copyGuideBookList(text) {
      if (!text) return Promise.reject(new Error('No text to copy'));

      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text);
      }

      return new Promise(function(resolve, reject) {
        var textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'absolute';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();

        try {
          document.execCommand('copy');
          document.body.removeChild(textarea);
          resolve();
        } catch (error) {
          document.body.removeChild(textarea);
          reject(error);
        }
      });
    }

    document.querySelectorAll('[data-guide-export]').forEach(function(button) {
      button.addEventListener('click', function() {
        var cardWrap = button.closest('[data-guide-bookcard]');
        var text = buildGuideBookList(cardWrap);
        if (!text) return;

        copyGuideBookList(text).then(function() {
          button.textContent = 'saved ✨';

          window.setTimeout(function() {
            button.textContent = 'save this list';
          }, 2000);
        }).catch(function() {});
      });
    });

    document.querySelectorAll('[data-guide-export-inline]').forEach(function(button) {
      var exportWrap = button.closest('.article-inline-book-export');

      if (exportWrap) {
        exportWrap.classList.remove('article-inline-book-export--with-rule');
        var previous = exportWrap.previousElementSibling;

        while (previous) {
          if (/^H[1-6]$/.test(previous.tagName)) {
            var next = previous.nextElementSibling;

            if (next && next.tagName === 'HR') {
              next.parentNode.insertBefore(exportWrap, next);
              exportWrap.classList.add('article-inline-book-export--with-rule');
            } else {
              previous.insertAdjacentElement('afterend', exportWrap);
            }
            break;
          }

          previous = previous.previousElementSibling;
        }
      }

      button.addEventListener('click', function() {
        var guideTitle = button.dataset.guideTitle || document.title || 'romance guide';
        var content = button.closest('.article-template__content');
        if (!content) return;

        var books = Array.from(content.querySelectorAll('[data-book-preview]')).filter(function(item) {
          return !item.closest('[data-guide-bookcard]') && !item.closest('.sss-blog-library');
        });

        if (!books.length) return;

        var text = 'books from ' + guideTitle + '\n\n';

        books.forEach(function(book, index) {
          var bookTitle = book.dataset.title || '';
          var author = book.dataset.author || '';
          var amazon = book.dataset.amazon || '';
          var bookshop = book.dataset.bookshop || '';

          text += (index + 1) + '. ' + bookTitle + '\n';

          if (author) {
            text += '   by ' + author + '\n';
          }

          if (amazon) {
            text += '   amazon: ' + amazon + '\n';
          }

          if (bookshop) {
            text += '   bookshop: ' + bookshop + '\n';
          }

          text += '\n';
        });

        copyGuideBookList(text).then(function() {
          button.textContent = 'saved ✨';

          window.setTimeout(function() {
            button.textContent = 'save this list';
          }, 2000);
        }).catch(function() {});
      });
    });

    function getBlogShelf(){
      try {
        return JSON.parse(localStorage.getItem('sssMyShelf')) || [];
      } catch (e) {
        return [];
      }
    }

    function setBlogShelf(data){
      localStorage.setItem('sssMyShelf', JSON.stringify(data));
      localStorage.setItem('sssShelf', JSON.stringify(data));
      document.dispatchEvent(new CustomEvent('sss:bookshelf-updated', {
        detail: { count: Array.isArray(data) ? data.length : 0 }
      }));
    }

    function getBlogBookKey(card){
      if (!card) return '';
      return String(card.dataset.handle || card.dataset.title || '').trim().toLowerCase();
    }

    function buildBlogShelfBook(card){
      if (!card) return null;
      return {
        handle: card.dataset.handle || '',
        title: card.dataset.title || '',
        author: card.dataset.author || '',
        cover: card.dataset.cover || '',
        amazon: card.dataset.amazon || '',
        bookshop: card.dataset.bookshop || ''
      };
    }

    function isBlogBookSaved(card){
      var key = getBlogBookKey(card);
      if (!key) return false;

      return getBlogShelf().some(function(item){
        var itemKey = String(item.handle || item.title || '').trim().toLowerCase();
        return itemKey && itemKey === key;
      });
    }

    function syncBlogBookHearts(){
      document.querySelectorAll('[data-blog-heart]').forEach(function(heart){
        var card = heart.closest('[data-book-preview]');
        if (!card) return;

        var isSaved = isBlogBookSaved(card);
        heart.classList.toggle('is-saved', isSaved);
        var icon = heart.querySelector('.article-book-card__heartIcon');
        var label = heart.querySelector('.article-book-card__heartLabel');
        if (icon) icon.textContent = isSaved ? '♥' : '♡';
        if (label) label.textContent = isSaved ? 'saved' : 'save';
        heart.setAttribute('aria-label', isSaved ? 'remove from your bookshelf' : 'save to your bookshelf');
      });
    }

    document.querySelectorAll('[data-blog-heart]').forEach(function(heart){
      if (heart.dataset.heartBound === 'true') return;
      heart.dataset.heartBound = 'true';

      heart.addEventListener('click', function(e){
        e.preventDefault();
        e.stopPropagation();

        var card = heart.closest('[data-book-preview]');
        var book = buildBlogShelfBook(card);
        if (!book || !book.title) return;

        var shelf = getBlogShelf();
        var key = getBlogBookKey(card);
        var exists = shelf.some(function(item){
          var itemKey = String(item.handle || item.title || '').trim().toLowerCase();
          return itemKey && itemKey === key;
        });

        if (exists){
          shelf = shelf.filter(function(item){
            var itemKey = String(item.handle || item.title || '').trim().toLowerCase();
            return itemKey !== key;
          });
        } else {
          shelf.push(book);
          document.dispatchEvent(new CustomEvent('bbb:shelf-saved', {
            detail: {
              count: shelf.length,
              bookTitle: book.title || '',
              bookHandle: book.handle || '',
              source: document.body.dataset.template || 'blog'
            }
          }));
        }

        setBlogShelf(shelf);
        syncBlogBookHearts();
      });
    });

    syncBlogBookHearts();
  })();

</script>

{% if has_pillar %}
<div id="sssBackToTop" class="blog-pillar-backtop">
  <button class="sss-lib__backTopBtn" type="button" aria-label="Back to top">↑</button>
</div>

<script>
  (function() {
    var backTopWrap = document.getElementById('sssBackToTop');
    if (!backTopWrap || !backTopWrap.classList.contains('blog-pillar-backtop')) return;

    var backTopBtn = backTopWrap.querySelector('.sss-lib__backTopBtn');

    function updateBackTopVisibility() {
      var scrollTop = window.scrollY || window.pageYOffset || 0;
      var doc = document.documentElement;
      var scrollableHeight = doc.scrollHeight - window.innerHeight;

      if (scrollableHeight <= 0) {
        backTopWrap.classList.remove('is-visible');
        return;
      }

      backTopWrap.classList.toggle('is-visible', scrollTop >= 360 || (scrollTop / scrollableHeight) >= 0.16);
    }

    if (backTopBtn) {
      backTopBtn.addEventListener('click', function() {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }

    window.addEventListener('scroll', updateBackTopVisibility, { passive: true });
    window.addEventListener('resize', updateBackTopVisibility);
    updateBackTopVisibility();
  })();
</script>
{% endif %}

