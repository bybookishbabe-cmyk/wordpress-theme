    {% if faq_section contains '[/faq]' %}
      {% assign faq_parts = faq_section | split: '[/faq]' %}
      {% assign faq_body = faq_parts.first %}
      {% capture faq_after %}
        {% for faq_after_part in faq_parts offset: 1 %}
          {% unless forloop.first %}[/faq]{% endunless %}{{ faq_after_part }}
        {% endfor %}
      {% endcapture %}

      {% capture rendered_faq %}
        <section class="blog-faq" aria-label="frequently asked questions">
          <div class="blog-faq__kicker">questions readers ask</div>
          <h2 class="blog-faq__title">frequently asked questions</h2>
          <div class="blog-faq__list">
            {% assign faq_items = faq_body | split: '[q]' %}
            {% for faq_item in faq_items offset: 1 %}
              {% if faq_item contains '[/q]' and faq_item contains '[a]' and faq_item contains '[/a]' %}
                {% assign question_split = faq_item | split: '[/q]' %}
                {% assign faq_question = question_split.first | strip_html | strip %}
                {% capture answer_source %}
                  {% for answer_source_part in question_split offset: 1 %}
                    {% unless forloop.first %}[/q]{% endunless %}{{ answer_source_part }}
                  {% endfor %}
                {% endcapture %}
                {% assign answer_split = answer_source | split: '[a]' %}
                {% assign answer_chunk = '' %}
                {% for answer_part in answer_split offset: 1 %}
                  {% if forloop.first %}
                    {% assign answer_chunk = answer_part %}
                  {% endif %}
                {% endfor %}
                {% assign faq_answer = answer_chunk | split: '[/a]' | first | strip %}
                {% if faq_question != blank and faq_answer != blank %}
                  <details class="blog-faq__item">
                    <summary class="blog-faq__question">
                      <span>{{ faq_question }}</span>
                      <span class="blog-faq__arrow" aria-hidden="true">⌄</span>
                    </summary>
                    <div class="blog-faq__answer">
                      {{ faq_answer }}
                    </div>
                  </details>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
        </section>
      {% endcapture %}

      {% capture rebuilt_faq_content %}{{ rebuilt_faq_content }}{{ rendered_faq }}{{ faq_after }}{% endcapture %}
    {% else %}
      {% capture rebuilt_faq_content %}{{ rebuilt_faq_content }}[faq]{{ faq_section }}{% endcapture %}
    {% endif %}
  {% endfor %}

  {% assign content = rebuilt_faq_content %}
{% endif %}
