{%- assign now_ts = 'now' | date: '%s' | plus: 0 -%}
{%- assign current_issue = nil -%}
{%- assign current_issue_ts = 0 -%}
{%- for issue in shop.metaobjects.newsletter_issue.values -%}
  {%- if issue.publish_date.value == blank -%}
    {%- continue -%}
  {%- endif -%}
  {%- assign issue_ts = issue.publish_date.value | date: '%s' | plus: 0 -%}
  {%- assign live_ts = issue_ts | plus: 36000 -%}
  {%- if live_ts <= now_ts and issue_ts >= current_issue_ts -%}
    {%- assign current_issue = issue -%}
    {%- assign current_issue_ts = issue_ts -%}
  {%- endif -%}
{%- endfor -%}

{%- assign obsession_book = nil -%}
{%- assign obsession_trope_one = blank -%}
{%- assign obsession_trope_two = blank -%}
{%- assign obsession_url = '/pages/weekly-obsession' -%}
{%- if current_issue != nil -%}
  {%- assign obsession_book = current_issue.book.value -%}
  {%- if obsession_book == blank -%}
    {%- assign obsession_book = current_issue.library_book.value -%}
  {%- endif -%}
{%- endif -%}
{%- if obsession_book != blank and obsession_book.tropes.value != blank -%}
  {%- for obsession_trope in obsession_book.tropes.value limit: 2 -%}
    {%- if forloop.first -%}
      {%- assign obsession_trope_one = obsession_trope -%}
    {%- elsif forloop.index == 2 -%}
      {%- assign obsession_trope_two = obsession_trope -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign has_pillar = false -%}
{%- if article.content contains '[pillar]' or article.content contains '[Pillar]' or article.content contains '[PILLAR]' or article.content contains '[pillarnav]' or article.content contains '[Pillarnav]' or article.content contains '[PILLARNAV]' or article.content contains '[pillar nav]' or article.content contains '[Pillar Nav]' or article.content contains '[PILLAR NAV]' -%}
  {%- assign has_pillar = true -%}
{%- endif -%}

<article class="article-template">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when '@app' -%}
        <div class="page-width page-width--narrow">
          {% render block %}
        </div>
      {%- when 'featured_image' -%}

  {% assign books = shop.metaobjects.sss_library.values %}
  {% assign hero_count = 0 %}

  <div class="article-template__hero-container">

    <div class="sss-article-hero">

      <div class="sss-article-hero__collage">

        {% for book in books %}
          {% capture is_visible %}{% render 'sss-book-visible', book: book %}{% endcapture %}
          {% assign is_visible_value = is_visible | strip %}
          {% unless is_visible_value == 'true' %}
            {% continue %}
          {% endunless %}
          {% if book.shelf_categories.value == "morally gray lovers" and hero_count < 3 %}

            {% assign hero_count = hero_count | plus: 1 %}

            {% assign cover_url = '' %}
            {% if book.cover.value != blank %}
              {% if book.cover.value.url != blank %}
                {% assign cover_url = book.cover.value.url %}
              {% else %}
                {% assign cover_url = book.cover.value %}
              {% endif %}
            {% endif %}

            {% if cover_url != blank %}
              <div class="sss-article-hero__book book-{{ hero_count }}">
                <img 
                  src="{{ cover_url }}" 
                  alt="{{ book.title.value | escape }}"
                  loading="eager"
                >
              </div>
            {% endif %}

          {% endif %}
        {% endfor %}

      </div>

      <div class="sss-article-hero__title">
        <h1>{{ article.title }}</h1>
      </div>
      <p>articles count: {{ blog.articles_count }}</p>

    </div>

  </div>

      {%- when 'title' -%}
        <header
          class="page-width page-width--narrow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
          {{ block.shopify_attributes }}
        >
          <h1
            class="article-template__title"
          >
            {{ article.title | escape }}
          </h1>
          {%- if block.settings.blog_show_date -%}
            <span class="circle-divider caption-with-letter-spacing">
              {{- article.published_at | time_tag: format: 'date' -}}
            </span>
          {%- endif -%}
          {%- if block.settings.blog_show_author -%}
            <span class="caption-with-letter-spacing">
              <span>{{ article.author }}</span>
            </span>
          {%- endif -%}
        </header>




{%- when 'content' -%}

<div class="article-template__content page-width page-width--narrow rte">
{% assign content = article.content %}
{% assign books = article.metafields.custom.book.value %}
{% assign article_trope = article.metafields.custom.trope.value %}
{% assign article_series = article.metafields.custom.sss_series.value | default: article.metafields.custom.series.value %}
{% capture inline_export_button %}
<div class="article-inline-book-export">
  <button
    type="button"
    class="sss-lib__exportBtn guide-bookcard__export"
    data-guide-export-inline
    data-guide-title="{{ article.title | escape }}"
  >
    save this list
  </button>
  <div class="guide-bookcard__affiliate-note">
    some links may be affiliate links, so thank you for supporting the recs. <3
  </div>
</div>
{% endcapture %}

{% if article_trope != blank and article_trope.name == blank %}
  {% assign article_trope_first = article_trope | first %}
  {% if article_trope_first != blank %}
    {% assign article_trope = article_trope_first %}
  {% endif %}
{% endif %}

{% assign guide_category_value = article.metafields.custom.guide_category.value %}
{% assign guide_category_label = guide_category_value.name.value | default: guide_category_value.name | default: guide_category_value.title.value | default: guide_category_value.title | default: guide_category_value | default: '' %}
{% assign guide_category_handle = guide_category_value.system.handle | default: guide_category_label | handleize %}

{% assign pillar_label = guide_category_label %}
{% if pillar_label == blank and article_trope != blank %}
  {% assign pillar_label = article_trope.name | default: article_trope %}
{% endif %}

{% capture weekly_obsession_banner %}
{% if obsession_trope_one != blank %}
<a class="blog-obsession-banner blog-obsession-banner--article" href="{{ obsession_url }}" aria-label="see this week's weekly obsession">
  <p class="blog-obsession-banner__text">
    see the book everyone is talking about...
    think
    <span class="blog-obsession-banner__trope">
      {%- if obsession_trope_one.emoji != blank -%}<span class="blog-obsession-banner__tropeEmoji">{{ obsession_trope_one.emoji }}</span>{%- endif -%}
      {{ obsession_trope_one.name }}
    </span>
    {%- if obsession_trope_two != blank -%}
      and
      <span class="blog-obsession-banner__trope">
        {%- if obsession_trope_two.emoji != blank -%}<span class="blog-obsession-banner__tropeEmoji">{{ obsession_trope_two.emoji }}</span>{%- endif -%}
        {{ obsession_trope_two.name }}
      </span>
    {%- endif -%}
    <span class="blog-obsession-banner__cta">see the weekly obsession</span>
  </p>
</a>
{% endif %}
{% endcapture %}

{% assign next_read_first_cover = '' %}
{% assign next_read_first_title = '' %}
{% assign next_read_second_cover = '' %}
{% assign next_read_second_title = '' %}
{% assign next_read_anchor_handle = '' %}
{% assign next_read_anchor_title = '' %}
{% assign next_read_anchor_shelf_handle = '' %}
{% assign next_read_anchor_shelf_name = '' %}
{% assign next_read_anchor_spice = 0 %}
{% assign next_read_anchor_trope_handles = '|' %}
{% assign next_read_context = guide_category_label | default: '' %}
{% if next_read_context == blank and article_trope != blank %}
  {% assign next_read_context = article_trope.name | default: article_trope %}
{% endif %}
{% if next_read_context == blank %}
  {% assign next_read_context = 'romance' %}
{% endif %}

{% if books != blank %}
  {% assign first_linked_book = books | first %}
  {% if first_linked_book != blank %}
    {% assign next_read_first_cover = first_linked_book.cover.value.url %}
    {% if next_read_first_cover == blank %}
      {% assign first_cover_value = first_linked_book.cover.value | append: '' %}
      {% if first_cover_value contains 'http' or first_cover_value contains '//' %}
        {% assign next_read_first_cover = first_cover_value %}
      {% endif %}
    {% endif %}
    {% assign next_read_first_title = first_linked_book.title.value | default: first_linked_book.title %}
    {% assign next_read_anchor_handle = first_linked_book.system.handle | default: '' %}
    {% assign next_read_anchor_title = next_read_first_title | strip | downcase %}
    {% assign next_read_anchor_shelf_handle = first_linked_book.shelf.value.system.handle | default: first_linked_book.shelf.value.name | handleize %}
    {% assign next_read_anchor_shelf_name = first_linked_book.shelf.value.name | default: '' | strip | downcase %}
    {% assign next_read_anchor_spice = first_linked_book.spice_level.value | default: 0 | plus: 0 %}
    {% for linked_trope in first_linked_book.tropes.value %}
      {% assign linked_trope_handle = linked_trope.system.handle | default: linked_trope.name | handleize %}
      {% assign next_read_anchor_trope_handles = next_read_anchor_trope_handles | append: linked_trope_handle | append: '|' %}
    {% endfor %}
  {% endif %}
{% endif %}

{% if next_read_first_cover != blank and next_read_second_cover == blank %}
  {% for library_book in shop.metaobjects.sss_library.values %}
    {% capture is_visible %}{% render 'sss-book-visible', book: library_book %}{% endcapture %}
    {% assign is_visible_value = is_visible | strip %}
    {% unless is_visible_value == 'true' %}
      {% continue %}
    {% endunless %}

    {% assign library_book_handle = library_book.system.handle | default: '' %}
    {% assign library_book_title = library_book.title.value | default: library_book.title | strip | downcase %}
    {% if library_book_handle != blank and library_book_handle == next_read_anchor_handle %}
      {% continue %}
    {% endif %}
    {% if library_book_title != blank and library_book_title == next_read_anchor_title %}
      {% continue %}
    {% endif %}

    {% assign series_number_text = library_book.series_number.value | append: '' | strip %}
    {% if library_book.series.value != blank and library_book.read_as_standalone.value != true and series_number_text != blank and series_number_text != '1' %}
      {% continue %}
    {% endif %}

    {% assign library_book_spice = library_book.spice_level.value | default: 0 | plus: 0 %}
    {% assign spice_diff = library_book_spice | minus: next_read_anchor_spice | abs %}
    {% assign library_shelf_handle = library_book.shelf.value.system.handle | default: library_book.shelf.value.name | handleize %}
    {% assign library_shelf_name = library_book.shelf.value.name | default: '' | strip | downcase %}
    {% assign shelf_match = false %}
    {% if next_read_anchor_shelf_handle != blank and library_shelf_handle == next_read_anchor_shelf_handle %}
      {% assign shelf_match = true %}
    {% elsif next_read_anchor_shelf_name != blank and library_shelf_name == next_read_anchor_shelf_name %}
      {% assign shelf_match = true %}
    {% endif %}

    {% assign trope_match = false %}
    {% for linked_trope in library_book.tropes.value %}
      {% assign linked_trope_handle = linked_trope.system.handle | default: linked_trope.name | handleize %}
      {% assign linked_trope_token = '|' | append: linked_trope_handle | append: '|' %}
      {% if next_read_anchor_trope_handles contains linked_trope_token %}
        {% assign trope_match = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% assign guide_match = false %}
    {% if guide_category_handle != blank %}
      {% assign guide_category_name_downcase = guide_category_label | default: '' | strip | downcase %}
      {% if library_shelf_handle == guide_category_handle or library_shelf_name == guide_category_name_downcase %}
        {% assign guide_match = true %}
      {% endif %}
      {% unless guide_match %}
        {% for linked_trope in library_book.tropes.value %}
          {% assign linked_trope_handle = linked_trope.system.handle | default: linked_trope.name | handleize %}
          {% assign linked_trope_name = linked_trope.name | default: '' | strip | downcase %}
          {% if linked_trope_handle == guide_category_handle or linked_trope_name == guide_category_name_downcase %}
            {% assign guide_match = true %}
            {% break %}
          {% endif %}
        {% endfor %}
      {% endunless %}
    {% endif %}

    {% unless trope_match or shelf_match or guide_match %}
      {% continue %}
    {% endunless %}
    {% if next_read_anchor_spice > 0 and library_book_spice > 0 and spice_diff > 1 and trope_match == false %}
      {% continue %}
    {% endif %}

    {% assign cover_url = library_book.cover.value.url %}
    {% if cover_url == blank %}
      {% assign cover_value = library_book.cover.value | append: '' %}
      {% if cover_value contains 'http' or cover_value contains '//' %}
        {% assign cover_url = cover_value %}
      {% endif %}
    {% endif %}

    {% if cover_url != blank and cover_url != next_read_first_cover %}
      {% assign next_read_second_cover = cover_url %}
      {% assign next_read_second_title = library_book.title.value | default: library_book.title %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if next_read_first_cover == blank and guide_category_handle != blank %}
  {% for library_book in shop.metaobjects.sss_library.values %}
    {% capture is_visible %}{% render 'sss-book-visible', book: library_book %}{% endcapture %}
    {% assign is_visible_value = is_visible | strip %}
    {% unless is_visible_value == 'true' %}
      {% continue %}
    {% endunless %}

    {% assign category_match = false %}
    {% assign book_shelf_handle = library_book.shelf.value.system.handle | default: library_book.shelf.value.name | handleize %}
    {% assign book_shelf_name = library_book.shelf.value.name | default: '' | strip | downcase %}
    {% assign guide_category_name_downcase = guide_category_label | default: '' | strip | downcase %}

    {% if book_shelf_handle == guide_category_handle or book_shelf_name == guide_category_name_downcase %}
      {% assign category_match = true %}
    {% endif %}

    {% unless category_match %}
      {% for linked_trope in library_book.tropes.value %}
        {% assign linked_trope_handle = linked_trope.system.handle | default: linked_trope.name | handleize %}
        {% assign linked_trope_name = linked_trope.name | default: '' | strip | downcase %}
        {% if linked_trope_handle == guide_category_handle or linked_trope_name == guide_category_name_downcase %}
          {% assign category_match = true %}
          {% break %}
        {% endif %}
      {% endfor %}
    {% endunless %}

    {% unless category_match %}
      {% continue %}
    {% endunless %}

    {% assign series_number_text = library_book.series_number.value | append: '' | strip %}
    {% if library_book.series.value != blank and library_book.read_as_standalone.value != true and series_number_text != blank and series_number_text != '1' %}
      {% continue %}
    {% endif %}

    {% assign cover_url = library_book.cover.value.url %}
    {% if cover_url == blank %}
      {% assign cover_value = library_book.cover.value | append: '' %}
      {% if cover_value contains 'http' or cover_value contains '//' %}
        {% assign cover_url = cover_value %}
      {% endif %}
    {% endif %}

    {% if cover_url != blank %}
      {% if next_read_first_cover == blank %}
        {% assign next_read_first_cover = cover_url %}
        {% assign next_read_first_title = library_book.title.value | default: library_book.title %}
      {% elsif next_read_second_cover == blank and cover_url != next_read_first_cover %}
        {% assign next_read_second_cover = cover_url %}
        {% assign next_read_second_title = library_book.title.value | default: library_book.title %}
        {% break %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if next_read_first_cover == blank and article_trope != blank %}
  {% for library_book in shop.metaobjects.sss_library.values %}
    {% capture is_visible %}{% render 'sss-book-visible', book: library_book %}{% endcapture %}
    {% assign is_visible_value = is_visible | strip %}
    {% unless is_visible_value == 'true' %}
      {% continue %}
    {% endunless %}
    {% assign trope_match = false %}
    {% for linked_trope in library_book.tropes.value %}
      {% if linked_trope.system.handle == article_trope.system.handle %}
        {% assign trope_match = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% unless trope_match %}
      {% continue %}
    {% endunless %}
    {% assign cover_url = library_book.cover.value.url %}
    {% if cover_url == blank %}
      {% assign cover_value = library_book.cover.value | append: '' %}
      {% if cover_value contains 'http' or cover_value contains '//' %}
        {% assign cover_url = cover_value %}
      {% endif %}
    {% endif %}
    {% if cover_url != blank %}
      {% if next_read_first_cover == blank %}
        {% assign next_read_first_cover = cover_url %}
        {% assign next_read_first_title = library_book.title.value | default: library_book.title %}
      {% elsif next_read_second_cover == blank %}
        {% assign next_read_second_cover = cover_url %}
        {% assign next_read_second_title = library_book.title.value | default: library_book.title %}
        {% break %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if next_read_first_cover == blank and obsession_book != blank %}
  {% assign next_read_first_cover = obsession_book.cover.value.url %}
  {% if next_read_first_cover == blank %}
    {% assign obsession_first_cover_value = obsession_book.cover.value | append: '' %}
    {% if obsession_first_cover_value contains 'http' or obsession_first_cover_value contains '//' %}
      {% assign next_read_first_cover = obsession_first_cover_value %}
    {% endif %}
  {% endif %}
  {% assign next_read_first_title = obsession_book.title.value | default: obsession_book.title %}
{% endif %}

{% if next_read_second_cover == blank and obsession_book != blank %}
  {% assign obsession_cover_url = obsession_book.cover.value.url %}
  {% if obsession_cover_url == blank %}
    {% assign obsession_second_cover_value = obsession_book.cover.value | append: '' %}
    {% if obsession_second_cover_value contains 'http' or obsession_second_cover_value contains '//' %}
      {% assign obsession_cover_url = obsession_second_cover_value %}
    {% endif %}
  {% endif %}
  {% if obsession_cover_url != blank and obsession_cover_url != next_read_first_cover %}
    {% assign next_read_second_cover = obsession_cover_url %}
    {% assign next_read_second_title = obsession_book.title.value | default: obsession_book.title %}
  {% endif %}
{% endif %}

{% capture what_to_read_next_cta %}
<a class="blog-next-read blog-next-read--article" href="https://bybookishbabe.com/pages/what-to-read-next" aria-label="find your next {{ next_read_context | escape }} read">
  {% if next_read_first_cover != blank or next_read_second_cover != blank %}
    <span class="blog-next-read__stage" aria-hidden="true">
      {% if next_read_first_cover != blank %}
        <span class="blog-next-read__book">
          <span class="blog-next-read__bookCover">
            <img src="{{ next_read_first_cover }}" alt="{{ next_read_first_title | escape }}" loading="lazy">
          </span>
          <span class="blog-next-read__bookLabel">start here</span>
        </span>
      {% endif %}
      <span class="blog-next-read__arrow">→</span>
      {% if next_read_second_cover != blank %}
        <span class="blog-next-read__book">
          <span class="blog-next-read__bookCover">
            <img src="{{ next_read_second_cover }}" alt="{{ next_read_second_title | escape }}" loading="lazy">
          </span>
          <span class="blog-next-read__bookLabel">try next</span>
        </span>
      {% endif %}
    </span>
  {% endif %}
  <span class="blog-next-read__copy">find your next {{ next_read_context | escape }} read →</span>
</a>
{% endcapture %}

