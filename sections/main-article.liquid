<style>
  .blog-quickstats{
    margin:3rem 0;
    padding:1.4rem;
    border:1px solid rgba(255,138,199,.28);
    border-radius:2rem;
    background:
      linear-gradient(180deg, rgba(255,138,199,.08), rgba(255,255,255,.025)),
      #0d0b0c;
    box-shadow:0 1.8rem 4rem rgba(0,0,0,.22);
    color:#f6f6f6;
  }

  .blog-quickstats__head{
    margin-bottom:1rem;
    padding-bottom:.9rem;
    border-bottom:1px solid rgba(255,255,255,.1);
  }

  .blog-quickstats__kicker{
    margin:0;
    font-size:clamp(2.1rem, 3.2vw, 3.4rem);
    line-height:1.05;
    letter-spacing:0;
    text-transform:none;
    color:#ff9ccb;
  }

  .blog-quickstats__list{
    display:grid;
    grid-template-columns:repeat(3, minmax(0, 1fr));
    gap:.55rem;
    margin:0;
  }

  .blog-quickstats__row{
    min-width:0;
    padding:.85rem .95rem;
    border:1px solid rgba(255,255,255,.1);
    border-radius:1.4rem;
    background:rgba(255,255,255,.035);
  }

  .blog-quickstats__row--wide{
    grid-column:1 / -1;
  }

  .blog-quickstats dt{
    margin:0 0 .28rem;
    font-size:.78rem;
    letter-spacing:.11em;
    text-transform:uppercase;
    color:rgba(255,255,255,.55);
  }

  .blog-quickstats dd{
    margin:0;
    font-size:1.08rem;
    line-height:1.28;
    color:#f7f1f4;
  }

  .blog-quickstats__availability{
    display:inline-flex;
    align-items:center;
    gap:.32rem;
    font-weight:800;
  }

  .blog-quickstats__availability--yes{
    color:#74e0a4;
  }

  .blog-quickstats__availability--no{
    color:#ff7f8f;
  }

  .blog-quickstats__scale,
  .blog-quickstats__dot{
    color:rgba(255,255,255,.5);
  }

  .blog-quickstats__dot{
    display:inline-block;
    margin:0 .45rem;
  }

  .blog-obsession-banner{
    display:block;
    margin:0 0 28px;
    padding:16px 18px;
    border:1px solid rgba(255,255,255,.1);
    border-radius:18px;
    background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
    box-shadow:0 12px 30px rgba(0,0,0,.16);
    text-decoration:none;
    color:inherit;
    position:relative;
    overflow:hidden;
    transition:transform .32s ease, border-color .32s ease, box-shadow .32s ease;
    animation:blogObsessionFloat 4.8s ease-in-out infinite;
  }

  .blog-obsession-banner::after{
    content:"";
    position:absolute;
    top:-30%;
    left:-18%;
    width:40%;
    height:180%;
    background:linear-gradient(90deg, rgba(255,255,255,0), rgba(255,170,214,.12), rgba(255,255,255,0));
    transform:rotate(14deg);
    animation:blogObsessionShimmer 5.2s ease-in-out infinite;
    pointer-events:none;
  }

  .blog-obsession-banner--article{
    margin-top:8px;
  }

  .blog-obsession-banner__eyebrow{
    margin:0 0 8px;
    font-size:11px;
    letter-spacing:.18em;
    text-transform:uppercase;
    color:rgba(246,246,246,.6);
  }

  .blog-obsession-banner__text{
    margin:0;
    font-size:clamp(1.5rem, 2vw, 1.9rem);
    line-height:1.45;
    color:#f6f6f6;
    font-family:"Cormorant Garamond", Georgia, serif;
  }

  .blog-obsession-banner__trope{
    display:inline-block;
    margin:0 .15em;
    padding:0;
