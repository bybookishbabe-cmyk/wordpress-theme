{% for newsletter_issue in shop.metaobjects.newsletter_issue.values %}
  {% capture issue_preview %}
    {% render 'blog-newsletter-preview', issue: newsletter_issue %}
  {% endcapture %}

  {% assign issue_handle_token = '[newsletter:' | append: newsletter_issue.system.handle | append: ']' %}
  {% assign content = content | replace: issue_handle_token, issue_preview %}

  {% if newsletter_issue.url.value != blank %}
    {% assign issue_url = newsletter_issue.url.value.url | default: newsletter_issue.url.value %}
