              <span class="blog-specific-links__itemIcon" aria-hidden="true">📖</span>
              <span>{{ linked_article.title }}</span>
            </a>
            {% assign specific_item_count = specific_item_count | plus: 1 %}
          {% endif %}
        {% endfor %}
        {% for linked_page in specific_page_links_override %}
          {% if linked_page != blank %}
            {% assign linked_page_emoji = linked_page.metafields.custom.trope.value.emoji | default: linked_page.metafields.custom.shelf.value.emoji | default: linked_page.metafields.custom.genre.value.emoji | default: '📚' %}
            {% if specific_item_count > 0 %}<span aria-hidden="true">·</span>{% endif %}
            <a href="{{ linked_page.url }}">
              <span class="blog-specific-links__itemIcon" aria-hidden="true">{{ linked_page_emoji }}</span>
              <span>{{ linked_page.title }}</span>
            </a>
            {% assign specific_item_count = specific_item_count | plus: 1 %}
          {% endif %}
        {% endfor %}
      </span>
    </nav>
  {% endif %}
{% endcapture %}
{% capture bigspecific_links_custom %}
