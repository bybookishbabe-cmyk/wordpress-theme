      min-width: 0;
    }

    #bbb-next-{{ section.id }} .bbb-next__explore {
      overflow-x: clip;
    }

    #bbb-next-{{ section.id }} .bbb-next__explore .sss-you-might-like {
      max-width: 100%;
      overflow-x: clip;
    }

    #bbb-next-{{ section.id }} .bbb-next__explore .sss-you-might-like__grid {
      max-width: 100%;
    }

    #bbb-next-{{ section.id }} .bbb-next__searchPick {
      appearance: none;
      border: 1px solid rgba(255,255,255,.1);
      background: rgba(255,255,255,.03);
      border-radius: 18px;
      padding: 10px;
      color: #fff;
      text-align: left;
      cursor: pointer;
      transition: border-color .18s ease, background .18s ease, transform .18s ease;
    }

    #bbb-next-{{ section.id }} .bbb-next__searchPick:hover {
      border-color: rgba(255,62,165,.42);
      background: rgba(255,62,165,.1);
      transform: translateY(-1px);
    }

    #bbb-next-{{ section.id }} .bbb-next__searchPick img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      border-radius: 12px;
      display: block;
    }

    #bbb-next-{{ section.id }} .bbb-next__searchPickTitle {
      display: block;
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.4;
      text-transform: lowercase;
    }

    #bbb-next-{{ section.id }} .bbb-next__searchPickMeta {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      color: rgba(246,246,246,.6);
      text-transform: lowercase;
    }

    #bbb-next-{{ section.id }} .bbb-next__searchEmpty {
      grid-column: 1 / -1;
      font-size: 13px;
      color: rgba(246,246,246,.62);
      text-transform: lowercase;
    }

    #bbb-next-{{ section.id }} .bbb-next__debug {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 16px;
      border: 1px dashed rgba(255, 138, 199, 0.32);
      background: rgba(255, 138, 199, 0.06);
    }

    #bbb-next-{{ section.id }} .bbb-next__debugLabel {
      font-size: 10px;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: rgba(255, 184, 224, 0.9);
    }

    #bbb-next-{{ section.id }} .bbb-next__debugCount {
      margin-top: 8px;
      color: #fff;
      font-size: 14px;
      line-height: 1.5;
    }

    #bbb-next-{{ section.id }} .bbb-next__debugList {
      margin-top: 8px;
      color: rgba(246,246,246,.72);
      font-size: 12px;
      line-height: 1.6;
    }

    #bbb-next-{{ section.id }} .bbb-next__resultsHead {
      margin-top: 10px;
      text-align: center;
      max-width: 60ch;
      margin-left: auto;
      margin-right: auto;
    }

    #bbb-next-{{ section.id }} .bbb-next__title,
    #bbb-next-{{ section.id }} .bbb-next__resultsTitle,
    #bbb-next-{{ section.id }} .bbb-next__sourceTitle,
    #bbb-next-{{ section.id }} .bbb-next__cardTitle {
      color: #f6f6f6;
    }

    #bbb-next-{{ section.id }} .bbb-next__cardMeta,
    #bbb-next-{{ section.id }} .bbb-next__sourceMeta {
      color: #ffb8e0;
    }

    @media screen and (max-width: 989px) {
      #bbb-next-{{ section.id }} .bbb-next__panel,
      #bbb-next-{{ section.id }} .bbb-next__cards {
        grid-template-columns: 1fr;
      }
    }

    @media screen and (min-width: 750px) and (max-width: 989px) {
      #bbb-next-{{ section.id }} .sss-tropeTop {
        grid-template-columns: 1fr;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchPanel {
        width: min(94vw, 860px);
        padding: 24px 22px 22px;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchResults {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        max-height: 50vh;
      }
    }

    @media screen and (max-width: 749px) {
      #bbb-next-{{ section.id }} .sss-tropeTop {
        grid-template-columns: 1fr;
        gap: 14px;
      }

      #bbb-next-{{ section.id }} .sss-tropeTop__left,
      #bbb-next-{{ section.id }} .sss-tropeTop__right {
        max-width: 100%;
        width: 100%;
      }

      #bbb-next-{{ section.id }} .sss-tropeTop__right {
        justify-content: flex-start;
      }

      #bbb-next-{{ section.id }} .bbb-next__hero {
        padding-bottom: 0;
        text-align: center;
      }

      #bbb-next-{{ section.id }} .bbb-next__title {
        font-size: clamp(2.6rem, 11vw, 3.2rem);
        margin-bottom: 10px;
      }

      #bbb-next-{{ section.id }} .bbb-next__sub {
        margin-top: 0;
        max-width: 22ch;
        margin-left: auto;
        margin-right: auto;
      }

      #bbb-next-{{ section.id }} .sss-trope__divider {
        margin: 0;
      }

      #bbb-next-{{ section.id }} .bbb-next__societyInvite {
        display: none;
      }

      #bbb-next-{{ section.id }} .bbb-next__mobileInvite {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin: 0 0 8px;
        padding: 8px 10px;
        border-radius: 14px;
        border: 1px solid rgba(255, 138, 199, 0.22);
        background: rgba(255, 138, 199, 0.08);
        color: #f6f6f6;
        text-decoration: none;
      }

      #bbb-next-{{ section.id }} .bbb-next__mobileInviteCopy {
        display: block;
        min-width: 0;
        font-size: 10px;
        line-height: 1.35;
        color: rgba(246,246,246,.78);
      }

      #bbb-next-{{ section.id }} .bbb-next__mobileInviteCta {
        flex-shrink: 0;
        font-size: 9px;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #ffb8e0;
      }

      #bbb-next-{{ section.id }} .bbb-next__panel {
        gap: 14px;
        padding: 14px;
        margin-top: 0;
        border-radius: 16px;
      }

      #bbb-next-{{ section.id }} .bbb-next__pickerLabel {
        margin-bottom: 8px;
        font-size: 12px;
      }

      #bbb-next-{{ section.id }} .bbb-next__select {
        padding: 16px 18px;
        font-size: 15px;
      }

      #bbb-next-{{ section.id }} .bbb-next__selectBtn {
        min-height: 56px;
      }

      #bbb-next-{{ section.id }} .bbb-next__selectBtn::after {
        font-size: 10px;
      }

      #bbb-next-{{ section.id }} .bbb-next__source,
      #bbb-next-{{ section.id }} .bbb-next__cardInner {
        grid-template-columns: 1fr;
      }

      #bbb-next-{{ section.id }} .bbb-next__sourceCoverWrap,
      #bbb-next-{{ section.id }} .bbb-next__cardCoverWrap {
        max-width: 180px;
      }

      #bbb-next-{{ section.id }} .bbb-next__cardPill {
        padding: 10px 14px;
        font-size: 0.88rem;
        letter-spacing: 0.12em;
      }

      #bbb-next-{{ section.id }} .bbb-next__cardMood {
        font-size: 23px;
        min-height: 0;
      }

      #bbb-next-{{ section.id }} .bbb-next__statusRow {
        gap: 12px;
        margin-top: 16px;
        margin-bottom: 12px;
      }

      #bbb-next-{{ section.id }} .bbb-next__statusCheck {
        gap: 10px;
        min-height: 34px;
        font-size: 13px;
      }

      #bbb-next-{{ section.id }} .bbb-next__statusBox {
        width: 18px;
        height: 18px;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchPanel {
        width: min(94vw, 520px);
        margin: 4vh auto 0;
        padding: 18px 14px 16px;
        max-height: 88vh;
        overflow-x: hidden;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchTitle {
        font-size: 24px;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchInput {
        margin-top: 12px;
        min-height: 42px;
        border-radius: 14px;
        padding: 0 14px;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchResults {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 6px;
        max-height: 42vh;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchPick {
        padding: 6px;
        border-radius: 12px;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchPick img {
        border-radius: 8px;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchPickTitle {
        margin-top: 6px;
        font-size: 10px;
        line-height: 1.2;
      }

      #bbb-next-{{ section.id }} .bbb-next__searchPickMeta {
        display: none;
      }
    }
  </style>
</section>
{% endpaginate %}

