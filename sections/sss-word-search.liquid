{% comment %}
  sss-wordsearch.liquid
  Interactive word search:
  - drag to select letters
  - supports diagonal + backwards (all 8 directions)
  - pink ink trail while dragging
  - found words highlight pink + cross out in list
  - hearts burst on each found word
  - unlock message when all found

  Words (default):
  kai, aaron, rhysand, morally gray, fictional, valentine, villain, romantically, unwell
{% endcomment %}

{%- assign active_drop = nil -%}
{%- assign best_drop = nil -%}
{%- assign best_drop_key = '' -%}
{%- capture shared_preview_drop_handle -%}{% render 'sss-preview-drop-handle' %}{%- endcapture -%}
{%- assign preview_drop_handle = section.settings.preview_drop_handle | default: shared_preview_drop_handle | strip -%}
{%- assign now_key = 'now' | date: '%Y-%m-%d' -%}

{%- if preview_drop_handle != blank -%}
  {%- assign active_drop = shop.metaobjects.sss_drop[preview_drop_handle] -%}
{%- elsif shop.metaobjects.sss_drop != blank -%}
  {%- for d in shop.metaobjects.sss_drop.values -%}
    {%- if d.release_date != blank -%}
      {%- assign d_key = d.release_date | date: '%Y-%m-%d' -%}
      {%- if d_key <= now_key -%}
        {%- if best_drop_key == '' or d_key >= best_drop_key -%}
          {%- assign best_drop = d -%}
          {%- assign best_drop_key = d_key -%}
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if best_drop != nil -%}
    {%- assign active_drop = best_drop -%}
  {%- endif -%}
{%- endif -%}

{%- assign ws_accent = '#ff69b4' -%}
{%- assign ws_card_bg = '#151515' -%}
{%- assign ws_text = '#f6f6f6' -%}
{%- if active_drop != nil -%}
  {%- if active_drop.mood_accent != blank -%}{%- assign ws_accent = active_drop.mood_accent -%}{%- endif -%}
  {%- if active_drop.mood_pill_bg != blank -%}{%- assign ws_card_bg = active_drop.mood_pill_bg -%}{%- endif -%}
  {%- if active_drop.mood_pill_ink != blank -%}{%- assign ws_text = active_drop.mood_pill_ink -%}{%- endif -%}
{%- endif -%}

<section class="sss-ws" data-sss-wordsearch>
  <div class="sss-ws__wrap">

    <div class="sss-ws__top">
      <p class="sss-ws__kicker">{{ section.settings.kicker }}</p>
      <h2 class="sss-ws__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="sss-ws__sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="sss-ws__gridWrap">
      <!-- LEFT: Puzzle -->
      <div class="sss-ws__board">
        <div class="sss-ws__hud">
          <span class="sss-ws__pill" id="wsHint">drag over letters to find a word</span>
          <button class="sss-ws__reset" type="button" id="wsReset">reset</button>
        </div>

        <div class="sss-ws__stage">
          <!-- SVG “ink trail” layer -->
          <svg class="sss-ws__ink" id="wsInk" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            <path id="wsInkPath" d="" fill="none"></path>
          </svg>

          <!-- Hearts burst layer -->
          <div class="sss-ws__hearts" id="wsHearts" aria-hidden="true"></div>
          <div class="sss-ws__foundPopup" id="wsFoundPopup" hidden></div>

          <!-- Grid -->
          <div class="sss-ws__grid" id="wsGrid" role="application" aria-label="word search grid"></div>
        </div>

        <div class="sss-ws__unlock" id="wsUnlock" hidden>
          <div class="sss-ws__unlockCard">
            <p class="sss-ws__unlockKicker">unlocked</p>
            <h3 class="sss-ws__unlockTitle">{{ section.settings.unlock_title }}</h3>
            <p class="sss-ws__unlockSub">{{ section.settings.unlock_subtext }}</p>
            {% if section.settings.unlock_url != blank %}
              <a class="sss-ws__unlockBtn" href="{{ section.settings.unlock_url }}">{{ section.settings.unlock_btn }}</a>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- RIGHT: Word list -->
      <aside class="sss-ws__list">
        <div class="sss-ws__listHead">
          <p class="sss-ws__listKicker">find these</p>
          <p class="sss-ws__listSub">diagonal + backwards count 😌</p>
        </div>
        <ul class="sss-ws__words" id="wsWords" aria-label="words to find"></ul>
      </aside>
    </div>

  </div>
</section>

<script type="application/json" id="wsWordsData-{{ section.id }}">
[
{%- assign configured_words = section.settings.words | newline_to_br | split: '<br />' -%}
{%- assign first_word = true -%}
{%- assign rendered_word_count = 0 -%}
{%- for word in configured_words -%}
  {%- assign clean_word = word | strip | downcase -%}
  {%- if clean_word == blank -%}{%- continue -%}{%- endif -%}
  {%- if rendered_word_count >= 10 -%}{%- break -%}{%- endif -%}
  {%- unless first_word -%},{%- endunless -%}
  {{ clean_word | json }}
  {%- assign first_word = false -%}
  {%- assign rendered_word_count = rendered_word_count | plus: 1 -%}
{%- endfor -%}
]
</script>

<style>
/* ===== bybookishbabe dark editorial ===== */
.sss-ws{
  --ws-accent: {{ ws_accent }};
  --ws-card-bg: {{ ws_card_bg }};
  --ws-text: {{ ws_text }};
  --ws-accent-soft: color-mix(in srgb, var(--ws-accent) 16%, transparent);
  --ws-accent-strong: color-mix(in srgb, var(--ws-accent) 55%, transparent);
  background:
    radial-gradient(circle at top center, color-mix(in srgb, var(--ws-accent) 12%, transparent), transparent 54%),
    linear-gradient(180deg, color-mix(in srgb, var(--ws-card-bg) 24%, #0b0b0b 76%), #0b0b0b 42%);
  color:var(--ws-text);
  padding:22px 12px;
  font-family:"Libre Baskerville", Georgia, serif;
  position:relative;
  overflow:hidden;
}
.sss-ws::before{
  content:"";
  position:absolute; inset:-60px;
  pointer-events:none;
  background:
    radial-gradient(1000px 560px at 50% 120px, rgba(255,255,255,.08), transparent 70%),
    repeating-linear-gradient(
      to bottom,
      rgba(255,255,255,.035),
      rgba(255,255,255,.035) 1px,
      transparent 1px,
      transparent 26px
    );
  opacity:.55;
}
.sss-ws__wrap{
  max-width:1200px;
  margin:0 auto;
  position:relative;
  z-index:2;
  padding:0 8px;
}
.sss-ws__top{ max-width:900px; margin:0 auto 14px; }
.sss-ws__top{
  text-align:right;
  margin:0 0 14px auto;
}
.sss-ws__kicker{
  margin:0 0 8px;
  font-size:12px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:rgba(255,255,255,.82);
}
.sss-ws__title{
  margin:0;
  font-size:20px;
  font-weight:400;
  text-transform:lowercase;
  color:#fff;
}
.sss-ws__sub{
  margin:8px 0 0;
  font-size:13px;
  line-height:1.6;
  color:rgba(255,255,255,.78);
}

.sss-ws__gridWrap{
  display:grid;
  grid-template-columns:1fr;
  gap:14px;
  align-items:start;
}
@media(min-width:990px){
  .sss-ws__gridWrap{ grid-template-columns: 1.25fr .75fr; }
}

/* left board */
.sss-ws__board{
  background:color-mix(in srgb, var(--ws-card-bg) 90%, rgba(10,10,10,.95));
  border:1px solid color-mix(in srgb, var(--ws-accent) 18%, rgba(255,255,255,.12));
  border-radius:18px;
  box-shadow:0 12px 28px rgba(0,0,0,.45), 0 0 0 1px color-mix(in srgb, var(--ws-accent) 10%, transparent);
  overflow:hidden;
}
.sss-ws__hud{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;
  padding:12px;
  border-bottom:1px solid color-mix(in srgb, var(--ws-accent) 14%, rgba(255,255,255,.12));
  background:color-mix(in srgb, var(--ws-text) 4%, transparent);
}
.sss-ws__pill{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-size:12px;
  padding:6px 10px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.16);
  background:rgba(255,255,255,.06);
  color:color-mix(in srgb, var(--ws-text) 86%, transparent);
  text-transform:lowercase;
}
.sss-ws__reset{
  height:38px;
  padding:0 12px;
  border-radius:12px;
  border:1px solid color-mix(in srgb, var(--ws-accent) 22%, rgba(255,255,255,.14));
  background:color-mix(in srgb, var(--ws-accent) 8%, transparent);
  color:color-mix(in srgb, var(--ws-text) 84%, transparent);
  cursor:pointer;
  text-transform:lowercase;
  font-size:12px;
}
.sss-ws__reset:hover{
  color:#fff;
  border-color:color-mix(in srgb, var(--ws-accent) 44%, white 10%);
  background:color-mix(in srgb, var(--ws-accent) 14%, transparent);
}

.sss-ws__stage{
  position:relative;
  padding:12px;
}

/* grid */
.sss-ws__grid{
  display:grid;
  grid-template-columns: repeat(12, minmax(0,1fr));
  gap:6px;
  width:100%;
  box-sizing:border-box;
  user-select:none;
  -webkit-user-select:none;
  touch-action:none;
}
.sss-ws__stage{
  position:relative;
  padding:10px;
  overflow:hidden;
  box-sizing:border-box;
}

.sss-ws__cell{
  aspect-ratio:1 / 1;
  border-radius:10px;
  border:1px solid color-mix(in srgb, var(--ws-accent) 14%, rgba(255,255,255,.1));
  background:color-mix(in srgb, var(--ws-text) 4%, transparent);
  color:var(--ws-text);
  display:grid;
  place-items:center;
  font-size:14px;
  letter-spacing:.06em;
  text-transform:uppercase;
  cursor:pointer;
  position:relative;
  z-index:2;
  transition:background .12s ease, border-color .12s ease;
}
.sss-ws__cell.is-active{
  border-color:var(--ws-accent-strong);
  background:var(--ws-accent-soft);
  color:#fff;
}
.sss-ws__cell.is-found{
  border-color:color-mix(in srgb, var(--ws-accent) 82%, white 18%);
  background:color-mix(in srgb, var(--ws-accent) 24%, transparent);
  color:#fff;
}

/* ink trail */
.sss-ws__ink{
  position:absolute;
  inset:12px;
  width:calc(100% - 24px);
  height:calc(100% - 24px);
  pointer-events:none;
  z-index:1;
}
#wsInkPath{
  stroke: var(--ws-accent);
  stroke-width: 10;
  stroke-linecap: round;
  stroke-linejoin: round;
  filter: drop-shadow(0 10px 16px rgba(0,0,0,.45));
  opacity:.86;
  transition:opacity .12s ease;
}
#wsInkPath.is-on{ opacity:.86; }

/* right list */
.sss-ws__list{
  background:color-mix(in srgb, var(--ws-card-bg) 88%, rgba(21,21,21,.92));
  border:1px solid color-mix(in srgb, var(--ws-accent) 18%, rgba(255,255,255,.12));
  border-radius:18px;
  box-shadow:0 12px 28px rgba(0,0,0,.45), 0 0 0 1px color-mix(in srgb, var(--ws-accent) 10%, transparent);
  overflow:hidden;
}
.sss-ws__listHead{
  padding:12px;
  border-bottom:1px solid color-mix(in srgb, var(--ws-accent) 14%, rgba(255,255,255,.12));
  background:color-mix(in srgb, var(--ws-text) 4%, transparent);
}
.sss-ws__listKicker{
  margin:0;
  font-size:12px;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:#fff;
}
.sss-ws__listSub{
  margin:6px 0 0;
  font-size:12px;
  color:rgba(255,255,255,.74);
}
.sss-ws__words{
  list-style:none;
  margin:0;
  padding:10px 12px 12px;
  display:grid;
  gap:8px;
}
.sss-ws__word{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  padding:10px 12px;
  border-radius:14px;
  border:1px solid color-mix(in srgb, var(--ws-accent) 16%, rgba(255,255,255,.1));
  background:color-mix(in srgb, var(--ws-accent) 10%, var(--ws-text) 4%);
  text-transform:lowercase;
  font-size:13px;
  color:color-mix(in srgb, var(--ws-text) 82%, white 18%);
}
.sss-ws__word .label{
  color:color-mix(in srgb, var(--ws-text) 82%, white 18%);
}
.sss-ws__word .tag{
  font-size:11px;
  padding:4px 8px;
  border-radius:999px;
  border:1px solid color-mix(in srgb, var(--ws-accent) 18%, rgba(255,255,255,.12));
  color:color-mix(in srgb, var(--ws-text) 72%, transparent);
}
.sss-ws__word.is-found{
  border-color:var(--ws-accent-strong);
  background:var(--ws-accent-soft);
}
.sss-ws__word.is-found .label{
  color:#fff;
  text-decoration:line-through;
  text-decoration-thickness:2px;
  text-decoration-color:var(--ws-accent);
}
.sss-ws__word.is-found .tag{
  border-color:var(--ws-accent-strong);
  color:#fff;
}

