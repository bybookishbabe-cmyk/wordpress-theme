  }

  .sss-ws__word .label{
    line-height:1.25;
  }

  .sss-ws__word .tag{
    margin-top:2px;
  }

  .sss-ws__stage{
    padding:8px;
  }

  .sss-ws__grid{
    grid-template-columns: repeat(12, minmax(0,1fr));
