{% comment %}
  auto-exclusive.liquid (based on your original sss-member-exclusive-gram)

  Progressive render:
  - Shows whatever is filled out (no minimums).
  - Pulls current drop from metaobject sss_drop by most recent release_date <= today.
  - Printable/Physical panels come from drop.items (sss_drop_item) by item_type.
  - Gram card comes from fields on the drop.
  - Fixes:
    - DOES NOT rely on system.published_at (can be blank on storefront even when Active)
    - Normalizes download links (supports url, value.url, or raw string)
    - Physical add-to-cart normalizes variant ids + toast "added to cart 🖤"
  - Optional: debug + preview mode (force a specific drop by handle or name).
{% endcomment %}

{%- assign active_drop = nil -%}
{%- assign now_key = 'now' | date: '%Y-%m-%d' -%}
{%- assign best_key = '' -%}
{%- capture shared_preview_drop_handle -%}{% render 'sss-preview-drop-handle' %}{%- endcapture -%}
{%- assign effective_preview_drop_handle = section.settings.preview_drop_handle | default: shared_preview_drop_handle | strip -%}

{%- if shop.metaobjects.sss_drop != blank -%}
  {%- for d in shop.metaobjects.sss_drop.values -%}
    {%- if d.release_date != blank -%}
      {%- assign d_key = d.release_date | date: '%Y-%m-%d' -%}
      {%- if d_key <= now_key -%}
        {%- if best_key == '' or d_key >= best_key -%}
          {%- assign best_key = d_key -%}
          {%- assign active_drop = d -%}
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%}
  Fallback while testing:
  If none are <= today (timezone edge case or future-dated drops), use newest by release_date.
{%- endcomment -%}
{%- if active_drop == nil and shop.metaobjects.sss_drop != blank -%}
  {%- assign newest_key = '' -%}
  {%- assign newest_drop = nil -%}
  {%- for d in shop.metaobjects.sss_drop.values -%}
    {%- if d.release_date != blank -%}
      {%- assign d_key = d.release_date | date: '%Y-%m-%d' -%}
      {%- if newest_key == '' or d_key > newest_key -%}
        {%- assign newest_key = d_key -%}
        {%- assign newest_drop = d -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if newest_drop != nil -%}
    {%- assign active_drop = newest_drop -%}
    {%- assign best_key = newest_key -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%}
  PREVIEW MODE: force a specific drop (handle OR exact name)
{%- endcomment -%}
{%- if shop.metaobjects.sss_drop != blank and section.settings.preview_mode or shop.metaobjects.sss_drop != blank and effective_preview_drop_handle != blank -%}
  {%- assign forced = nil -%}
  {%- assign want_handle = effective_preview_drop_handle -%}
  {%- assign want_name = section.settings.preview_drop_name | strip -%}
  
{%- if want_handle != blank -%}
  {%- assign forced = shop.metaobjects.sss_drop[want_handle] -%}
{%- endif -%}

  {%- if forced == nil and want_name != blank -%}
    {%- for d in shop.metaobjects.sss_drop.values -%}
      {%- if d.name == want_name -%}
        {%- assign forced = d -%}{%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if forced != nil -%}
    {%- assign active_drop = forced -%}
    {%- if active_drop.release_date != blank -%}
      {%- assign best_key = active_drop.release_date | date: '%Y-%m-%d' -%}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%}Only render output if we found an active drop.{%- endcomment -%}
{%- if active_drop != nil -%}

  {%- assign quote_text = active_drop.quote_text -%}
  {%- assign kicker     = '' -%}
  {%- assign title      = 'printable kindle insert vault' -%}
  {%- assign subtext    = 'the full printable insert set for this drop is included for paid members.' -%}

  {%- assign gram_kicker  = active_drop.gram_kicker -%}
  {%- assign gram_title   = active_drop.gram_title -%}
  {%- assign gram_sub     = active_drop.gram_sub -%}
  {%- assign gram_image   = active_drop.gram_image -%}
  {%- assign gram_caption = active_drop.gram_caption -%}
  {%- assign gram_url     = 'https://www.instagram.com/bybookishbabe/' -%}
  {%- assign bonus_printable_product = active_drop.bonus_printable_product.value | default: active_drop.bonus_printable_product -%}
  {%- assign bonus_physical_product  = active_drop.bonus_physical_product.value  | default: active_drop.bonus_physical_product -%}
  {%- assign monthly_collection_printable_products = active_drop.monthly_collection_printable_products.value | default: active_drop.monthly_collection_printable_products -%}
  {%- assign has_monthly_collection = false -%}
  {%- if monthly_collection_printable_products != blank -%}
    {%- assign has_monthly_collection = true -%}
  {%- endif -%}

  {%- assign printable_item = nil -%}
  {%- assign physical_item  = nil -%}

  {%- assign items_val = nil -%}
  {%- if active_drop.items != blank -%}
    {%- assign items_val = active_drop.items.value -%}
  {%- endif -%}

  {%- if items_val != nil -%}
    {%- if items_val.size != blank -%}
      {%- for it in items_val -%}
        {%- assign t = it.item_type | downcase -%}
        {%- if t == 'printable' and printable_item == nil -%}{%- assign printable_item = it -%}{%- endif -%}
        {%- if t == 'physical'  and physical_item  == nil -%}{%- assign physical_item  = it -%}{%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- assign t = items_val.item_type | downcase -%}
      {%- if t == 'printable' -%}{%- assign printable_item = items_val -%}{%- endif -%}
      {%- if t == 'physical'  -%}{%- assign physical_item  = items_val -%}{%- endif -%}
    {%- endif -%}
  {%- endif -%}

  {%- assign show_printable = false -%}
  {%- assign show_physical  = false -%}
  {%- assign show_gram      = false -%}

  {%- if printable_item != nil -%}
    {%- if printable_item.pill != blank or printable_item.image != blank or printable_item.note != blank or printable_item.dl_12th != blank or printable_item.dl_11th != blank or printable_item.dl_6in != blank or printable_item.dl_10th != blank -%}
      {%- assign show_printable = true -%}
    {%- endif -%}
  {%- endif -%}

  {%- assign show_physical = false -%}

  {%- if gram_kicker != blank or gram_title != blank or gram_sub != blank or gram_image != blank or gram_caption != blank -%}
    {%- assign show_gram = true -%}
  {%- endif -%}

  {%- comment -%}Printable fields{%- endcomment -%}
  {%- assign printable_pill  = printable_item.pill -%}
  {%- assign printable_image = printable_item.image -%}
  {%- assign printable_note  = printable_item.note -%}
  {%- assign dl12 = printable_item.dl_12th -%}
  {%- assign dl11 = printable_item.dl_11th -%}
  {%- assign dl6  = printable_item.dl_6in  -%}
  {%- assign dl10 = printable_item.dl_10th -%}

  {%- comment -%}
    ✅ Normalize download URLs (file refs or raw strings)
    Supports:
    - dl12.url
    - dl12.value.url
    - dl12 (string)
  {%- endcomment -%}
  {%- assign dl12_url = dl12.url | default: dl12.value.url | default: dl12 -%}
  {%- assign dl11_url = dl11.url | default: dl11.value.url | default: dl11 -%}
  {%- assign dl6_url  = dl6.url  | default: dl6.value.url  | default: dl6  -%}
  {%- assign dl10_url = dl10.url | default: dl10.value.url | default: dl10 -%}

  {%- comment -%}Physical fields{%- endcomment -%}
  {%- assign physical_pill  = physical_item.pill -%}
  {%- assign physical_image = physical_item.image -%}
  {%- assign physical_note  = physical_item.note -%}
  {%- assign product_name   = physical_item.product_name | default: active_drop.name -%}
  {%- assign price_label    = physical_item.price_label | default: '$9' -%}

  {%- assign v12 = physical_item.v_12th -%}
  {%- assign v11 = physical_item.v_11th -%}
  {%- assign v6  = physical_item.v_6in  -%}
  {%- assign v10 = physical_item.v_10th -%}

  {%- comment -%}Normalize variant IDs: support numeric, variant object, or gid://{%- endcomment -%}
  {%- assign v12_id = v12.id | default: v12 | append: '' | split: '/' | last | strip -%}
  {%- assign v11_id = v11.id | default: v11 | append: '' | split: '/' | last | strip -%}
  {%- assign v6_id  = v6.id  | default: v6  | append: '' | split: '/' | last | strip -%}
  {%- assign v10_id = v10.id | default: v10 | append: '' | split: '/' | last | strip -%}

  {%- capture label12 -%}{{ product_name }} · 12th gen{%- endcapture -%}
  {%- capture label11 -%}{{ product_name }} · 11th gen{%- endcapture -%}
  {%- capture label6  -%}{{ product_name }} · 6 inch{%- endcapture -%}
  {%- capture label10 -%}{{ product_name }} · 10th gen{%- endcapture -%}

  {%- assign show12 = false -%}
  {%- assign show11 = false -%}
  {%- assign show6  = false -%}
  {%- assign show10 = false -%}
  {%- if v12_id != blank and v12_id != '0' -%}{%- assign show12 = true -%}{%- endif -%}
  {%- if v11_id != blank and v11_id != '0' -%}{%- assign show11 = true -%}{%- endif -%}
  {%- if v6_id  != blank and v6_id  != '0' -%}{%- assign show6  = true -%}{%- endif -%}
  {%- if v10_id != blank and v10_id != '0' -%}{%- assign show10 = true -%}{%- endif -%}

  {%- assign printable_product_name = '' -%}
  {%- assign printable_price_label = 'free' -%}
  {%- assign printable_v12_id = '' -%}
  {%- assign printable_v11_id = '' -%}
  {%- assign printable_v6_id = '' -%}
  {%- assign printable_v10_id = '' -%}
  {%- assign printable_show12 = false -%}
  {%- assign printable_show11 = false -%}
  {%- assign printable_show6 = false -%}
  {%- assign printable_show10 = false -%}
  {%- assign printable_product_url = '' -%}

  {%- if bonus_printable_product != blank -%}
    {%- assign printable_pill = printable_pill | default: 'bonus printable' -%}
    {%- assign printable_default_variant = bonus_printable_product.selected_or_first_available_variant -%}
    {%- assign printable_image = bonus_printable_product.featured_image | default: bonus_printable_product.featured_media.preview_image | default: printable_default_variant.featured_image | default: printable_default_variant.image | default: bonus_printable_product.images.first | default: printable_image -%}
    {%- assign printable_product_name = bonus_printable_product.title | strip -%}
    {%- assign printable_product_url = bonus_printable_product.url -%}
    {%- assign printable_dl12_url = '' -%}
    {%- assign printable_dl11_url = '' -%}
    {%- assign printable_dl6_url = '' -%}
    {%- assign printable_dl10_url = '' -%}
    {%- if printable_default_variant != blank -%}
        {%- assign printable_price_label = 'free' -%}
    {%- endif -%}
    {%- for variant in bonus_printable_product.variants -%}
      {%- assign variant_title = variant.title | downcase -%}
      {%- assign variant_download_url = '' -%}
      {%- if variant.metafields.custom.download_file.value != blank -%}
        {%- if variant.metafields.custom.download_file.value.url != blank -%}
          {%- assign variant_download_url = variant.metafields.custom.download_file.value.url -%}
        {%- else -%}
          {%- assign variant_download_url = variant.metafields.custom.download_file.value | file_url -%}
        {%- endif -%}
      {%- endif -%}
      {%- if variant_download_url contains 'dropbox.com' -%}
        {%- assign variant_download_url = variant_download_url | replace: 'www.dropbox.com', 'dl.dropboxusercontent.com' | replace: 'dropbox.com', 'dl.dropboxusercontent.com' | replace: '?dl=0', '?raw=1' | replace: '&dl=0', '&raw=1' -%}
      {%- endif -%}
      {%- if printable_v12_id == '' and variant_title contains '12th' -%}{%- assign printable_v12_id = variant.id | append: '' -%}{%- assign printable_dl12_url = variant_download_url -%}{%- endif -%}
      {%- if printable_v11_id == '' and variant_title contains '11th' -%}{%- assign printable_v11_id = variant.id | append: '' -%}{%- assign printable_dl11_url = variant_download_url -%}{%- endif -%}
      {%- if printable_v6_id == '' and variant_title contains '6' -%}{%- assign printable_v6_id = variant.id | append: '' -%}{%- assign printable_dl6_url = variant_download_url -%}{%- endif -%}
      {%- if printable_v10_id == '' and variant_title contains '10th' -%}{%- assign printable_v10_id = variant.id | append: '' -%}{%- assign printable_dl10_url = variant_download_url -%}{%- endif -%}
    {%- endfor -%}
    {%- assign printable_product_download = '' -%}
    {%- if bonus_printable_product.metafields.custom.download_file.value != blank -%}
      {%- if bonus_printable_product.metafields.custom.download_file.value.url != blank -%}
        {%- assign printable_product_download = bonus_printable_product.metafields.custom.download_file.value.url -%}
      {%- else -%}
        {%- assign printable_product_download = bonus_printable_product.metafields.custom.download_file.value | file_url -%}
      {%- endif -%}
    {%- endif -%}
    {%- if printable_product_download contains 'dropbox.com' -%}
      {%- assign printable_product_download = printable_product_download | replace: 'www.dropbox.com', 'dl.dropboxusercontent.com' | replace: 'dropbox.com', 'dl.dropboxusercontent.com' | replace: '?dl=0', '?raw=1' | replace: '&dl=0', '&raw=1' -%}
    {%- endif -%}
    {%- if printable_dl12_url == '' -%}{%- assign printable_dl12_url = printable_product_download -%}{%- endif -%}
    {%- if printable_dl11_url == '' -%}{%- assign printable_dl11_url = printable_product_download -%}{%- endif -%}
    {%- if printable_dl6_url == '' -%}{%- assign printable_dl6_url = printable_product_download -%}{%- endif -%}
    {%- if printable_dl10_url == '' -%}{%- assign printable_dl10_url = printable_product_download -%}{%- endif -%}
    {%- if printable_v12_id != '' -%}{%- assign printable_show12 = true -%}{%- endif -%}
    {%- if printable_v11_id != '' -%}{%- assign printable_show11 = true -%}{%- endif -%}
    {%- if printable_v6_id  != '' -%}{%- assign printable_show6  = true -%}{%- endif -%}
    {%- if printable_v10_id != '' -%}{%- assign printable_show10 = true -%}{%- endif -%}
    {%- if printable_show12 == false and printable_show11 == false and printable_show6 == false and printable_show10 == false and printable_default_variant != blank -%}
      {%- assign printable_v12_id = printable_default_variant.id | append: '' -%}
      {%- assign printable_show12 = true -%}
    {%- endif -%}
    {%- assign show_printable = true -%}
  {%- endif -%}

  {%- assign physical_product_url = '' -%}
  {%- if bonus_physical_product != blank -%}
    {%- assign physical_pill = physical_pill | default: 'bonus physical' -%}
    {%- assign physical_default_variant = bonus_physical_product.selected_or_first_available_variant -%}
    {%- assign physical_image = bonus_physical_product.featured_image | default: bonus_physical_product.featured_media.preview_image | default: physical_default_variant.featured_image | default: physical_default_variant.image | default: bonus_physical_product.images.first | default: physical_image -%}
    {%- assign product_name = bonus_physical_product.title | strip -%}
    {%- assign physical_product_url = bonus_physical_product.url -%}
    {%- if physical_default_variant != blank -%}
      {%- assign price_label = physical_default_variant.price | money_without_trailing_zeros -%}
    {%- endif -%}
    {%- assign v12_id = '' -%}
    {%- assign v11_id = '' -%}
    {%- assign v6_id = '' -%}
    {%- assign v10_id = '' -%}
    {%- for variant in bonus_physical_product.variants -%}
      {%- assign variant_title = variant.title | downcase -%}
      {%- if v12_id == '' and variant_title contains '12th' -%}{%- assign v12_id = variant.id | append: '' -%}{%- endif -%}
      {%- if v11_id == '' and variant_title contains '11th' -%}{%- assign v11_id = variant.id | append: '' -%}{%- endif -%}
      {%- if v6_id == '' and variant_title contains '6' -%}{%- assign v6_id = variant.id | append: '' -%}{%- endif -%}
      {%- if v10_id == '' and variant_title contains '10th' -%}{%- assign v10_id = variant.id | append: '' -%}{%- endif -%}
    {%- endfor -%}
    {%- assign show12 = false -%}
    {%- assign show11 = false -%}
    {%- assign show6 = false -%}
    {%- assign show10 = false -%}
    {%- if v12_id != '' -%}{%- assign show12 = true -%}{%- endif -%}
    {%- if v11_id != '' -%}{%- assign show11 = true -%}{%- endif -%}
    {%- if v6_id  != '' -%}{%- assign show6  = true -%}{%- endif -%}
    {%- if v10_id != '' -%}{%- assign show10 = true -%}{%- endif -%}
    {%- if show12 == false and show11 == false and show6 == false and show10 == false and physical_default_variant != blank -%}
      {%- assign v12_id = physical_default_variant.id | append: '' -%}
      {%- assign show12 = true -%}
    {%- endif -%}
    {%- capture label12 -%}{{ product_name }} · 12th gen{%- endcapture -%}
    {%- capture label11 -%}{{ product_name }} · 11th gen{%- endcapture -%}
    {%- capture label6  -%}{{ product_name }} · 6 inch{%- endcapture -%}
    {%- capture label10 -%}{{ product_name }} · 10th gen{%- endcapture -%}
    {%- assign show_physical = true -%}
  {%- endif -%}

<style>
  /* ===== OUTER WRAP (two-column layout) ===== */
  .sss-mpg{
    background:#0b0b0b;
    color:#f6f6f6;
    padding:18px 12px;
    font-family:"Libre Baskerville", Georgia, serif;
    position:relative;
    overflow:hidden;
  }
  .sss-mpg:before{
    content:"";
    position:absolute; inset:-40px;
    pointer-events:none;
    background:
      radial-gradient(900px 520px at 50% 120px, rgba(255,255,255,.08), transparent 70%),
      repeating-linear-gradient(
        to bottom,
        rgba(255,255,255,.035),
        rgba(255,255,255,.035) 1px,
        transparent 1px,
        transparent 26px
      );
    opacity:.55;
  }
  .sss-mpg__wrap{
    max-width:1300px;
    margin:0 auto;
    position:relative;
    z-index:1;
    padding:0 8px;
  }
  .sss-mpg__grid{
    display:grid;
    grid-template-columns:1fr;
    gap:14px;
    align-items:start;
  }
  @media(min-width:990px){
    .sss-mpg__grid{
      grid-template-columns: 1.12fr .88fr;
      gap:16px;
    }
  }

  .sss-me2{ color:#f6f6f6; }
  .sss-me2 a{ color:inherit; text-decoration:none; }

  .sss-me2__kicker{
    margin:0 0 10px;
    font-size:12px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:#c8c8c8;
  }

  .sss-me2__card{
    background:rgba(21,21,21,.92);
    border:1px solid #2a2a2a;
    border-radius:18px;
    box-shadow:0 12px 28px rgba(0,0,0,.45);
    overflow:hidden;
  }

  .sss-me2__head{
    padding:10px 12px 8px;
    border-bottom:1px solid #2a2a2a;
    background:rgba(255,255,255,.03);
  }

  .sss-me2__title{
    margin:0;
    font-size:17px;
    font-weight:400;
    text-transform:lowercase;
  }

  .sss-me2__sub{
    margin:6px 0 0;
    font-size:12px;
    line-height:1.55;
    color:#c8c8c8;
  }

  .sss-me2__collection{
    margin:0 0 16px;
    padding:10px;
    border:1px solid #2a2a2a;
    border-radius:18px;
    background:rgba(21,21,21,.92);
    box-shadow:0 12px 28px rgba(0,0,0,.45);
    display:grid;
    gap:14px;
  }
  .sss-mpg__monthlyTop{
    display:grid;
    gap:18px;
    align-items:start;
    margin:0 0 18px;
  }
  @media (min-width:990px){
    .sss-mpg__monthlyTop--split{
      grid-template-columns:minmax(0, 1fr);
    }
  }
  .sss-me2__collectionIntro{
    display:grid;
    gap:4px;
  }
  .sss-me2__collectionPills{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-top:6px;
  }
  .sss-me2__collectionPill{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:30px;
    padding:0 14px;
    border-radius:999px;
    background:#050505;
    border:1px solid rgba(255,255,255,.14);
    color:#f7f3ee;
    font-size:11px;
    letter-spacing:.12em;
    text-transform:uppercase;
    box-shadow:0 6px 16px rgba(0,0,0,.22);
    cursor:pointer;
    transition:background .18s ease, border-color .18s ease, color .18s ease, transform .18s ease;
  }
  .sss-me2__collectionPill:hover,
  .sss-me2__collectionPill.is-active{
    background:#10192b;
    border-color:rgba(91,123,181,.48);
    color:#d7e6ff;
    transform:translateY(-1px);
  }
  .sss-me2__collectionPill.is-dim{
    opacity:.88;
  }
  .sss-me2__collectionKicker{
    margin:0;
    font-size:11px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:rgba(246,246,246,.62);
  }
  .sss-me2__collectionTitle{
    margin:0;
    font-size:22px;
    line-height:1.08;
    text-transform:lowercase;
    color:#fff;
  }
  .sss-me2__collectionSub{
    margin:0;
    max-width:720px;
    font-size:11px;
    line-height:1.5;
    color:rgba(246,246,246,.72);
    text-transform:lowercase;
  }
  .sss-me2__collectionGrid{
    display:block;
  }
  .sss-me2__collectionLabel{
    margin:0;
    font-size:10px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:rgba(246,246,246,.58);
  }
  .sss-me2__collectionRail{
    display:flex;
    flex-wrap:nowrap;
    align-items:flex-start;
    gap:12px;
    overflow-x:auto;
    overflow-y:hidden;
    padding-bottom:4px;
    scroll-snap-type:x proximity;
    -webkit-overflow-scrolling:touch;
    touch-action:pan-x pinch-zoom;
    scroll-padding-left:4px;
    overscroll-behavior-x:contain;
    scrollbar-width:thin;
    scrollbar-color:rgba(102,133,191,.92) rgba(247,243,238,.18);
    scrollbar-gutter:stable both-edges;
    cursor:grab;
    user-select:none;
  }
  .sss-me2__collectionRail.is-dragging{
    cursor:grabbing;
  }
  .sss-me2__collectionRail--mixed{
    padding-top:2px;
  }
  .sss-me2__collectionScroll{
