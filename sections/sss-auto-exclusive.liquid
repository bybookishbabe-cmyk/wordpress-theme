<script>

if (!document.getElementById('sssToast')) {
  const t = document.createElement('div');
  t.id = 'sssToast';
  t.className = 'sss-toast';
  document.body.appendChild(t);
}

function sssToast(msg, sub){
  const el = document.getElementById('sssToast');
  if (!el) return;

  el.innerHTML = sub ? (msg + '<br><span>' + sub + '</span>') : msg;
  el.classList.add('show');

  setTimeout(function(){
    el.classList.remove('show');
  }, 2400);
}

function sssToast(msg, sub){
  const el = document.getElementById('sssToast');
  if (!el) return;
  el.innerHTML = sub ? (msg + '<br><span>' + sub + '</span>') : msg;
  el.classList.add('show');
  setTimeout(function(){ el.classList.remove('show'); }, 2400);
}

function sssAdd(rawId, label){

  var idStr = (rawId || '').toString().trim();
  if (idStr.indexOf('gid://') === 0) idStr = idStr.split('/').pop();

  var id = parseInt(idStr, 10);
  if (!id || isNaN(id)) {
    sssToast('not added 🖤', 'invalid variant id');
    return;
  }

  var formData = new FormData();
  formData.append('id', id);
  formData.append('quantity', 1);

  fetch('/cart/add', {
    method: 'POST',
    body: formData
  })
  .then(function(response){
    if(response.ok){
      sssToast('added to cart 🖤', label);
    } else {
      sssToast('not added 🖤', 'unavailable');
    }
  })
  .catch(function(){
    sssToast('not added 🖤', 'error');
  });
}

function sssAddMany(rawIds, label){
  var ids = (rawIds || []).map(function(rawId){
    var idStr = (rawId || '').toString().trim();
    if (idStr.indexOf('gid://') === 0) idStr = idStr.split('/').pop();
    var id = parseInt(idStr, 10);
    return (!id || isNaN(id)) ? null : id;
  }).filter(Boolean);

  if (!ids.length) {
    sssToast('not added 🖤', 'invalid variant id');
    return;
  }

  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      items: ids.map(function(id){
        return { id: id, quantity: 1 };
      })
    })
  })
  .then(function(response){
    if (response.ok){
      sssToast('added to cart 🖤', label);
    } else {
      sssToast('not added 🖤', 'unavailable');
    }
  })
  .catch(function(){
    sssToast('not added 🖤', 'error');
  });
}

function sssInitPhysicalCollection(){
  document.querySelectorAll('[data-physical-card]').forEach(function(card){
    if (card.dataset.physicalReady === 'true') return;
    var image = card.querySelector('.sss-me2__physicalImage');
    var sizeSelect = card.querySelector('[data-physical-sizes]');
    var addButton = card.querySelector('[data-physical-add]');
    var designSelect = card.querySelector('[data-physical-design]');
    var jsonNode = card.querySelector('[data-physical-variants]');
    if (!sizeSelect || !addButton || !jsonNode || !designSelect) return;

    var variants = [];
    try {
      variants = JSON.parse(jsonNode.textContent || '[]');
    } catch (e) {
      variants = [];
    }
    variants = variants.filter(function(variant){ return !!variant && variant.available; });
    if (!variants.length) return;

    var activeDesign = designSelect.value || '';
    var currentVariant = null;

    function render(){
      var filtered = variants.filter(function(variant){
        return (variant.design || '') === activeDesign;
      });
      if (!filtered.length) filtered = variants;

      if (image && filtered[0] && filtered[0].image){
        image.src = filtered[0].image;
        image.setAttribute('src', filtered[0].image);
        image.removeAttribute('srcset');
      }

      sizeSelect.innerHTML = '';
      var placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = 'choose a size';
      sizeSelect.appendChild(placeholder);

      filtered.forEach(function(variant){
        var option = document.createElement('option');
        option.value = String(variant.id);
        option.textContent = (variant.size && variant.size !== 'Default Title' ? variant.size : 'default size') + ' · ' + variant.price;
        option.dataset.label = variant.label;
        sizeSelect.appendChild(option);
      });

      currentVariant = filtered[0] || null;
      if (currentVariant) {
        sizeSelect.value = String(currentVariant.id);
        addButton.textContent = 'add to cart · ' + currentVariant.price;
      } else {
        sizeSelect.value = '';
        addButton.textContent = 'add to cart';
      }
    }

    designSelect.addEventListener('change', function(){
      activeDesign = designSelect.value || '';
      render();
    });

    sizeSelect.addEventListener('change', function(){
      var selectedId = sizeSelect.value;
      currentVariant = variants.find(function(variant){
        return String(variant.id) === selectedId;
      }) || currentVariant;

      if (currentVariant) {
        addButton.textContent = 'add to cart · ' + currentVariant.price;
      } else {
        addButton.textContent = 'add to cart';
      }
    });

    addButton.addEventListener('click', function(){
      if (!currentVariant) return;
      sssAdd(currentVariant.id, currentVariant.label);
    });

    card.dataset.physicalReady = 'true';
    render();
  });
}

function sssInitCollectionFilters(){
  document.querySelectorAll('.sss-me2__collection').forEach(function(section){
    if (section.dataset.collectionReady === 'true') return;
    var buttons = section.querySelectorAll('[data-collection-filter]');
    var cards = section.querySelectorAll('[data-collection-type]');
    if (!buttons.length || !cards.length) return;

    function applyFilter(type){
      buttons.forEach(function(button){
        var active = !!type && button.getAttribute('data-collection-filter') === type;
        button.classList.toggle('is-active', active);
        button.classList.toggle('is-dim', !active);
      });
      cards.forEach(function(card){
        card.classList.toggle('is-hidden', !!type && card.getAttribute('data-collection-type') !== type);
      });
    }

    buttons.forEach(function(button){
      button.addEventListener('click', function(){
        var selectedType = button.getAttribute('data-collection-filter');
        var nextType = button.classList.contains('is-active') ? '' : selectedType;
        applyFilter(nextType);
      });
    });

    applyFilter('');
    section.dataset.collectionReady = 'true';
  });
}

function sssInitCollectionRails(){
  document.querySelectorAll('[data-collection-rail]').forEach(function(rail){
    if (rail.dataset.dragReady === 'true') return;

    rail.querySelectorAll('img').forEach(function(image){
      image.setAttribute('draggable', 'false');
      image.addEventListener('dragstart', function(event){
        event.preventDefault();
      });
    });
    rail.addEventListener('dragstart', function(event){
      event.preventDefault();
    });

    var isCoarsePointer = false;
    try {
      isCoarsePointer = window.matchMedia('(pointer: coarse)').matches;
    } catch (e) {}

    var pointerActive = false;
    var startX = 0;
    var startScroll = 0;
    var moved = false;
    var touchActive = false;
    var touchDragging = false;
    var startY = 0;
    var scrollWrap = rail.parentElement;
    var scrollThumb = scrollWrap ? scrollWrap.querySelector('[data-collection-scroll-thumb]') : null;

    function syncThumb(){
      if (!scrollThumb) return;
      var maxScroll = rail.scrollWidth - rail.clientWidth;
      if (maxScroll <= 0) {
        scrollThumb.style.width = '100%';
        scrollThumb.style.transform = 'translateX(0)';
        return;
      }

      var visibleRatio = rail.clientWidth / rail.scrollWidth;
      var thumbWidth = Math.max(visibleRatio * 100, 18);
      var maxThumbTravel = 100 - thumbWidth;
      var progress = rail.scrollLeft / maxScroll;
      var thumbOffset = maxThumbTravel * progress;

      scrollThumb.style.width = thumbWidth + '%';
      scrollThumb.style.transform = 'translateX(' + thumbOffset + '%)';
    }

    rail.addEventListener('scroll', syncThumb, { passive: true });
    window.addEventListener('resize', syncThumb);

    if (!isCoarsePointer) {
      rail.addEventListener('pointerdown', function(event){
        if (event.target && event.target.closest('select, input, textarea')) return;
        if (event.pointerType === 'mouse' && event.button !== 0) return;
        pointerActive = true;
        moved = false;
        startX = event.clientX;
        startScroll = rail.scrollLeft;
        rail.classList.add('is-dragging');
        if (rail.setPointerCapture) rail.setPointerCapture(event.pointerId);
      });

      rail.addEventListener('pointermove', function(event){
        if (!pointerActive) return;
        var delta = event.clientX - startX;
        if (Math.abs(delta) > 6) moved = true;
        rail.scrollLeft = startScroll - delta;
      });

      function endDrag(event){
        if (!pointerActive) return;
        pointerActive = false;
        rail.classList.remove('is-dragging');
        if (event && rail.releasePointerCapture) {
          try { rail.releasePointerCapture(event.pointerId); } catch (e) {}
        }
      }

      rail.addEventListener('pointerup', endDrag);
      rail.addEventListener('pointercancel', endDrag);
      rail.addEventListener('pointerleave', function(event){
        if (event.pointerType === 'mouse') endDrag(event);
      });

      rail.querySelectorAll('a, button, select').forEach(function(control){
        control.addEventListener('pointerdown', function(event){
          event.stopPropagation();
        });
        control.addEventListener('click', function(event){
          if (moved) {
            event.preventDefault();
            event.stopPropagation();
          }
        });
      });
    }

    rail.dataset.dragReady = 'true';
    syncThumb();
  });
}

function sssInitPrintableDownloadTracking(){
  var shouldDebugPrintable = {% if section.settings.debug %}true{% else %}false{% endif %};
  document.querySelectorAll('[data-printable-download]').forEach(function(link){
    if (link.dataset.printableTrackingReady === 'true') return;

    link.addEventListener('click', function(event){
      var product = (link.dataset.printableProduct || '').trim();
      var label = (link.dataset.printableLabel || link.textContent || '').trim();
      var url = (link.dataset.printableUrl || link.href || '').trim();
      var inDesignMode = !!(window.Shopify && window.Shopify.designMode);
      var printableKey = (product || label || 'printable')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '')
        .slice(0, 120);

      if (typeof trackSiteEvent === 'function') {
        trackSiteEvent('printable_download_clicked', {
          uiLocation: 'monthly_exclusive_printable',
          metadata: {
            printable: printableKey,
            product: product,
            label: label,
            url: url,
            source: link.dataset.printableSource || '',
            link_text: (link.textContent || '').trim()
          }
        });
      }

      if (shouldDebugPrintable && typeof console !== 'undefined') {
        console.log('[sss auto exclusive] printable click', {
          product: product,
          label: label,
          url: url,
          source: link.dataset.printableSource || '',
          href: link.getAttribute('href') || ''
        });
      }

      if (!url) {
        event.preventDefault();
        event.stopPropagation();
        sssToast('download link missing', product || label || 'no file url found');
        return;
      }

      if (!inDesignMode) {
        return;
      }

      event.preventDefault();
      event.stopPropagation();

      try {
        try {
          if (window.top && typeof window.top.open === 'function') {
            var topOpened = window.top.open(url, '_blank', 'noopener');
            if (topOpened) {
              return;
            }
          }
          if (typeof window.open === 'function') {
            var previewOpened = window.open(url, '_blank', 'noopener');
            if (previewOpened) {
              return;
            }
          }
        } catch (topError) {
          if (shouldDebugPrintable && typeof console !== 'undefined') {
            console.warn('[sss auto exclusive] top window open failed, falling back to direct location', topError);
          }
        }

        if (window.top && window.top.location) {
          window.top.location.assign(url);
        } else {
          window.location.assign(url);
        }
      } catch (error) {
        if (shouldDebugPrintable && typeof console !== 'undefined') {
          console.warn('[sss auto exclusive] printable open failed, falling back to location.assign', error);
        }
        if (window.top && window.top.location) {
          window.top.location.assign(url);
        } else {
          window.location.assign(url);
        }
      }
    });

    link.dataset.printableTrackingReady = 'true';
  });
}

document.addEventListener('DOMContentLoaded', sssInitPhysicalCollection);
document.addEventListener('DOMContentLoaded', sssInitCollectionFilters);
document.addEventListener('DOMContentLoaded', sssInitCollectionRails);
document.addEventListener('DOMContentLoaded', sssInitPrintableDownloadTracking);
sssInitPhysicalCollection();
sssInitCollectionFilters();
sssInitCollectionRails();
sssInitPrintableDownloadTracking();
document.addEventListener('shopify:section:load', sssInitPhysicalCollection);
document.addEventListener('shopify:section:load', sssInitCollectionFilters);
document.addEventListener('shopify:section:load', sssInitCollectionRails);
document.addEventListener('shopify:section:load', sssInitPrintableDownloadTracking);

</script>

{%- else -%}
  <div style="padding:16px 12px; background:#0b0b0b; color:#f6f6f6; font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;">
    no active drop found — set a release_date on your sss_drop (and make sure it’s published).
  </div>
{%- endif -%}

{% schema %}
{
  "name": "auto exclusive",
  "settings": [
    { "type": "checkbox", "id": "debug", "label": "debug: show what the section sees", "default": false },
    { "type": "checkbox", "id": "preview_mode", "label": "preview mode (force a specific drop)", "default": false },
    { "type": "text", "id": "preview_drop_handle", "label": "preview drop handle (recommended)", "default": "romantically-unwell" },
    { "type": "text", "id": "preview_drop_name", "label": "preview drop name (exact match)", "default": "romantically unwell" }
  ],
  "presets": [
    { "name": "auto exclusive" }
  ]
}
{% endschema %}
