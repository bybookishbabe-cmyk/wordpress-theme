<style>
  .ki-shelf{
    background:#000;
    color:#f7f3ee;
    padding:42px 0;
  }
  .ki-shelf__wrap{
    max-width:1100px;
    margin:0 auto;
    padding:0 20px;
  }

  .ki-shelf__head{
    margin-bottom:14px;
  }

  .ki-shelf__seasonal{
    position:relative;
    margin-bottom:26px;
    padding:26px 22px 22px;
    border-radius:24px;
    border:1px solid rgba(255,255,255,.1);
    background:
      radial-gradient(circle at 18% 22%, rgba(255, 192, 222, .14), transparent 32%),
      radial-gradient(circle at 82% 30%, rgba(201, 255, 216, .08), transparent 28%),
      linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
    overflow:hidden;
  }

  .ki-shelf__seasonalFloat{
    position:absolute;
    inset:0;
    pointer-events:none;
  }

  .ki-shelf__seasonalFloat span{
    position:absolute;
    opacity:.2;
    filter:blur(.1px);
    animation:kiSeasonFloat 8s ease-in-out infinite;
  }

  .ki-shelf__seasonalFloat span:nth-child(1){ top:18px; left:22px; font-size:22px; animation-delay:0s; }
  .ki-shelf__seasonalFloat span:nth-child(2){ top:26px; right:58px; font-size:18px; animation-delay:1.2s; }
  .ki-shelf__seasonalFloat span:nth-child(3){ bottom:18px; left:18%; font-size:16px; animation-delay:2.4s; }
  .ki-shelf__seasonalFloat span:nth-child(4){ bottom:20px; right:16%; font-size:20px; animation-delay:3.1s; }
  .ki-shelf__seasonalFloat span:nth-child(5){ top:48%; left:50%; font-size:14px; animation-delay:1.8s; }

  .ki-shelf__seasonalKicker{
    position:relative;
    z-index:1;
    margin:0 0 8px;
    font-size:11px;
    letter-spacing:.18em;
    text-transform:uppercase;
    color:rgba(247,243,238,.64);
  }

  .ki-shelf__seasonalTitle{
    position:relative;
    z-index:1;
    margin:0;
    font-size:clamp(24px, 4vw, 38px);
    line-height:1.02;
  }

  .ki-shelf__seasonalTitle em{
    font-style:normal;
    color:#ffc6df;
  }

  .ki-shelf__seasonalSub{
    position:relative;
    z-index:1;
    margin:10px 0 0;
    max-width:42ch;
    opacity:.82;
  }

  .ki-shelf__seasonalBtn{
    position:relative;
    z-index:1;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    margin-top:16px;
    min-height:42px;
    padding:0 16px;
    border-radius:999px;
    border:1px solid rgba(255,255,255,.14);
    background:rgba(255,255,255,.06);
    color:#f7f3ee;
    text-decoration:none;
    transition:transform .2s ease, border-color .2s ease, background .2s ease;
  }

  .ki-shelf__seasonalBtn:hover{
    transform:translateY(-2px);
    border-color:rgba(255, 198, 223, .42);
    background:rgba(255, 198, 223, .12);
  }
  .ki-shelf__title{
    margin:0 0 8px;
    font-size:22px;
    line-height:1.2;
  }
  .ki-shelf__sub{
    margin:0;
    opacity:.82;
    max-width:720px;
  }

  /* horizontal “shelf” */
  .ki-shelf__row{
    margin-top:18px;
    display:flex;
    gap:14px;
    overflow-x:auto;
    padding:8px 2px 14px;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch;
  }
  .ki-shelf__row::-webkit-scrollbar{ height:8px; }
  .ki-shelf__row::-webkit-scrollbar-thumb{
    background:rgba(255,255,255,.14);
    border-radius:999px;
  }

  .ki-shelf__card{
    flex:0 0 72%;
    max-width:72%;
    scroll-snap-align:start;
    background:#f7f3ee;
    color:#1e1b1c;
    border-radius:16px;
    overflow:hidden;
    text-decoration:none;
    box-shadow:0 18px 40px rgba(0,0,0,.45);
  }

  @media(min-width:750px){
    .ki-shelf__card{ flex-basis: 32%; max-width:32%; }
  }
  @media(min-width:990px){
    .ki-shelf__card{ flex-basis: 26%; max-width:26%; }
  }

 /* ---------- SHELF MEDIA: FIT TO IMAGE ---------- */
.ki-shelf__media{
  background:transparent;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:10px;
}

.ki-shelf__media img{
  width:100%;
  height:auto;
  max-height:320px;   /* controls shelf card height */
  object-fit:contain; /* KEY: no cropping */
  display:block;
}

  .ki-shelf__body{
    padding:14px 14px 16px;
  }

  .ki-shelf__pill{
    display:inline-block;
    background:#000;
    color:#f7f3ee;
    padding:6px 10px;
    border-radius:999px;
    font-size:11px;
    letter-spacing:.12em;
    text-transform:uppercase;
    border:1px solid rgba(255,255,255,.12);
    margin-bottom:10px;
  }

  .ki-shelf__name{
    margin:0 0 6px;
    font-size:16px;
    line-height:1.25;
  }
  .ki-shelf__desc{
    margin:0;
    opacity:.78;
    font-size:13px;
    line-height:1.4;
  }
  /* hide shelf collection titles */
.ki-shelf__title h3 {
  display: none;
}

  @keyframes kiSeasonFloat{
    0%, 100%{ transform:translateY(0) rotate(0deg); opacity:.16; }
    50%{ transform:translateY(8px) rotate(4deg); opacity:.3; }
  }

  @media (max-width: 749px){
    .ki-shelf__seasonal{
      padding:22px 16px 18px;
      border-radius:20px;
      margin-bottom:22px;
    }

    .ki-shelf__seasonalTitle{
      font-size:30px;
    }

    .ki-shelf__seasonalSub{
      font-size:14px;
    }
  }
</style>

<section class="ki-shelf">
  <div class="ki-shelf__wrap">
    {% assign seasonal_collection = collections[section.settings.seasonal_collection] %}
    {% if seasonal_collection != blank %}
      <div class="ki-shelf__seasonal">
        <div class="ki-shelf__seasonalFloat" aria-hidden="true">
          <span>{{ section.settings.seasonal_emoji_one }}</span>
          <span>{{ section.settings.seasonal_emoji_two }}</span>
          <span>{{ section.settings.seasonal_emoji_three }}</span>
          <span>{{ section.settings.seasonal_emoji_four }}</span>
          <span>{{ section.settings.seasonal_emoji_five }}</span>
        </div>
        <p class="ki-shelf__seasonalKicker">{{ section.settings.seasonal_kicker }}</p>
        <h2 class="ki-shelf__seasonalTitle">inserts for <em>{{ section.settings.season_name }}</em></h2>
        {% if section.settings.seasonal_subtitle != blank %}
          <p class="ki-shelf__seasonalSub">{{ section.settings.seasonal_subtitle }}</p>
        {% endif %}
        <a class="ki-shelf__seasonalBtn" href="{{ seasonal_collection.url }}">{{ section.settings.seasonal_button }}</a>
      </div>
    {% endif %}

    <div class="ki-shelf__head">
      <h2 class="ki-shelf__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="ki-shelf__sub">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ki-shelf__row" role="list">
      {% for block in section.blocks %}
        {% if block.type == 'style' and block.settings.collection != blank %}
          {% assign col = collections[block.settings.collection] %}
          {% if col != blank %}
            <a class="ki-shelf__card" href="{{ col.url }}" {{ block.shopify_attributes }}>
              <div class="ki-shelf__media">
                {% if col.featured_image %}
                  {{ col.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: col.title }}
                {% endif %}
              </div>
              <div class="ki-shelf__body">
                <span class="ki-shelf__pill">{{ block.settings.pill_label }}</span>
                {% if block.settings.description != blank %}
                  <p class="ki-shelf__desc">{{ block.settings.description }}</p>
                {% endif %}
              </div>
            </a>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ki style shelf",
  "settings": [
    { "type": "collection", "id": "seasonal_collection", "label": "seasonal collection" },
    { "type": "text", "id": "seasonal_kicker", "label": "seasonal kicker", "default": "seasonal drop" },
    { "type": "text", "id": "season_name", "label": "season name", "default": "spring" },
    { "type": "text", "id": "seasonal_subtitle", "label": "seasonal subtitle", "default": "fresh little flowers, soft color, and the kind of inserts that make your kindle feel like spring on your nightstand." },
    { "type": "text", "id": "seasonal_button", "label": "seasonal button", "default": "shop the spring shelf →" },
    { "type": "text", "id": "seasonal_emoji_one", "label": "seasonal emoji 1", "default": "🌸" },
    { "type": "text", "id": "seasonal_emoji_two", "label": "seasonal emoji 2", "default": "🌷" },
    { "type": "text", "id": "seasonal_emoji_three", "label": "seasonal emoji 3", "default": "🌼" },
    { "type": "text", "id": "seasonal_emoji_four", "label": "seasonal emoji 4", "default": "🪻" },
    { "type": "text", "id": "seasonal_emoji_five", "label": "seasonal emoji 5", "default": "🍃" },
    { "type": "text", "id": "title", "label": "title", "default": "shop by style" },
    { "type": "text", "id": "subtitle", "label": "subtitle", "default": "pick a vibe. browse like a library. stay as long as you like." }
  ],
  "blocks": [
    {
      "type": "style",
      "name": "style",
      "settings": [
        { "type": "collection", "id": "collection", "label": "collection" },
        { "type": "text", "id": "pill_label", "label": "pill label", "default": "aesthetic" },
        { "type": "text", "id": "description", "label": "description", "default": "a shelf you’ll keep coming back to." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "ki style shelf" }
  ]
}
{% endschema %}
