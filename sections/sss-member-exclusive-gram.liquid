{% comment %}
  sss-member-exclusive-gram.liquid

  Progressive render:
  - Shows whatever is filled out (no minimums).
  - Pulls current drop from metaobject sss_drop by most recent release_date <= today (Active only).
  - Printable/Physical panels come from drop.items (sss_drop_item) by item_type.
  - Gram card comes from fields on the drop.
{% endcomment %}

{%- assign active_drop = nil -%}
{%- assign now_ts = 'now' | date: '%s' | plus: 0 -%}
{%- assign best_ts = 0 -%}

{%- if shop.metaobjects.sss_drop != blank -%}
  {%- for d in shop.metaobjects.sss_drop.values -%}
    {%- comment -%}Skip drafts when Active/Draft is enabled{%- endcomment -%}
    {%- if d.system != blank and d.system.published_at == blank -%}
      {%- continue -%}
    {%- endif -%}

    {%- if d.release_date != blank -%}
      {%- assign d_ts = d.release_date | date: '%s' | plus: 0 -%}
      {%- if d_ts <= now_ts and d_ts >= best_ts -%}
        {%- assign best_ts = d_ts -%}
        {%- assign active_drop = d -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%}
  Only render output if we found an active drop.
{%- endcomment -%}
{%- if active_drop != nil -%}

  {%- assign quote_text = active_drop.quote_text -%}
  {%- assign kicker     = 'monthly collection' -%}
  {%- assign title      = 'society member exclusive' -%}
  {%- assign subtext    = 'this insert is available for paid members - printable is included of course, but you can also purchase a physical one.' -%}

  {%- assign gram_kicker  = active_drop.gram_kicker -%}
  {%- assign gram_title   = active_drop.gram_title -%}
  {%- assign gram_sub     = active_drop.gram_sub -%}
  {%- assign gram_image   = active_drop.gram_image -%}
  {%- assign gram_caption = active_drop.gram_caption -%}
  {%- assign gram_url     = 'https://www.instagram.com/bybookishbabe/' -%}
  {%- assign bonus_printable_product = active_drop.bonus_printable_product.value | default: active_drop.bonus_printable_product -%}
  {%- assign bonus_physical_product  = active_drop.bonus_physical_product.value  | default: active_drop.bonus_physical_product -%}
  {%- assign monthly_collection_printable_products = active_drop.monthly_collection_printable_products.value | default: active_drop.monthly_collection_printable_products -%}
  {%- assign monthly_collection_physical_products = active_drop.monthly_collection_physical_products.value | default: active_drop.monthly_collection_physical_products -%}
  {%- assign has_monthly_collection = false -%}
  {%- if monthly_collection_printable_products != blank or monthly_collection_physical_products != blank -%}
    {%- assign has_monthly_collection = true -%}
  {%- endif -%}

  {%- assign printable_item = nil -%}
  {%- assign physical_item  = nil -%}

  {%- if active_drop.items != blank -%}
    {%- for it in active_drop.items.value -%}
      {%- assign t = it.item_type | downcase -%}
      {%- if t == 'printable' and printable_item == nil -%}{%- assign printable_item = it -%}{%- endif -%}
      {%- if t == 'physical'  and physical_item  == nil -%}{%- assign physical_item  = it -%}{%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- assign show_printable = false -%}
  {%- assign show_physical  = false -%}
  {%- assign show_gram      = false -%}

  {%- if printable_item != nil -%}
    {%- if printable_item.pill != blank or printable_item.image != blank or printable_item.note != blank or printable_item.dl_12th != blank or printable_item.dl_11th != blank or printable_item.dl_6in != blank or printable_item.dl_10th != blank -%}
      {%- assign show_printable = true -%}
    {%- endif -%}
  {%- endif -%}

  {%- if physical_item != nil -%}
    {%- if physical_item.pill != blank or physical_item.image != blank or physical_item.note != blank or physical_item.v_12th != blank or physical_item.v_11th != blank or physical_item.v_6in != blank or physical_item.v_10th != blank -%}
      {%- assign show_physical = true -%}
    {%- endif -%}
  {%- endif -%}

  {%- if gram_kicker != blank or gram_title != blank or gram_sub != blank or gram_image != blank or gram_caption != blank -%}
    {%- assign show_gram = true -%}
  {%- endif -%}

  {%- comment -%}Printable fields{%- endcomment -%}
  {%- assign printable_pill  = printable_item.pill -%}
  {%- assign printable_image = printable_item.image -%}
  {%- assign printable_note  = printable_item.note -%}
  {%- assign dl12 = printable_item.dl_12th -%}
  {%- assign dl11 = printable_item.dl_11th -%}
  {%- assign dl6  = printable_item.dl_6in  -%}
  {%- assign dl10 = printable_item.dl_10th -%}

  {%- comment -%}Physical fields{%- endcomment -%}
  {%- assign physical_pill  = physical_item.pill -%}
  {%- assign physical_image = physical_item.image -%}
  {%- assign physical_note  = physical_item.note -%}
  {%- assign product_name   = physical_item.product_name | default: active_drop.name -%}
  {%- assign price_label    = physical_item.price_label | default: '$9' -%}
  {%- assign v12 = physical_item.v_12th -%}
  {%- assign v11 = physical_item.v_11th -%}
  {%- assign v6  = physical_item.v_6in  -%}
  {%- assign v10 = physical_item.v_10th -%}

  {%- assign show12 = false -%}
  {%- assign show11 = false -%}
  {%- assign show6  = false -%}
  {%- assign show10 = false -%}
  {%- if v12 != blank and v12 != '0' -%}{%- assign show12 = true -%}{%- endif -%}
  {%- if v11 != blank and v11 != '0' -%}{%- assign show11 = true -%}{%- endif -%}
  {%- if v6  != blank and v6  != '0' -%}{%- assign show6  = true -%}{%- endif -%}
  {%- if v10 != blank and v10 != '0' -%}{%- assign show10 = true -%}{%- endif -%}

  {%- assign printable_product_name = '' -%}
  {%- assign printable_price_label = 'free' -%}
  {%- assign printable_v12 = blank -%}
  {%- assign printable_v11 = blank -%}
  {%- assign printable_v6 = blank -%}
  {%- assign printable_v10 = blank -%}
  {%- assign printable_show12 = false -%}
  {%- assign printable_show11 = false -%}
  {%- assign printable_show6 = false -%}
  {%- assign printable_show10 = false -%}
  {%- assign printable_product_url = '' -%}
  {%- assign printable_fallback_variant = blank -%}

  {%- if bonus_printable_product != blank -%}
    {%- assign printable_pill = printable_pill | default: 'bonus printable' -%}
    {%- assign printable_fallback_variant = bonus_printable_product.selected_or_first_available_variant -%}
    {%- assign printable_image = bonus_printable_product.featured_image | default: bonus_printable_product.featured_media.preview_image | default: printable_fallback_variant.featured_image | default: printable_fallback_variant.image | default: bonus_printable_product.images.first | default: printable_image -%}
    {%- assign printable_product_name = bonus_printable_product.title | strip -%}
    {%- assign printable_product_url = bonus_printable_product.url -%}
    {%- assign printable_dl12 = blank -%}
    {%- assign printable_dl11 = blank -%}
    {%- assign printable_dl6 = blank -%}
    {%- assign printable_dl10 = blank -%}
    {%- if printable_fallback_variant != blank -%}
        {%- assign printable_price_label = 'free' -%}
    {%- endif -%}
    {%- for variant in bonus_printable_product.variants -%}
      {%- assign variant_title = variant.title | downcase -%}
      {%- assign variant_download = blank -%}
      {%- if variant.metafields.custom.download_file.value != blank -%}
        {%- if variant.metafields.custom.download_file.value.url != blank -%}
          {%- assign variant_download = variant.metafields.custom.download_file.value.url -%}
        {%- else -%}
          {%- assign variant_download = variant.metafields.custom.download_file.value | file_url -%}
        {%- endif -%}
      {%- endif -%}
      {%- if variant_download contains 'dropbox.com' -%}
        {%- assign variant_download = variant_download | replace: 'www.dropbox.com', 'dl.dropboxusercontent.com' | replace: 'dropbox.com', 'dl.dropboxusercontent.com' | replace: '?dl=0', '?raw=1' | replace: '&dl=0', '&raw=1' -%}
      {%- endif -%}
      {%- if printable_v12 == blank and variant_title contains '12th' -%}{%- assign printable_v12 = variant.id -%}{%- assign printable_dl12 = variant_download -%}{%- endif -%}
      {%- if printable_v11 == blank and variant_title contains '11th' -%}{%- assign printable_v11 = variant.id -%}{%- assign printable_dl11 = variant_download -%}{%- endif -%}
      {%- if printable_v6 == blank and variant_title contains '6' -%}{%- assign printable_v6 = variant.id -%}{%- assign printable_dl6 = variant_download -%}{%- endif -%}
      {%- if printable_v10 == blank and variant_title contains '10th' -%}{%- assign printable_v10 = variant.id -%}{%- assign printable_dl10 = variant_download -%}{%- endif -%}
    {%- endfor -%}
    {%- assign printable_product_download = blank -%}
    {%- if bonus_printable_product.metafields.custom.download_file.value != blank -%}
      {%- if bonus_printable_product.metafields.custom.download_file.value.url != blank -%}
        {%- assign printable_product_download = bonus_printable_product.metafields.custom.download_file.value.url -%}
      {%- else -%}
        {%- assign printable_product_download = bonus_printable_product.metafields.custom.download_file.value | file_url -%}
      {%- endif -%}
    {%- endif -%}
    {%- if printable_product_download contains 'dropbox.com' -%}
      {%- assign printable_product_download = printable_product_download | replace: 'www.dropbox.com', 'dl.dropboxusercontent.com' | replace: 'dropbox.com', 'dl.dropboxusercontent.com' | replace: '?dl=0', '?raw=1' | replace: '&dl=0', '&raw=1' -%}
    {%- endif -%}
    {%- if printable_dl12 == blank -%}{%- assign printable_dl12 = printable_product_download -%}{%- endif -%}
    {%- if printable_dl11 == blank -%}{%- assign printable_dl11 = printable_product_download -%}{%- endif -%}
    {%- if printable_dl6 == blank -%}{%- assign printable_dl6 = printable_product_download -%}{%- endif -%}
    {%- if printable_dl10 == blank -%}{%- assign printable_dl10 = printable_product_download -%}{%- endif -%}
    {%- if printable_v12 != blank -%}{%- assign printable_show12 = true -%}{%- endif -%}
    {%- if printable_v11 != blank -%}{%- assign printable_show11 = true -%}{%- endif -%}
    {%- if printable_v6  != blank -%}{%- assign printable_show6  = true -%}{%- endif -%}
    {%- if printable_v10 != blank -%}{%- assign printable_show10 = true -%}{%- endif -%}
    {%- if printable_show12 == false and printable_show11 == false and printable_show6 == false and printable_show10 == false and printable_fallback_variant != blank -%}
      {%- assign printable_v12 = printable_fallback_variant.id -%}
      {%- assign printable_show12 = true -%}
    {%- endif -%}
    {%- assign show_printable = true -%}
  {%- endif -%}

  {%- assign physical_product_url = '' -%}
  {%- if bonus_physical_product != blank -%}
    {%- assign physical_pill = physical_pill | default: 'bonus physical' -%}
    {%- assign physical_default_variant = bonus_physical_product.selected_or_first_available_variant -%}
    {%- assign physical_image = bonus_physical_product.featured_image | default: bonus_physical_product.featured_media.preview_image | default: physical_default_variant.featured_image | default: physical_default_variant.image | default: bonus_physical_product.images.first | default: physical_image -%}
    {%- assign product_name = bonus_physical_product.title | strip -%}
    {%- assign physical_product_url = bonus_physical_product.url -%}
    {%- if physical_default_variant != blank -%}
      {%- assign price_label = physical_default_variant.price | money_without_trailing_zeros -%}
    {%- endif -%}
    {%- assign v12 = blank -%}
    {%- assign v11 = blank -%}
    {%- assign v6 = blank -%}
    {%- assign v10 = blank -%}
    {%- for variant in bonus_physical_product.variants -%}
      {%- assign variant_title = variant.title | downcase -%}
      {%- if v12 == blank and variant_title contains '12th' -%}{%- assign v12 = variant.id -%}{%- endif -%}
      {%- if v11 == blank and variant_title contains '11th' -%}{%- assign v11 = variant.id -%}{%- endif -%}
      {%- if v6 == blank and variant_title contains '6' -%}{%- assign v6 = variant.id -%}{%- endif -%}
      {%- if v10 == blank and variant_title contains '10th' -%}{%- assign v10 = variant.id -%}{%- endif -%}
    {%- endfor -%}
    {%- assign show12 = false -%}
    {%- assign show11 = false -%}
    {%- assign show6 = false -%}
    {%- assign show10 = false -%}
    {%- if v12 != blank -%}{%- assign show12 = true -%}{%- endif -%}
    {%- if v11 != blank -%}{%- assign show11 = true -%}{%- endif -%}
    {%- if v6  != blank -%}{%- assign show6  = true -%}{%- endif -%}
    {%- if v10 != blank -%}{%- assign show10 = true -%}{%- endif -%}
    {%- if show12 == false and show11 == false and show6 == false and show10 == false and physical_default_variant != blank -%}
      {%- assign v12 = physical_default_variant.id -%}
      {%- assign show12 = true -%}
    {%- endif -%}
    {%- assign show_physical = true -%}
  {%- endif -%}

<style>
  /* ===== OUTER WRAP (two-column layout) ===== */
  .sss-mpg{
    background:#0b0b0b;
    color:#f6f6f6;
    padding:18px 12px;
    font-family:"Libre Baskerville", Georgia, serif;
    position:relative;
    overflow:hidden;
  }
  .sss-mpg:before{
    content:"";
    position:absolute; inset:-40px;
    pointer-events:none;
    background:
      radial-gradient(900px 520px at 50% 120px, rgba(255,255,255,.08), transparent 70%),
      repeating-linear-gradient(
        to bottom,
        rgba(255,255,255,.035),
        rgba(255,255,255,.035) 1px,
        transparent 1px,
        transparent 26px
      );
    opacity:.55;
  }
  .sss-mpg__wrap{
    max-width:1300px;
    margin:0 auto;
    position:relative;
    z-index:1;
    padding:0 8px;
  }
  .sss-mpg__grid{
    display:grid;
    grid-template-columns:1fr;
    gap:14px;
    align-items:start;
  }
  @media(min-width:990px){
    .sss-mpg__grid{
      grid-template-columns: 1.12fr .88fr;
      gap:16px;
    }
  }

  .sss-me2{ color:#f6f6f6; }
  .sss-me2 a{ color:inherit; text-decoration:none; }

  .sss-me2__kicker{
    margin:0 0 10px;
    font-size:12px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:#c8c8c8;
  }

  .sss-me2__card{
    background:rgba(21,21,21,.92);
    border:1px solid #2a2a2a;
    border-radius:18px;
    box-shadow:0 12px 28px rgba(0,0,0,.45);
    overflow:hidden;
  }

  .sss-me2__head{
    padding:10px 12px 8px;
    border-bottom:1px solid #2a2a2a;
    background:rgba(255,255,255,.03);
  }

  .sss-me2__title{
    margin:0;
    font-size:17px;
    font-weight:400;
    text-transform:lowercase;
  }

  .sss-me2__sub{
    margin:6px 0 0;
    font-size:12px;
    line-height:1.55;
    color:#c8c8c8;
  }

  .sss-me2__collection{
    margin:0 0 16px;
    padding:10px;
    border:1px solid #2a2a2a;
    border-radius:18px;
    background:rgba(21,21,21,.92);
    box-shadow:0 12px 28px rgba(0,0,0,.45);
    display:grid;
    gap:14px;
  }
  .sss-me2__collectionIntro{
    display:grid;
    gap:4px;
  }
  .sss-me2__collectionKicker{
    margin:0;
    font-size:11px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:rgba(246,246,246,.62);
  }
  .sss-me2__collectionTitle{
    margin:0;
    font-size:22px;
    line-height:1.08;
    text-transform:lowercase;
    color:#fff;
  }
  .sss-me2__collectionSub{
    margin:0;
    max-width:720px;
    font-size:11px;
    line-height:1.5;
    color:rgba(246,246,246,.72);
    text-transform:lowercase;
  }
  .sss-me2__collectionGrid{
    display:grid;
    grid-template-columns:1fr;
    gap:12px;
  }
  .sss-me2__collectionGroup{
    display:grid;
    gap:8px;
  }
  .sss-me2__collectionLabel{
    margin:0;
    font-size:10px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:rgba(246,246,246,.58);
  }
  .sss-me2__collectionRail{
    display:flex;
    flex-wrap:wrap;
    align-items:flex-start;
    gap:8px;
  }
  .sss-me2__productCard{
    display:grid;
    gap:7px;
    padding:9px;
    width:178px;
    border-radius:16px;
    border:1px solid rgba(255,255,255,.08);
    background:rgba(255,255,255,.03);
    text-decoration:none;
    color:#f6f6f6;
    transition:transform .18s ease, border-color .18s ease, background .18s ease;
  }
  .sss-me2__productCard:hover{
    transform:translateY(-2px);
    border-color:rgba(255,255,255,.18);
    background:rgba(255,255,255,.05);
  }
  .sss-me2__productImage{
    width:100%;
    aspect-ratio:1 / 1;
    border-radius:12px;
    overflow:hidden;
    background:#111;
    border:1px solid rgba(255,255,255,.08);
  }
  .sss-me2__productImage img{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }
  .sss-me2__productMeta{
    display:grid;
    gap:4px;
  }
  .sss-me2__productTag{
    font-size:10px;
    letter-spacing:.12em;
    text-transform:uppercase;
    color:rgba(246,246,246,.48);
  }
  .sss-me2__productActions{
    margin-top:4px;
    display:grid;
    gap:6px;
  }
  .sss-me2__collectionGroupHead{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
  }
  .sss-me2__collectionAll{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:32px;
    padding:0 12px;
    border-radius:999px;
    border:1px solid rgba(255,255,255,.14);
    background:rgba(255,255,255,.04);
    color:#f6f6f6;
    text-decoration:none;
    font-size:11px;
    letter-spacing:.08em;
    text-transform:lowercase;
    cursor:pointer;
    transition:background .18s ease, border-color .18s ease, transform .18s ease;
  }
  .sss-me2__collectionAll:hover{
    background:rgba(255,255,255,.08);
    border-color:rgba(255,255,255,.22);
    transform:translateY(-1px);
  }
  .sss-me2__productBtn{
    display:flex;
    justify-content:center;
    align-items:center;
    width:100%;
    min-height:38px;
    padding:0 12px;
    border-radius:12px;
    border:1px solid rgba(255,255,255,.14);
    background:rgba(255,255,255,.06);
    color:#f6f6f6;
    text-decoration:none;
    font-size:12px;
    cursor:pointer;
    transition:background .18s ease, border-color .18s ease, transform .18s ease;
  }
  .sss-me2__productBtn:hover{
    background:rgba(255,255,255,.1);
    border-color:rgba(255,255,255,.22);
    transform:translateY(-1px);
  }
  @media(min-width:990px){
    .sss-me2__collectionGrid{
      grid-template-columns:1fr 1fr;
    }
  }
  @media(max-width:749px){
    .sss-me2__productCard{
      width:calc(50% - 4px);
      min-width:0;
    }
    .sss-me2__collectionGroupHead{
      align-items:flex-start;
      flex-direction:column;
      gap:6px;
    }
  }
  .sss-me2__productName{
    margin:0;
    font-size:13px;
    line-height:1.35;
    text-transform:lowercase;
    color:#fff;
  }
  .sss-me2__productPrice{
    font-size:12px;
    color:rgba(246,246,246,.74);
    text-transform:lowercase;
  }

  .sss-me2__grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
    padding:10px;
  }

  .sss-me2__panel{
    border:1px solid #2a2a2a;
    border-radius:16px;
    background:rgba(255,255,255,.02);
    overflow:hidden;
  }

  .sss-me2__panelTop{
    padding:8px 10px;
    border-bottom:1px solid #2a2a2a;
    background:rgba(255,255,255,.03);
    display:flex;
    justify-content:center;
  }

  .sss-me2__pill{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-size:11px;
    padding:5px 10px;
    border-radius:999px;
    border:1px solid #2a2a2a;
    background:rgba(255,255,255,.06);
    color:#c8c8c8;
    text-transform:lowercase;
  }

  .sss-me2__media{ padding:8px; }

  .sss-me2__media img{
    width:100%;
    height:auto;
    max-height:220px;
    object-fit:contain;
    display:block;
    background:#0f0f0f;
    border:1px solid #2a2a2a;
    border-radius:14px;
    padding:8px;
    box-sizing:border-box;
  }

  .sss-me2__note{
    margin:8px 0 0;
    font-size:11px;
    color:#9e9e9e;
    text-align:center;
    font-style:italic;
    padding:0 10px 0;
  }

  .sss-me2__btnWrap{ padding:10px; }

  .sss-me2__productLine{
    margin:0 0 10px;
    font-size:12px;
    line-height:1.45;
    color:#1E1B1C;
    text-align:center;
    text-transform:lowercase;
    padding:0 4px;
  }

  .sss-me2__btnGrid{
    display:grid;
    gap:8px;
  }

  .sss-me2__btn{
    display:flex;
    justify-content:center;
    align-items:center;
    width:100%;
    height:40px;
    padding:0 12px;
    border-radius:12px;
    border:1px solid #2a2a2a;
    background:rgba(255,255,255,.06);
    color:#f6f6f6;
    font-size:12.5px;
    cursor:pointer;
    text-align:center;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
    box-sizing:border-box;
    appearance:none;
    -webkit-appearance:none;
    margin:0;
    font:inherit;
  }
  .sss-me2__btn:hover{
    background:rgba(255,255,255,.10);
    border-color:#5a5a5a;
  }
  .sss-me2__btn[disabled]{
    opacity:.55;
    cursor:not-allowed;
  }

  .sss-me2__panel{
    position:relative;
    background:#F7F3EE;
    background-image:repeating-linear-gradient(
      to bottom,
      rgba(30,27,28,.12) 0,
      rgba(30,27,28,.12) 1px,
      transparent 1px,
      transparent 28px
    );
    border:2px solid rgba(30,27,28,.85);
    box-shadow:0 10px 24px rgba(0,0,0,.25);
    color:#1E1B1C;
  }
  .sss-me2__panel::before{
    content:"";
    position:absolute;
    top:12px; left:12px;
    width:12px; height:12px;
    border-radius:999px;
    background:#000;
    box-shadow:
      0 0 0 3px rgba(247,243,238,.95),
      0 0 0 4px rgba(30,27,28,.9);
    z-index:2;
  }
  .sss-me2__panelTop{
    background:rgba(30,27,28,.04);
    border-bottom:1px solid rgba(30,27,28,.25);
  }
  .sss-me2__panel .sss-me2__pill{
    background:#000;
    color:#F7F3EE;
    border:1px solid #000;
  }
  .sss-me2__panel .sss-me2__note{ color:rgba(30,27,28,.7); }
  .sss-me2__panel .sss-me2__media img{
    background:rgba(0,0,0,.04);
    border:1px solid rgba(30,27,28,.25);
  }
  .sss-me2__panel .sss-me2__btn{
    background:rgba(247,243,238,.95);
    color:#1E1B1C;
    border:1px solid rgba(30,27,28,.4);
  }
  .sss-me2__panel .sss-me2__btn:hover{
    background:#fff;
    border-color:rgba(30,27,28,.6);
  }

  .gramcard{
    background:rgba(21,21,21,.92);
    border:1px solid #2a2a2a;
    border-radius:18px;
    box-shadow:0 12px 28px rgba(0,0,0,.45);
    overflow:hidden;
    color:#f6f6f6;
  }
  .gramcard__head{
    padding:10px 12px 8px;
    border-bottom:1px solid #2a2a2a;
    background:rgba(255,255,255,.03);
  }
  .gramcard__kicker{
    margin:0 0 6px;
    font-size:12px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:#c8c8c8;
  }
  .gramcard__title{
    margin:0;
    font-size:17px;
    font-weight:400;
    text-transform:lowercase;
  }
  .gramcard__sub{
    margin:6px 0 0;
    font-size:12px;
    line-height:1.55;
    color:#c8c8c8;
  }
  .gramcard__body{ padding:10px; }

  .gramcard__img{
    width:100%;
    height:auto;
    max-height:520px;
    object-fit:contain;
    display:block;
    border-radius:14px;
    border:1px solid #2a2a2a;
    background:#0f0f0f;
    padding:8px;
    box-sizing:border-box;
  }

  .gramcard__caption{
    margin:10px 0 0;
    font-size:12.5px;
    line-height:1.55;
    color:rgba(246,246,246,.78);
  }

  .gramcard__btn{
    margin-top:12px;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:10px 12px;
    border-radius:12px;
    border:1px solid #2a2a2a;
    background:rgba(255,255,255,.06);
    color:#f6f6f6;
    text-decoration:none;
    font-size:13px;
  }
  .gramcard__btn:hover{
    background:rgba(255,255,255,.10);
    border-color:#5a5a5a;
  }
  @media (min-width:990px){
    .gramcard{ margin-top:22px; }
  }

  .sss-toast{
    position:fixed;
    left:50%;
    top:50%;
    transform:translate(-50%, -50%) scale(.96);
    background:rgba(0,0,0,.88);
    border:1px solid rgba(255,255,255,.22);
    color:#fff;
    padding:14px 18px;
    border-radius:18px;
    font-size:14px;
    line-height:1.35;
    z-index:9999;
    opacity:0;
    pointer-events:none;
    box-shadow:0 18px 40px rgba(0,0,0,.6);
    transition:opacity .18s ease, transform .18s ease;
    text-align:center;
  }
  .sss-toast span{
    display:block;
    margin-top:4px;
    font-size:12px;
    opacity:.75;
  }
  .sss-toast.show{
    opacity:1;
    transform:translate(-50%, -50%) scale(1);
  }

  @media (max-width:989px){
    .sss-mpg__grid > .gramcard{ order:-1; }
  }

  .sss-quote{
    max-width:1100px;
    margin:0 auto 16px;
    padding:6px 12px 6px 16px;
    display:flex;
    gap:12px;
    align-items:flex-start;
  }
  .sss-quote__bar{
    width:3px;
    background:#b91c1c;
    border-radius:2px;
    flex-shrink:0;
    margin-top:4px;
  }
  .sss-quote__text{
    margin:0;
    font-size:15px;
    line-height:1.6;
    color:#f6f6f6;
    font-style:italic;
  }
  @media(max-width:600px){
    .sss-quote{ margin-bottom:12px; }
    .sss-quote__text{ font-size:14px; }
  }
</style>

<section class="sss-mpg">
  <div class="sss-mpg__wrap">

    {% if quote_text != blank %}
      <div class="sss-quote">
        <span class="sss-quote__bar"></span>
        <blockquote class="sss-quote__text">{{ quote_text }}</blockquote>
      </div>
    {% endif %}

    {% if has_monthly_collection %}
      <section class="sss-me2__collection">
        <div class="sss-me2__collectionIntro">
          <h3 class="sss-me2__collectionTitle">digital on the left. physical on the right.</h3>
          <p class="sss-me2__collectionSub">the current month’s products, all in one place.</p>
        </div>
        <div class="sss-me2__collectionGrid">
          {% if monthly_collection_printable_products != blank %}
            <div class="sss-me2__collectionGroup">
              <p class="sss-me2__collectionLabel">digital</p>
              <div class="sss-me2__collectionRail">
                {% for product in monthly_collection_printable_products %}
                  {% assign product_image = product.featured_image | default: product.featured_media.preview_image | default: product.images.first %}
                  {% assign product_variant = product.selected_or_first_available_variant %}
                  <div class="sss-me2__productCard">
                    <div class="sss-me2__productImage">
                      {% if product_image != blank %}
                        {{ product_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
                      {% endif %}
                    </div>
                    <div class="sss-me2__productMeta">
                      <span class="sss-me2__productTag">printable</span>
                      <p class="sss-me2__productName">{{ product.title }}</p>
                      <span class="sss-me2__productPrice">free</span>
                    </div>
                    <div class="sss-me2__productActions">
                      {% assign rendered_variant_buttons = false %}
                      {% for variant in product.variants %}
                        {% if variant.available %}
                          {% assign variant_label = variant.title %}
                          {% assign variant_download = '' %}
                          {% assign variant_download = '' %}
                          {% if variant.metafields.custom.download_file.value != blank %}
                            {% if variant.metafields.custom.download_file.value.url != blank %}
                              {% assign variant_download = variant.metafields.custom.download_file.value.url %}
                            {% else %}
                              {% assign variant_download = variant.metafields.custom.download_file.value | file_url %}
                            {% endif %}
                          {% elsif product.metafields.custom.download_file.value != blank %}
                            {% if product.metafields.custom.download_file.value.url != blank %}
                              {% assign variant_download = product.metafields.custom.download_file.value.url %}
                            {% else %}
                              {% assign variant_download = product.metafields.custom.download_file.value | file_url %}
                            {% endif %}
                          {% endif %}
                          {% if variant_download contains 'dropbox.com' %}
                            {% assign variant_download = variant_download | replace: 'www.dropbox.com', 'dl.dropboxusercontent.com' | replace: 'dropbox.com', 'dl.dropboxusercontent.com' | replace: '?dl=0', '?raw=1' | replace: '&dl=0', '&raw=1' %}
                          {% endif %}
                          {% if variant_label == blank or variant_label == 'Default Title' %}
                            {% assign variant_label = 'download free' %}
                          {% else %}
                            {% assign variant_label = variant_label | append: ' · free' %}
                          {% endif %}
                          {% if variant_download != blank %}
                            <a class="sss-me2__productBtn" href="{{ variant_download }}" target="_blank" rel="noopener" download>{{ variant_label }}</a>
                            {% assign rendered_variant_buttons = true %}
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                      {% assign product_download = '' %}
                      {% if product.metafields.custom.download_file.value != blank %}
                        {% if product.metafields.custom.download_file.value.url != blank %}
                          {% assign product_download = product.metafields.custom.download_file.value.url %}
                        {% else %}
                          {% assign product_download = product.metafields.custom.download_file.value | file_url %}
                        {% endif %}
                      {% endif %}
                      {% if product_download contains 'dropbox.com' %}
                        {% assign product_download = product_download | replace: 'www.dropbox.com', 'dl.dropboxusercontent.com' | replace: 'dropbox.com', 'dl.dropboxusercontent.com' | replace: '?dl=0', '?raw=1' | replace: '&dl=0', '&raw=1' %}
                      {% endif %}
                      {% if rendered_variant_buttons == false and product_download != blank %}
                        <a class="sss-me2__productBtn" href="{{ product_download }}" target="_blank" rel="noopener" download>download free</a>
                      {% elsif rendered_variant_buttons == false %}
                        <span class="sss-me2__productBtn" aria-disabled="true">file coming soon</span>
                      {% endif %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}
          {% if monthly_collection_physical_products != blank %}
            <div class="sss-me2__collectionGroup">
              {%- assign all_physical_variant_ids = '' -%}
              {%- assign all_physical_count = 0 -%}
              {%- assign all_physical_total = 0 -%}
              {%- for product in monthly_collection_physical_products -%}
                {%- assign all_variant = product.selected_or_first_available_variant -%}
                {%- if all_variant != blank and all_variant.available -%}
                  {%- assign all_physical_count = all_physical_count | plus: 1 -%}
                  {%- assign all_physical_total = all_physical_total | plus: all_variant.price -%}
                  {%- if all_physical_variant_ids == blank -%}
                    {%- assign all_physical_variant_ids = all_variant.id | append: '' -%}
                  {%- else -%}
                    {%- assign all_physical_variant_ids = all_physical_variant_ids | append: ',' | append: all_variant.id -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              <div class="sss-me2__collectionGroupHead">
                <p class="sss-me2__collectionLabel">physical</p>
                {% if all_physical_count > 1 %}
                  <button class="sss-me2__collectionAll" type="button" onclick='sssAddMany({{ all_physical_variant_ids | split: "," | json }}, {{ "monthly collection · all physical" | json }})'>
                    add all · {{ all_physical_total | money_without_trailing_zeros }}
                  </button>
                {% endif %}
              </div>
              <div class="sss-me2__collectionRail">
                {% for product in monthly_collection_physical_products %}
                  {% assign product_image = product.featured_image | default: product.featured_media.preview_image | default: product.images.first %}
                  {% assign product_variant = product.selected_or_first_available_variant %}
                  <div class="sss-me2__productCard">
                    <div class="sss-me2__productImage">
                      {% if product_image != blank %}
                        {{ product_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
                      {% endif %}
                    </div>
                    <div class="sss-me2__productMeta">
                      <span class="sss-me2__productTag">physical</span>
                      <p class="sss-me2__productName">{{ product.title }}</p>
                      {% if product_variant != blank %}
                        <span class="sss-me2__productPrice">{{ product_variant.price | money_without_trailing_zeros }}</span>
                      {% endif %}
                    </div>
                    <div class="sss-me2__productActions">
                      {% assign rendered_variant_buttons = false %}
                      {% for variant in product.variants %}
                        {% if variant.available %}
                          {% assign variant_label = variant.title %}
                          {% assign variant_price_label = variant.price | money_without_trailing_zeros %}
                          {% if variant_label == blank or variant_label == 'Default Title' %}
                            {% assign variant_label = 'add to cart' %}
                          {% else %}
                            {% assign variant_label = variant_label | append: ' · ' | append: variant_price_label %}
                          {% endif %}
                          <button class="sss-me2__productBtn" type="button" onclick='sssAdd({{ variant.id | json }}, {{ product.title | append: " · " | append: variant.title | json }})'>{{ variant_label }}</button>
                          {% assign rendered_variant_buttons = true %}
                        {% endif %}
                      {% endfor %}
                      {% if rendered_variant_buttons == false and product_variant != blank %}
                        <button class="sss-me2__productBtn" type="button" onclick='sssAdd({{ product_variant.id | json }}, {{ product.title | append: " · physical" | json }})'>add to cart</button>
                      {% elsif rendered_variant_buttons == false %}
                        <a class="sss-me2__productBtn" href="{{ product.url }}">view product</a>
                      {% endif %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        </div>
      </section>
    {% endif %}

    <div class="sss-mpg__grid">

      {% if kicker != blank or title != blank or subtext != blank or show_printable or show_physical %}
        <div class="sss-me2">
          {% if kicker != blank %}
            <p class="sss-me2__kicker">{{ kicker }}</p>
          {% endif %}

          <article class="sss-me2__card">

            {% if title != blank or subtext != blank %}
              <div class="sss-me2__head">
                {% if title != blank %}<h3 class="sss-me2__title">{{ title }}</h3>{% endif %}
                {% if subtext != blank %}<p class="sss-me2__sub">{{ subtext }}</p>{% endif %}
              </div>
            {% endif %}

            {% if show_printable or show_physical %}
              <section class="sss-me2__grid">

                {% if show_printable %}
                  <div class="sss-me2__panel">
                    {% if printable_pill != blank %}
                      <div class="sss-me2__panelTop">
                        <span class="sss-me2__pill">{{ printable_pill }}</span>
                      </div>
                    {% endif %}

                    <div class="sss-me2__media">
                      {% if printable_image != blank %}
                        {{ printable_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'Printable preview' }}
                      {% endif %}
                    </div>

                    {% if printable_note != blank %}
                      <p class="sss-me2__note">{{ printable_note }}</p>
                    {% endif %}

                    {% if bonus_printable_product != blank or dl12 != blank or dl11 != blank or dl6 != blank or dl10 != blank %}
                      <div class="sss-me2__btnWrap">
                        {% if printable_product_name != blank %}
                          <p class="sss-me2__productLine">{{ printable_product_name }}</p>
                        {% endif %}
                        <div class="sss-me2__btnGrid">
                          {% if bonus_printable_product != blank %}
                            {% if printable_show12 and printable_dl12 != blank %}<a class="sss-me2__btn" href="{{ printable_dl12 }}" download>12th gen · {{ printable_price_label }}</a>{% endif %}
                            {% if printable_show11 and printable_dl11 != blank %}<a class="sss-me2__btn" href="{{ printable_dl11 }}" download>11th gen · {{ printable_price_label }}</a>{% endif %}
                            {% if printable_show6 and printable_dl6 != blank %}<a class="sss-me2__btn" href="{{ printable_dl6 }}" download>6 inch · {{ printable_price_label }}</a>{% endif %}
                            {% if printable_show10 and printable_dl10 != blank %}<a class="sss-me2__btn" href="{{ printable_dl10 }}" download>10th gen · {{ printable_price_label }}</a>{% endif %}
                            {% if printable_show12 == false and printable_show11 == false and printable_show6 == false and printable_show10 == false %}
                              {% if printable_product_download != blank %}
                                <a class="sss-me2__btn" href="{{ printable_product_download }}" download>download free</a>
                              {% elsif printable_product_url != blank %}
                                <a class="sss-me2__btn" href="{{ printable_product_url }}">view product</a>
                              {% endif %}
                            {% endif %}
                          {% else %}
                            {% if dl12 != blank %}<a class="sss-me2__btn" href="{{ dl12 }}">12th gen</a>{% endif %}
                            {% if dl11 != blank %}<a class="sss-me2__btn" href="{{ dl11 }}">11th gen</a>{% endif %}
                            {% if dl6  != blank %}<a class="sss-me2__btn" href="{{ dl6 }}">6 inch</a>{% endif %}
                            {% if dl10 != blank %}<a class="sss-me2__btn" href="{{ dl10 }}">10th gen</a>{% endif %}
                          {% endif %}
                        </div>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}

                {% if show_physical %}
                  <div class="sss-me2__panel">
                    {% if physical_pill != blank %}
                      <div class="sss-me2__panelTop">
                        <span class="sss-me2__pill">{{ physical_pill }}</span>
                      </div>
                    {% endif %}

                    <div class="sss-me2__media">
                      {% if physical_image != blank %}
                        {{ physical_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'Physical preview' }}
                      {% endif %}
                    </div>

                    {% if physical_note != blank %}
                      <p class="sss-me2__note">{{ physical_note }}</p>
                    {% endif %}

                    {% if show12 or show11 or show6 or show10 or physical_product_url != blank %}
                      <div class="sss-me2__btnWrap">
                        {% if product_name != blank %}
                          <p class="sss-me2__productLine">{{ product_name }}</p>
                        {% endif %}
                        <div class="sss-me2__btnGrid">
                          {% if show12 %}
                            <button class="sss-me2__btn" type="button" onclick='sssAdd({{ v12 | json }}, {{ product_name | append: " · 12th gen" | json }})'>12th gen · {{ price_label }}</button>
                          {% endif %}
                          {% if show11 %}
                            <button class="sss-me2__btn" type="button" onclick='sssAdd({{ v11 | json }}, {{ product_name | append: " · 11th gen" | json }})'>11th gen · {{ price_label }}</button>
                          {% endif %}
                          {% if show6 %}
                            <button class="sss-me2__btn" type="button" onclick='sssAdd({{ v6 | json }}, {{ product_name | append: " · 6 inch" | json }})'>6 inch · {{ price_label }}</button>
                          {% endif %}
                          {% if show10 %}
                            <button class="sss-me2__btn" type="button" onclick='sssAdd({{ v10 | json }}, {{ product_name | append: " · 10th gen" | json }})'>10th gen · {{ price_label }}</button>
                          {% endif %}
                          {% if show12 == false and show11 == false and show6 == false and show10 == false and physical_product_url != blank %}
                            <a class="sss-me2__btn" href="{{ physical_product_url }}">view product</a>
                          {% endif %}
                        </div>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}

              </section>
            {% endif %}

          </article>
        </div>
      {% endif %}

      {% if show_gram %}
        <aside class="gramcard">
          {% if gram_kicker != blank or gram_title != blank or gram_sub != blank %}
            <div class="gramcard__head">
              {% if gram_kicker != blank %}<p class="gramcard__kicker">{{ gram_kicker }}</p>{% endif %}
              {% if gram_title != blank %}<h3 class="gramcard__title">{{ gram_title }}</h3>{% endif %}
              {% if gram_sub != blank %}<p class="gramcard__sub">{{ gram_sub }}</p>{% endif %}
            </div>
          {% endif %}

          <div class="gramcard__body">
            {% if gram_image != blank %}
              <a href="{{ gram_url }}" target="_blank" rel="noopener" class="gramcard__imageLink" aria-label="open bybookishbabe on instagram">
                {{ gram_image | image_url: width: 1600 | image_tag: class: 'gramcard__img', loading: 'lazy', alt: 'From the gram' }}
              </a>
            {% endif %}

            {% if gram_caption != blank %}
              <p class="gramcard__caption">{{ gram_caption }}</p>
            {% endif %}
          </div>
        </aside>
      {% endif %}

    </div>
  </div>
</section>

<script>
(function(){
  if (document.getElementById('sssToast')) return;
  const t = document.createElement('div');
  t.id = 'sssToast';
  t.className = 'sss-toast';
  document.body.appendChild(t);
})();

function sssToast(msg, sub){
  const el = document.getElementById('sssToast');
  if (!el) return;
  el.innerHTML = sub ? (msg + '<br><span>' + sub + '</span>') : msg;
  el.classList.add('show');
  setTimeout(function(){ el.classList.remove('show'); }, 2400);
}

function sssAdd(variantId, label){
  fetch('/cart/add.js', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ id: Number(variantId), quantity: 1 })
  })
  .then(function(res){
    if (res.ok){
      sssToast('added to cart 🤍', label);
      return;
    }
    return res.json().then(function(data){
      var msg = "couldn't add";
      if (data && (data.description || data.message)) msg = data.description || data.message;
      sssToast('not added 🖤', msg);
    }).catch(function(){
      sssToast('not added 🖤', "couldn't add");
    });
  })
  .catch(function(){
    sssToast('not added 🖤', 'network error');
  });
}

function sssAddMany(variantIds, label){
  var ids = (variantIds || []).filter(function(id){ return !!id; }).map(function(id){
    return Number(id);
  }).filter(Boolean);
  if (!ids.length) {
    sssToast('not added 🖤', 'invalid variant id');
    return;
  }
  fetch('/cart/add.js', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({
      items: ids.map(function(id){
        return { id: id, quantity: 1 };
      })
    })
  })
  .then(function(res){
    if (res.ok){
      sssToast('added to cart 🤍', label);
      return;
    }
    return res.json().then(function(data){
      var msg = "couldn't add";
      if (data && (data.description || data.message)) msg = data.description || data.message;
      sssToast('not added 🖤', msg);
    }).catch(function(){
      sssToast('not added 🖤', "couldn't add");
    });
  })
  .catch(function(){
    sssToast('not added 🖤', 'network error');
  });
}
</script>

{%- endif -%}

{% schema %}
{
  "name": "sss member+gram",
  "settings": [],
  "presets": [
    { "name": "sss member+gram" }
  ]
}
{% endschema %}
