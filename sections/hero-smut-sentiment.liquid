<section class="hero-custom">
  <div class="hero-overlay"></div>

  <div class="hero-frame">
    <h1 class="hero-heading">
      <span class="hero-cursive">{{ section.settings.heading }}</span>
    </h1>

    <p class="hero-mini">{{ section.settings.mini_text }}</p>

    <p class="hero-subtitle">
      {{ section.settings.subtitle }}
    </p>

    <div class="hero-buttons">
      {% if section.settings.primary_link != blank %}
        <a href="{{ section.settings.primary_link }}" class="btn-primary">
          {{ section.settings.primary_label }}
        </a>
      {% endif %}

      {% if section.settings.secondary_link != blank %}
        <a href="{{ section.settings.secondary_link }}" class="btn-secondary">
          {{ section.settings.secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .hero-frame > * {
    opacity: 0;
    animation: bbbHeroFade 0.8s ease forwards;
  }

  .hero-heading {
    animation-delay: 0.1s;
  }

  .hero-mini {
    animation-delay: 0.28s;
  }

  .hero-subtitle {
    animation-delay: 0.44s;
  }

  .hero-buttons {
    animation-delay: 0.6s;
  }

  @keyframes bbbHeroFade {
    from {
      opacity: 0;
      transform: translateY(1.6rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

</style>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "smut meets sentiment"
    },
    {
      "type": "text",
      "id": "mini_text",
      "label": "Mini line",
      "default": "for soft hearts with sinful taste."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "beautiful things for readers + a tastefully smutty society 🖤"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "shop new this month"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "join the society"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
