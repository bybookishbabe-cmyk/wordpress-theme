{% assign context_downcase = context | default: '' | downcase %}
{% assign cluster = '' %}
{% assign prompt_text = prompt | default: 'looking for something specific?' %}
{% assign forced_proximity_page_handle = 'forced-proximity-romance-books' %}
{% assign forced_proximity_page_url = '/pages/' | append: forced_proximity_page_handle %}

{% if context_downcase contains 'stalker' or context_downcase contains 'obsession' or context_downcase contains 'obsessive' %}
  {% assign cluster = 'stalker' %}
{% elsif context_downcase contains 'darkobsession' or context_downcase contains 'dark-obsession' or context_downcase contains 'dark obsession' %}
  {% assign cluster = 'darkobsession' %}
{% elsif context_downcase contains 'darkromantasy' or context_downcase contains 'dark-romantasy' or context_downcase contains 'dark romantasy' or context_downcase contains 'ever king' %}
  {% assign cluster = 'darkromantasy' %}
{% elsif context_downcase contains 'morallygrayfantasy' or context_downcase contains 'morally-gray-fantasy' or context_downcase contains 'morally gray fantasy' %}
  {% assign cluster = 'morallygrayfantasy' %}
{% elsif context_downcase contains 'sport' or context_downcase contains 'hockey' or context_downcase contains 'football' or context_downcase contains 'athlete' or context_downcase contains 'baseball' or context_downcase contains 'basketball' %}
  {% assign cluster = 'sports' %}
{% elsif context_downcase contains 'romantasy' or context_downcase contains 'fantasy' or context_downcase contains 'fae' or context_downcase contains 'fated' or context_downcase contains 'dragon' or context_downcase contains 'magic' %}
  {% assign cluster = 'romantasy' %}
{% elsif context_downcase contains 'slow-burn' or context_downcase contains 'slow burn' %}
  {% assign cluster = 'slowburn' %}
{% elsif context_downcase contains 'soft' or context_downcase contains 'small-town' or context_downcase contains 'small town' or context_downcase contains 'second-chance' or context_downcase contains 'second chance' or context_downcase contains 'friends-to-lovers' or context_downcase contains 'friends to lovers' %}
  {% assign cluster = 'soft' %}
{% elsif context_downcase contains 'morally-gray' or context_downcase contains 'morally gray' %}
  {% assign cluster = 'morallygraymen' %}
{% elsif context_downcase contains 'captor' or context_downcase contains 'captive' or context_downcase contains 'touch her and die' or context_downcase contains 'villain' or context_downcase contains 'dark' or context_downcase contains 'extra-dark' %}
  {% assign cluster = 'dark' %}
{% endif %}

