{% assign page_handles = '' %}
{% assign guide_handles = '' %}
{% assign nav_markup = '' %}

{% case cluster %}
  {% when 'morallygraymen' %}
    {% assign nav_markup = nav_morallygraymen %}
    {% assign page_handles = 'dark-romance-books|villain-gets-the-girl-romance-books|touch-her-and-die-books|stalker-romance-books|' %}
  {% when 'darkobsession' %}
    {% assign nav_markup = nav_darkobsession %}
    {% assign page_handles = 'dark-romance-books|touch-her-and-die-books|enemies-to-lovers|' %}
    {% assign guide_handles = 'the-best-dark-romance-books-with-morally-gray-men-that-will-ruin-you|' %}
  {% when 'morallygrayfantasy' %}
    {% assign nav_markup = nav_morallygrayfantasy %}
    {% assign page_handles = 'romantasy-books|touch-her-and-die-books|villain-gets-the-girl-romance-books|' %}
    {% assign guide_handles = 'the-best-dark-romance-books-with-morally-gray-men-that-will-ruin-you|' %}
  {% when 'darkromantasy' %}
    {% assign nav_markup = nav_darkromantasy %}
    {% assign page_handles = 'villain-gets-the-girl-romance-books|' %}
    {% assign guide_handles = 'the-ultimate-romantasy-reading-guide|dark-romantasy-books|' %}
  {% when 'stalker' %}
    {% assign nav_markup = nav_stalker %}
    {% assign page_handles = 'stalker-romance-books|dark-romance-books|touch-her-and-die-books|' %}
  {% when 'sports' %}
    {% assign nav_markup = nav_sports %}
    {% capture page_handles %}slow-burn-books|fake-dating-romance-books|{{ forced_proximity_page_handle }}|{% endcapture %}
  {% when 'romantasy' %}
    {% assign nav_markup = nav_romantasy %}
    {% assign page_handles = 'romantasy-books|fated-mates-romance-books|' %}
    {% assign guide_handles = 'spicy-romantasy-books-that-are-actually-worth-it|' %}
  {% when 'soft' %}
    {% assign nav_markup = nav_soft %}
    {% assign page_handles = 'slow-burn-books|friends-to-lovers-romance-books|small-town-romance-books|second-chance-romance-books|' %}
  {% when 'slowburn' %}
    {% assign nav_markup = nav_slowburn %}
    {% capture page_handles %}enemies-to-lovers|{{ forced_proximity_page_handle }}|he-falls-first-romance-books|{% endcapture %}
  {% when 'dark' %}
    {% assign nav_markup = nav_dark %}
    {% assign page_handles = 'stalker-romance-books|captor-captive-romance-books|' %}
    {% assign guide_handles = 'the-best-dark-romance-books-with-morally-gray-men-that-will-ruin-you|' %}
{% endcase %}

{% if mode == 'cluster' %}
  {{ cluster }}
{% elsif mode == 'page_handles' %}
  {{ page_handles }}
{% elsif mode == 'guide_handles' %}
  {{ guide_handles }}
{% else %}
  {{ nav_markup }}
{% endif %}
